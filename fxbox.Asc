'***************************************************************************** 
'*convert********************************************************************* 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'     .,-::::::    ...     ::.    :::.:::      .::..,:::::::::::::..  :::::::::: 
'   ,;;;'````'  .;;;;;;;.  ;;;;,  `;;;';;,   ,;;;' ;;;;'''';;;;``;;;; ;;;;;;;''' 
'   [[[        ,[[     \[[, [[[[[. '[[ \[[  .[[/    [[cccc \[[[,/[[['     [['    
'   $$$        $$$,     $$$ $$$ "Y$c$$  Y$c.$$"     $$"""" "$$$$$$c       $$ 
'   `88bo,__,o,"888,_ _,88P888    Y88    Y88P       888oo,_,888b "88bo    88,
'     "YUMMMMMP  "YMMMMMP" MM     YM      MP        """"YUM"MMMM   "W"    MMM
'
'
'
_8BITUNSIGNEDTO8BIT:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
Repeat 
   Poke FX,Peek(FX)-128
   Inc FX
Until FX>FXE
Return 
'  
_16BITTO8BIT:
_FLIP=False
Goto P16BIT
'
_16BITTO8BITFLIP:
_FLIP=True
'
P16BIT:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
FX_LENGTH2=FX_LENGTH/2
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
CN=0
FX2=FX
If _FLIP
   Repeat 
      CN3=Varptr(CN)
      Poke CN3+1,Peek(FX) : Inc FX
      Poke CN3,Peek(FX) : Inc FX
      Poke FX2,Deek(CN3)/256
      Inc FX2
   Until FX>FXE
Else 
   Repeat 
      Poke FX2,Deek(FX)/256 : Add FX,2
      Inc FX2
   Until FX>FXE
End If 
Copy FX_START,FX_START+FX_LENGTH2 To Start(WBANK)
Gosub _WORKSWAP
Gosub _CLEARWORK
Goto _RESIZED
'
_16BITFLIP:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
CN=0
Repeat 
   CN3=Varptr(CN)
   Poke CN3+1,Peek(FX)
   Poke CN3,Peek(FX+1)
   Doke FX,Deek(CN3)
   Add FX,2
Until FX>FXE
Return 
'
_24BITTO8BIT:
_FLIP=False
Goto P24BIT8
'
_24BITTO8BITFLIP:
_FLIP=True
'  
P24BIT8:
Gosub SETPBANK
FX_LENGTH2=FX_LENGTH/3
If FX_LENGTH<2 Then Goto FLSHSCR
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
CN=0
FX2=FX
Randomize Timer
If _FLIP
   Repeat 
      CN3=Varptr(CN)
      Poke CN3+3,Peek(FX) : Inc FX
      Poke CN3+2,Peek(FX) : Inc FX
      Poke CN3+1,Peek(FX) : Inc FX
      Poke CN3,0
      Gosub DITHER
      CN=Leek(CN3)
      Gosub DITHER24
      Poke FX2,CN/65536
      Inc FX2
   Until FX>FXE
Else 
   Repeat 
      CN3=Varptr(CN)
      Poke CN3,0
      Poke CN3+1,Peek(FX) : Inc FX
      Poke CN3+2,Peek(FX) : Inc FX
      Poke CN3+3,Peek(FX) : Inc FX
      Gosub DITHER
      CN=Leek(CN3)
      Gosub DITHER24
      Poke FX2,CN/65536
      Inc FX2
   Until FX>FXE
End If 
Copy FX_START,FX_START+FX_LENGTH2 To Start(WBANK)
Gosub _WORKSWAP
Gosub _CLEARWORK
Goto _RESIZED
'
_24BITTO16BIT:
_FLIP=False
Goto P24BIT16
'
_24BITTO16BITFLIP:
_FLIP=True
'
P24BIT16:
Gosub SETPBANK
FX_LENGTH2=FX_LENGTH-(FX_LENGTH/3)
If FX_LENGTH<2 Then Goto FLSHSCR
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
CN=0
FX2=FX
Randomize Timer
If _FLIP
   Repeat 
      CN3=Varptr(CN)
      Poke CN3+3,Peek(FX) : Inc FX
      Poke CN3+2,Peek(FX) : Inc FX
      Poke CN3+1,Peek(FX) : Inc FX
      Poke CN3,0
      Gosub DITHER
      CN=Leek(CN3)
      Gosub DITHER24
      Doke FX2,CN/256
      Add FX2,2
   Until FX>FXE
Else 
   Repeat 
      CN3=Varptr(CN)
      Poke CN3,0
      Poke CN3+1,Peek(FX) : Inc FX
      Poke CN3+2,Peek(FX) : Inc FX
      Poke CN3+3,Peek(FX) : Inc FX
      Gosub DITHER
      CN=Leek(CN3)
      Gosub DITHER24
      Doke FX2,CN/256
      Add FX2,2
   Until FX>FXE
End If 
Copy FX_START,FX_START+FX_LENGTH2 To Start(WBANK)
Gosub _WORKSWAP
Gosub _CLEARWORK
Goto _RESIZED
'
_32BITTO8BIT:
_FLIP=False
Goto P32BIT8
'
_32BITTO8BITFLIP:
_FLIP=True
'
P32BIT8:
Gosub MATH
Gosub SETPBANK
FX_LENGTH2=FX_LENGTH/4
If FX_LENGTH<2 Then Goto FLSHSCR
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
CN=0 : CN#=0
FX2=FX
If _FLIP
   Repeat 
      CN3=Varptr(CN)
      CN2=Varptr(CN#)
      Poke CN3+3,Peek(FX) : Inc FX
      Poke CN3+2,Peek(FX) : Inc FX
      Poke CN3+1,Peek(FX) : Inc FX
      Poke CN3,Peek(FX) : Inc FX
      Dreg(0)=CN
      CN=Lib Call(1,-108) : Rem _LVOIEEESPFiee 
      Loke CN2,Leek(CN3)
      Gosub FLOATCLIP
      If CN#<0
         CN=Int(CN#*128)
      Else 
         CN=Int(CN#*127)
      End If 
      Poke FX2,CN
      Inc FX2
   Until FX>FXE
Else 
   Repeat 
      CN3=Varptr(CN)
      CN2=Varptr(CN#)
      Loke CN3,Leek(FX) : Add FX,4
      Dreg(0)=CN
      CN=Lib Call(1,-108) : Rem _LVOIEEESPFiee 
      Loke CN2,Leek(CN3)
      Gosub FLOATCLIP
      If CN#<0
         CN=Int(CN#*128)
      Else 
         CN=Int(CN#*127)
      End If 
      Poke FX2,CN
      Inc FX2
   Until FX>FXE
End If 
Copy FX_START,FX_START+FX_LENGTH2 To Start(WBANK)
Gosub _WORKSWAP
Gosub _CLEARWORK
Goto _RESIZED
'
_32BITTO16BIT:
_FLIP=False
Goto P32BIT16
'
_32BITTO16BITFLIP:
_FLIP=True
'
P32BIT16:
Gosub MATH
Gosub SETPBANK
FX_LENGTH2=FX_LENGTH/2
If FX_LENGTH<2 Then Goto FLSHSCR
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
CN=0 : CN#=0
FX2=FX
If _FLIP
   Repeat 
      CN3=Varptr(CN)
      CN2=Varptr(CN#)
      Poke CN3+3,Peek(FX) : Inc FX
      Poke CN3+2,Peek(FX) : Inc FX
      Poke CN3+1,Peek(FX) : Inc FX
      Poke CN3,Peek(FX) : Inc FX
      Dreg(0)=CN
      CN=Lib Call(1,-108) : Rem _LVOIEEESPFiee 
      Loke CN2,Leek(CN3)
      Gosub FLOATCLIP
      If CN#<0
         CN=Int(CN#*32768)
      Else 
         CN=Int(CN#*32767)
      End If 
      Doke FX2,CN
      Add FX2,2
   Until FX>FXE
Else 
   Repeat 
      CN3=Varptr(CN)
      CN2=Varptr(CN#)
      Loke CN3,Leek(FX) : Add FX,4
      Dreg(0)=CN
      CN=Lib Call(1,-108) : Rem _LVOIEEESPFiee 
      Loke CN2,Leek(CN3)
      Gosub FLOATCLIP
      If CN#<0
         CN=Int(CN#*32768)
      Else 
         CN=Int(CN#*32767)
      End If 
      Doke FX2,CN
      Add FX2,2
   Until FX>FXE
End If 
Copy FX_START,FX_START+FX_LENGTH2 To Start(WBANK)
Gosub _WORKSWAP
Gosub _CLEARWORK
Goto _RESIZED
'
_32BITTO24BIT:
_FLIP=False
Goto P32BIT24
'
_32BITTO24BITFLIP:
_FLIP=True
'
P32BIT24:
Gosub MATH
Gosub SETPBANK
FX_LENGTH2=FX_LENGTH-(FX_LENGTH/4)
If FX_LENGTH<2 Then Goto FLSHSCR
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
CN=0 : CN#=0
FX2=FX
If _FLIP
   Repeat 
      CN3=Varptr(CN)
      CN2=Varptr(CN#)
      Poke CN3+3,Peek(FX) : Inc FX
      Poke CN3+2,Peek(FX) : Inc FX
      Poke CN3+1,Peek(FX) : Inc FX
      Poke CN3,Peek(FX) : Inc FX
      Dreg(0)=CN
      CN=Lib Call(1,-108) : Rem _LVOIEEESPFiee 
      Loke CN2,Leek(CN3)
      Gosub FLOATCLIP
      If CN#<0
         CN=Int(CN#*8388608)
      Else 
         CN=Int(CN#*8388607)
      End If 
      Poke FX2,Peek(Varptr(CN)+1) : Inc FX2
      Poke FX2,Peek(Varptr(CN)+2) : Inc FX2
      Poke FX2,Peek(Varptr(CN)+3) : Inc FX2
   Until FX>FXE
Else 
   Repeat 
      CN3=Varptr(CN)
      CN2=Varptr(CN#)
      Loke CN3,Leek(FX) : Add FX,4
      Dreg(0)=CN
      CN=Lib Call(1,-108) : Rem _LVOIEEESPFiee 
      Loke CN2,Leek(CN3)
      Gosub FLOATCLIP
      If CN#<0
         CN=Int(CN#*8388608)
      Else 
         CN=Int(CN#*8388607)
      End If 
      Poke FX2,Peek(Varptr(CN)+1) : Inc FX2
      Poke FX2,Peek(Varptr(CN)+2) : Inc FX2
      Poke FX2,Peek(Varptr(CN)+3) : Inc FX2
   Until FX>FXE
End If 
Copy FX_START,FX_START+FX_LENGTH2 To Start(WBANK)
Gosub _WORKSWAP
Gosub _CLEARWORK
Goto _RESIZED
'
'
'
'***************************************************************************** 
'***encoding****************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'   .,::::::::.    :::.  .,-::::::    ...     ::::::-.   :::  ::.    :::. .,-::::: 
'   ;;;;'''';;;;,  `;;;,;;;'````'  .;;;;;;;.  ;;,   `';, ;;;  ;;;;,  `;;;;;-'````' 
'    [[cccc  [[[[[. '[[[[[        ,[[     \[[,`[[     [[ [[[   [[[[[. '[[[[   [[[[ 
'    $$""""  $$$ "Y$c$$$$$        $$$,     $$$ $$,    $$ $$$,  $$$ "Y$c$$$$c.    " 
'    888oo,_888    Y88 `88bo,__,o,"888,_ _,88P 888_,o8P'o88888888    Y88 `Y8bo,,,o 
'    """"YUMMM     YM    "YUMMMMMP  "YMMMMMP" "MMMMP"`  MMM"MMMM     YM    `'YMUP" 
'  
'
'
_INTERLEAVE:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
FX_LENGTH2=FX_LENGTH
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
FX_START2=Start(WBANK)
Copy FX_START,FX_START+FX_LENGTH To FX_START2
FX_LENGTH3=FX_LENGTH2/2
FX2=FX_START2
Repeat 
   Poke FX,Peek(FX2) : Inc FX
   Poke FX,Peek(FX2+FX_LENGTH3) : Inc FX
   Inc FX2
Until FX>FXE
Goto _CLEARWORK
'
_DEINTERLEAVE:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
FX_LENGTH2=FX_LENGTH/2
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
FX_START2=Start(WBANK)
FX2=0
Add FXE,-2
Repeat 
   Poke FX_START+FX2,Peek(FX)
   Inc FX
   Poke FX_START2+FX2,Peek(FX)
   Inc FX
   Inc FX2
Until FX>FXE
Copy FX_START2,FX_START2+FX_LENGTH2 To FX_START+FX_LENGTH2
Goto _CLEARWORK
'
_DEINTERLEAVE16BIT:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
FX_LENGTH2=FX_LENGTH/2
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
FX_START2=Start(WBANK)
FX2=0
Add FXE,-4
Repeat 
   Loke FX_START+FX2,Leek(FX)
   Add FX,2
   Loke FX_START2+FX2,Leek(FX)
   Add FX,2
   Add FX2,2
Until FX>FXE
Copy FX_START2,FX_START2+FX_LENGTH2 To FX_START+FX_LENGTH2
Goto _CLEARWORK
'
_DEINTERLEAVE24BIT:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
FX_LENGTH2=FX_LENGTH/2
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
FX_START2=Start(WBANK)
FX2=0
Add FXE,-6
Repeat 
   Loke FX_START+FX2,Leek(FX)
   Add FX,2
   Poke FX_START+FX2+2,Peek(FX)
   Inc FX
   Loke FX_START2+FX2,Leek(FX)
   Add FX,2
   Poke FX_START2+FX2+2,Peek(FX)
   Inc FX
   Add FX2,3
Until FX>FXE
Copy FX_START2,FX_START2+FX_LENGTH2 To FX_START+FX_LENGTH2
Goto _CLEARWORK
'  
'**************************************************************************
'  Steve Hayes Fibonacci Delta sound compression technique         
'
_DECODEFIBONACCIDELTA:
Restore FIB
Goto DEDEL
_DECODEEXPONENTIALDELTA:
Restore XPO
DEDEL:
I=0
Repeat 
   Read DELTA(I)
   Inc I
Until I>15
Gosub SETPBANK
RST=0 : RL=P_LENGTH
T$=G$
G$="DELDE"
Gosub G$
Gosub STEREOQUADX2
RST=0 : RL=0
Gosub _RESIZED
COMP(B)=0
Return 
'
DELDE:
Gosub SETPBANK
FX_LENGTH2=((FX_LENGTH-2)*2)
If FX_LENGTH<2 Then Goto FLSHSCR
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
_UNDID$=T$
FX2=Start(WBANK)
Inc FX : CN3=Peek(FX) : Inc FX : Rem a pad byte, an 8bit initial value  
_NYBBLE=False
Repeat 
   CN=Peek(FX)
   If _NYBBLE
      CN=CN and $F
      Inc FX
      _NYBBLE=False
   Else 
      Ror.b 4,CN
      Bclr 4,CN
      Bclr 5,CN
      Bclr 6,CN
      Bclr 7,CN
      _NYBBLE=True
   End If 
   Add CN3,DELTA(CN)
   Poke FX2,CN3
   Inc FX2
Until FX>FXE
If _CHANNELS<2
   Gosub _WORKSWAP
   Gosub _CLEARWORK
End If 
Return 
'
'**************************************************************************
'
_ENCODEFIBONACCIDELTA:
Restore FIB : COMP=1
Goto ENCDEL
_ENCODEEXPONENTIALDELTA:
Restore XPO : COMP=2
ENCDEL:
I=0
Repeat 
   Read DELTA(I)
   Inc I
Until I>15
Gosub SETPBANK
RST=0 : RL=P_LENGTH
T$=G$
G$="DELENC"
Gosub G$
Gosub STEREOQUADX2
RST=0 : RL=0
Gosub _RESIZED
COMP(B)=COMP
Return 
'
DELENC:
Gosub SETPBANK
FX_LENGTH2=(FX_LENGTH/2)+2
If FX_LENGTH<2 Then Goto FLSHSCR
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
_UNDID$=T$
FX2=Start(WBANK)
_NYBBLE=False
CN2=Peek(FX)
Gosub SIGN2
Inc FX2 : Poke FX2,CN2 : Inc FX2 : Rem a pad byte, an 8bit initial value
Repeat 
   CN=Peek(FX) : Inc FX
   Gosub SIGN
   FX3=0 : FIBMATCH=8 : DELTAHISTORY=256
   Repeat 
      CN3=CN2+DELTA(FX3)
      If CN>CN3
         DELTA=CN-CN3
      Else 
         DELTA=CN3-CN
      End If 
      If DELTA<DELTAHISTORY
         FIBMATCH=FX3
         DELTAHISTORY=DELTA
      End If 
      Inc FX3
   Until FX3>15
   CN2=CN2+DELTA(FIBMATCH)
   If _NYBBLE
      _BYTE=FIBMATCH+_BYTE
      Poke FX2,_BYTE
      Inc FX2
      _NYBBLE=False
   Else 
      Rol.b 4,FIBMATCH
      _BYTE=FIBMATCH
      _NYBBLE=True
   End If 
Until FX>FXE
If _CHANNELS<2
   Gosub _WORKSWAP
   Gosub _CLEARWORK
End If 
Return 
'
'
'  
'***************************************************************************** 
'*process********************************************************************* 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'   ::::::::. :::::::..      ...       .,-::::::.,:::::: .::::::.  .::::::.
'   `;;```.;;;;;;;``;;;;  .;;;;;;;.  ,;;;'````' ;;;;'''';;;`    `;;;;`    `; 
'   `]]nnn]]' \[[[,/[[[' ,[[     \[[,[[[         [[cccc '[==/[[[[,'[==/[[[[, 
'    $$$""    "$$$$$$c   $$$,     $$$$$$         $$""""   '''    $  '''    $ 
'    888o     ,888b "88bo"888,_ _,88P`88bo,__,o, 888oo,_,88b    dP,88b    dP 
'    YMMMb    "MMMM   "W"  "YMMMMMP"   "YUMMMMMP """"YUM  "YMmMY"   "YMmMY"
'
'
'
_REVERSE:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Trap Reserve As Work WBANK,FX_LENGTH
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
FX2=FX_START+FX_LENGTH
Repeat 
   Dec FX2
   CN=Peek(FX2)
   Poke Start(WBANK)-FX_START+FX,CN
   Inc FX
Until FX>FXE
Copy Start(WBANK),Start(WBANK)+Length(WBANK) To FX_START
Gosub _CLEARWORK
Return 
'
_INVERT:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
Repeat 
   CN=Peek(FX)
   Gosub SIGN
   CN=-CN
   Gosub UNSIGN
   Poke FX,CN
   Inc FX
Until FX>FXE
Return 
'
'
'
'***************************************************************************** 
'*utils*********************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    ...    ::::::::::::: :::    :::     .::::::.  
'   ';;     ;;;;;;;;;;''' ;;;    ;;;    ;;;`    `; 
'   [['     [[[    [[     [[[    [[[    '[==/[[[[, 
'   $$      $$$    $$     $$$,   $$'      '''    $ 
'   88    .d888    88,   o88888o88oo,.__,88b    dP 
'    "YmmMMMM""    MMM   MMM"MM"""YUMMMM  "YMmMY"  
'
'  
'
T0NEG:
_TEXT=True : T0NEGENERATOR=True
RX=215 : RY=39
WTXT$=S$ : WX=RX-5 : WY=RY-15 : WX2=RX+215 : WY2=RY+107 : _COL=_WHITE : Gosub WIN
Restore T0B
BZN=ZN_PIANO
Repeat 
   Read BTXT1$,BX,BY,E$
   Add BX,RX : Add BY,RY : Gosub BTN
   Inc BZN
Until BZN>ZN_T0NECANCEL
Gosub T0NEPIANO
Gosub DIALT0NE
Gosub T0SET
Repeat 
   G$=_$
   Gosub GVAL
   If Z=ZN_PIANO and Fn MOUSEDOWN
      Repeat 
         Gosub GVAL
         If Z=ZN_PIANO and KDOWN=False
            Ink _COL
            Draw RX+63,RY+28 To RX+63+85,RY+28
            PZN=Z : BX=269 : BY=RY+26 : Gosub HIGHBTN
            Inc RY : Gosub T0NEPIANO : Dec RY
            N=0
            T$=_$
            KDOWN=True
         End If 
         If Fn KEY_PRESS and Z=ZN_PIANO
            Gosub PIANO
            If KEYC<>-1
               _TOAST$=KEYS$
               T0NEV#=KEYF/100.0
               Gosub T0SET
               ROT#(10)=(((T0NEV#-5)*4.8)/(FREQ/8))+8.5
               Gosub DIALT0NE
            End If 
         End If 
         If KDOWN and( Fn MOUSEUP or PZN<>Z)
            PZN=Z : BX=269 : BY=RY+26 : Gosub BTN
            Gosub T0NEPIANO
            KDOWN=False
         End If 
      Until Fn MOUSEUP
   Else If Fn MOUSEDOWN
      Restore T0B
      BZN=ZN_PIANO
      Repeat 
         Read BTXT1$,BX,BY,G$
         If Z=BZN
            PZN=Z : Add BX,RX : Add BY,RY : Gosub PRESS
            If _ON
               Gosub _UNDOSET
               S$=G$
               Gosub G$
               Gosub STEREOQUAD
               If Not MACRO
                  MACRO=True : Gosub _DCSCAN : MACRO=False
               Else 
                  Gosub _DCSCAN
               End If 
               _REPEAT$=S$
               G$=_$
               Exit 
            End If 
         End If 
         Inc BZN
      Until BZN>ZN_T0NECANCEL
      If G$=_$
         Exit 
      Else 
         Gosub DRWDIALS
      End If 
   End If 
Until Fn KEY_ESC
Goto T0NEC
'
T0NEUPDOWN:
If Fn KEY_CURSOR
   If Fn KEY_UP
      T0NEV#=T0NEV#+1
   Else If Fn KEY_DOWN
      T0NEV#=T0NEV#-1
   End If 
   Gosub T0SET
   ROT#(10)=(((T0NEV#-5)*4.8)/(FREQ/8))+8.5
End If 
Return 
'
T0NEPIANO:
Ink _BLACK
Bar RX+63,RY+28 To BX+94,RY+37
Paste Bob RX+63,RY+28,3
Return 
'
T0NECANCEL:
Pop 
REQ=False
T0NEC:
I=ZN_PIANO : N=ZN_T0NECANCEL : Gosub RESETZN
Gosub WINC
T0NEGENERATOR=False
WTXT$=_$
Gosub SETUNNAMED
If Not Fn KEY_ESC
   If G$=_$ and Length(PBANK)>0
      Goto _SHOWALL
   End If 
End If 
Return 
'
T0SET:
If T0NEV#<1
   T0NEV#=1
Else If T0NEV#>FREQ
   T0NEV#=FREQ
End If 
T0NEN=(T0NEV#/3)-2
Ink _WHITE,_SHADOW
N=Text Length(Str$(T0NEV#)+_SPACE$)
Text RX+188-N,RY-5,Space$(Len(Str$(FXSN))+1)
Text RX+212-N,RY-5,Str$(T0NEV#)-_SPACE$+_HZ$
Return 
'
T0NESET:
If Length(PBANK)=0
   S_LENGTH=FREQ*2
   Trap Reserve As Work PBANK,S_LENGTH
   Gosub SETCORDS
End If 
Return 
'
_SIN:
CN#=Sin(N#*(FX-FX_START))
Goto T
'
_COS:
CN#=Cos(N#*(FX-FX_START))
T:
If CN#<0
   CN=(T0NEA+2)*CN#
Else 
   CN=T0NEA*CN#
End If 
Goto CHECKCLIP
'
_SINTONE:
Gosub T0NESET
If Errtrap Then Goto NOMEMORY
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
N#= Fn T0NE#
Repeat 
   Gosub _SIN
   Poke FX,CN
   Inc FX
Until FX>FXE
Return 
'
_SQRTONE:
Gosub T0NESET
If Errtrap Then Goto NOMEMORY
SAWN=0
SAWMUL#=1.0
SYNTH:
Repeat 
   Gosub SETPBANK
   If FX_LENGTH<2 Then Goto FLSHSCR
   N#=(_2PI#*(T0NEV#*SAWMUL#))/FREQ
   Repeat 
      If SAWN>0
         CN2=Peek(FX)
      Else 
         CN2=0
      End If 
      Gosub _SIN
      If SAWN>0
         Poke FX,CN2+Int(CN/SAWMUL#)
      Else 
         Poke FX,CN
      End If 
      Inc FX
   Until FX>FXE
   SAWMUL#=SAWMUL#+2
   Inc SAWN
Until SAWN>8
Return 
'  
_SAWTONE:
Gosub T0NESET
If Errtrap Then Goto NOMEMORY
SAWN=0
SAWMUL#=0.0
Goto SYNTH
'  
_COSTONE:
Gosub T0NESET
If Errtrap Then Goto NOMEMORY
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
N#= Fn T0NE#
Repeat 
   Gosub _COS
   Poke FX,CN
   Inc FX
Until FX>FXE
Return 
'
_TRITONE:
Gosub T0NESET
If Errtrap Then Goto NOMEMORY
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
N#= Fn T0NE#
CN#=127
CN2#=(N#*T0NEA)/2
Repeat 
   CN3#=T0NEA*Cos(N#*(FX-FX_START))
   If CN3#>0
      CN#=CN#+CN2#
   Else If CN3#<0
      CN#=CN#-CN2#
   Else 
      CN#=127
   End If 
   Poke FX,Int(CN#-127)
   Inc FX
Until FX>FXE
Return 
'
_PLSTONE:
Gosub T0NESET
If Errtrap Then Goto NOMEMORY
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
N#= Fn T0NE#
Repeat 
   If Sin(N#*(FX-FX_START))<0 Then CN=-(T0NEA+1) Else CN=T0NEA
   Poke FX,CN
   Inc FX
Until FX>FXE
Return 
'
_WHITENOISE:
Gosub T0NESET
If Errtrap Then Goto NOMEMORY
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
Randomize Timer
Repeat 
   CN=Rnd(255)-127
   Poke FX,CN
   Inc FX
Until FX>FXE
Goto SETUNNAMED
'
_DITHER:
Gosub T0NESET
If Errtrap Then Goto NOMEMORY
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
Randomize Timer
Repeat 
   Gosub DITHER
   Poke FX,CN2
   Inc FX
Until FX>FXE
Goto SETUNNAMED
'
DITHER:
On _DITHER Goto DI,DT,DL
CN2=0 : Return 
DI: CN2=Rnd(2)-1 : Return 
DT: R2=R1 : R1=Rnd(2)-1 : CN2=(R1-R2) : Return 
DL: R2=R1 : R1=Rnd(2)-1 : CN2=(R2+R1)/2 : Return 
'
DITHER24:
If CN>8388607 Then CN=CN-16777216 : Rem SIGN24 
If CN>-1 and CN<8388607
   CN=CN+CN2
Else If CN<0 and CN>-8388608
   CN=CN-CN2
End If 
If CN<0 Then CN=CN+16777216 : Rem UNSIGN24 
Return 

'
_CRYPTONOISE:
AA=0 : BB=0 : CC=0
ISA=$9E3779B9 : ISB=ISA : ISC=ISA : ISD=ISA : ISE=ISA : ISF=ISA : ISG=ISA : ISH=ISA
N=0
T$=_$
_EXIT=False
Gosub _OPENFXTEXTWIN
TXT1$="Passphrase:"
_TEXT=True : _EXIT=False
T$=_$
CRY_X=340 : CRY_Y=Y+72 : TXT_X=0 : N=0 : _MAX=256
Repeat 
   Gosub _TEXTINPUT
   FOFF=Len(T$)-9
   Gosub DRWCRY
   Repeat 
      Gosub GVAL
      If Z=ZN_OK and Fn MOUSEDOWN or Fn KEY_RETURN
         PZN=Z : BX=RX+2 : Gosub PRESS
         If _ON
            REQ=True
            _EXIT=True
         End If 
      Else If Z=ZN_CANCEL and Fn MOUSEDOWN or Fn KEY_ESC
         PZN=Z : BX=RX+108 : Gosub PRESS
         If _ON
            REQ=False
            _EXIT=True
         End If 
      End If 
   Until _EXIT or C
Until _EXIT
Gosub _CLOSEFXWIN
Gosub WINC
If T$=_$ Then REQ=False
If REQ
   Gosub T0NESET
   If Errtrap
      Goto NOMEMORY
   End If 
   Gosub SETPBANK
   If FX_LENGTH<2
      Goto FLSHSCR
   End If 
   Gosub _UNDOSET
   Gosub ISET
   Gosub ISAAC
   ISI=0
   Repeat 
      ISN=RANDRSL(ISI)
      Inc ISI
      If ISI>255
         Gosub ISAAC
         ISI=0
      End If 
      ISN=(ISN mod 255)
      Poke FX,ISN
      Inc FX
   Until FX>FXE
   Gosub SETUNNAMED
End If 
_TEXT=False
Return 
'
DRWCRY:
Ink _BLACK,_WHITE
Text CRY_X,CRY_Y,Space$(9)
If FOFF<0 Then FOFF=0
Text CRY_X-Text Length(TXT1$),CRY_Y,TXT1$+Mid$(T$,FOFF+1,Min(Len(T$)-FOFF,9))
Gr Writing %10
If N-FOFF>0 Then Text CRY_X+((N-FOFF)*8),CRY_Y,_SCORE$+_SPACE$ Else Text CRY_X,CRY_Y,_SCORE$+_SPACE$
Gr Writing %1
Return 
'
ISET:
ISI=0 : ISN=0
Repeat 
   MM(ISI)=0
   If ISN>Len(T$)
      ISN=0
   End If 
   RANDRSL(ISI)=Asc(Mid$(T$,ISN,1))
   Inc ISI : Inc ISN
Until ISI>255
ISI=0
Repeat 
   Gosub IMIX
   Inc ISI
Until ISI>3
ISI=0
Repeat 
   ISA=ISA+RANDRSL(ISI) : ISB=ISB+RANDRSL(ISI+1) : ISC=ISC+RANDRSL(ISI+2) : ISD=ISD+RANDRSL(ISI+3)
   ISE=ISE+RANDRSL(ISI+4) : ISF=ISF+RANDRSL(ISI+5) : ISG=ISG+RANDRSL(ISI+6) : ISH=ISH+RANDRSL(ISI+7)
   Gosub IMIX
   MM(ISI)=ISA : MM(ISI+1)=ISB : MM(ISI+2)=ISC : MM(ISI+3)=ISD
   MM(ISI+4)=ISE : MM(ISI+5)=ISF : MM(ISI+6)=ISG : MM(ISI+7)=ISH
   Add ISI,8
Until ISI>255
Return 
'
ISAAC:
CC=CC+1
BB=BB+CC
IV=0
Repeat 
   XV=MM(IV)
   BIT1=IV : BIT2=3 : Gosub BITWISEAND
   TAA13=AA : TAA6=AA : TAA2=AA : TAA16=AA
   Rol.l 13,TAA13 : Ror.l 6,TAA6 : Rol.l 2,TAA2 : Ror.l 16,TAA16
   If BIT3=0
      AA=AA xor TAA13
   Else If BIT3=1
      AA=AA xor TAA6
   Else If BIT3=2
      AA=AA xor TAA2
   Else If BIT3=3
      AA=AA xor TAA16
   End If 
   BIT3=IV+128 : BIT2=255 : Gosub BITWISEAND
   Trap AA=MM(BIT3)+AA
   If Errtrap
      AA=MM(BIT3)+-AA
   End If 
   Ror.l 2,XV
   BIT3=XV : BIT2=255 : Gosub BITWISEAND
   Trap YV=MM(BIT3)+AA+BB
   If Errtrap
      Trap YV=MM(BIT3)+-AA+BB
      If Errtrap
         YV=MM(BIT3)+-AA+-BB
      End If 
   End If 
   Rol.l 10,YV
   MM(IV)=YV
   BIT3=YV : BIT2=255 : Gosub BITWISEAND
   Trap BB=MM(BIT3)+XV
   If Errtrap
      BB=MM(BIT3)+-XV
   End If 
   RANDRSL(IV)=BB
   Inc IV
Until IV>255
Return 
'
IMIX:
Rol.l 11,ISB
Ror.l 2,ISC
Rol.l 8,ISD
Ror.l 16,ISE
Rol.l 10,ISF
Ror.l 4,ISG
Rol.l 8,ISH
Ror.l 9,ISA
ISA=ISA xor ISB : Add ISD,ISA : Add ISB,ISC
ISB=ISB xor ISC : Add ISE,ISB : Add ISC,ISD
ISC=ISC xor ISD : Add ISF,ISC : Add ISF,ISC
ISD=ISD xor ISE : Add ISG,ISD : Add ISE,ISF
ISE=ISE xor ISE : Add ISH,ISE : Add ISF,ISG
ISF=ISF xor ISG : Add ISA,ISF : Add ISG,ISH
ISG=ISG xor ISH : Add ISB,ISG : Add ISH,ISA
ISH=ISH xor ISA : Add ISC,ISH : Add ISA,ISB
Return 
'
BITWISEAND:
BIT3=0
For I=0 To 31
   B1=Btst(I,BIT1)
   B2=Btst(I,BIT2)
   If B1=True and B2=True Then Bset I,BIT3 Else Bclr I,BIT3
Next I
Return 
'  
_SINNOISE:
Gosub T0NESET
If Errtrap Then Goto NOMEMORY
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
CN=Rnd(_GIGABYTE)+_GIGABYTE
CN#=0
Repeat 
   CN#=Sin(CN*CN#+1)
   CN2=Int(CN#*127)
   Inc CN
   Poke FX,CN2
   Inc FX
Until FX>FXE
Goto SETUNNAMED
'
_FILLNOISE:
Gosub T0NESET
If Errtrap Then Goto NOMEMORY
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
Randomize Timer
Repeat 
   CN=Rnd(255)-127
   CN2=Rnd(BSIZE-1)+1
   If FX+CN2>FXE Then CN2=FXE-FX
   FX2=FX
   S_LENGTH2=FX2+CN2
   Repeat 
      Poke FX2,CN
      Inc FX2
   Until FX2>S_LENGTH2
   FX=FX+CN2
   If FX=>FXE Then Inc FX
Until FX>FXE
Goto SETUNNAMED
'
_TGLRECORD:
If _REC
   _REC=False
   Close 2
   If _MODE>1
      Close 3
      If _MODE>2
         Close 4 : Close 5
      End If 
      If _CH>4
         SBCOUNT=6
         Repeat 
            Close SBCOUNT
            Inc SBCOUNT
         Until SBCOUNT>_CH+1
      End If 
   End If 
   _RECORD$="Record        "
   Colour _HIGHLIGHT,_COLP
Else 
   If Length(PBANK)=0
      Goto FLSHSCR
   End If 
   PF$=F$
   If Fn STEREO
      WTXT$="as Stereo"
   Else If Fn QUAD
      WTXT$="as Quad"
   Else If Fn MULTI
      WTXT$="as Multi Track"
   Else 
      WTXT$=_$
   End If 
   WTXT$="Record "+WTXT$+": raw"
   Gosub FREQUEST
   S$=F$
   If Not FRQ
      Return 
   End If 
   If Exist(F$)
      Gosub OVERWRITE
      If Not REQ
         Return 
      End If 
   End If 
   If Fn MONO
      Open Out 2,F$ : Gosub SETFILEPOS
   Else If Fn STEREO
      F$=S$+"-L" : Gosub SETFILEPOS
      Open Out 2,F$
      F$=S$+"-R" : Gosub SETFILEPOS
      Open Out 3,F$
   Else If Fn QUAD
      F$=S$+"-L1" : Gosub SETFILEPOS
      Open Out 2,F$
      F$=S$+"-R1" : Gosub SETFILEPOS
      Open Out 3,F$
      F$=S$+"-R2" : Gosub SETFILEPOS
      Open Out 4,F$
      F$=S$+"-L2" : Gosub SETFILEPOS
      Open Out 5,F$
   Else 
      SBCOUNT=2 : SB=1
      Repeat 
         F$=S$+"-"+Str$(SB)-_SPACE$ : Gosub SETFILEPOS
         Open Out SBCOUNT,F$
         Inc SBCOUNT : Inc SB
      Until SB>Min(8,_CH) : Rem amos limited to 10 open files  
   End If 
   F$=PF$
   _RECORD$="Stop Record   "
   _REC=True
   _COLP=Colour(_HIGHLIGHT)
   Colour _HIGHLIGHT,$F00
End If 
RECTOTAL=-1
Return 
'
REC:
If RECTOTAL=-1
   Inc RECTOTAL
   Return 
End If 
BBUFF=0 : SBCOUNT=1
If Fn MONO
   SB=1
Else If Fn STEREO
   SB=2
Else If Fn QUAD
   SB=4
Else 
   SB=_CH
End If 
Repeat 
   Ssave SBCOUNT+1,P_BUF+BBUFF To P_BUF+BBUFF+BSIZE
   BBUFF=BBUFF+BSIZE
   Inc SBCOUNT
Until SBCOUNT>SB
DRWREC:
RECTOTAL=RECTOTAL+BSIZE
If TGL
   If Not RENDERING
      Gosub GFXSET
      Ink _HIGHLIGHT,_PANE
      T_LENGTH=RECTOTAL
      Gosub TIME_ALL
      T$=Str$(DIV#)-_SPACE$+T$
      If Len(T$)<16
         T$=Space$(5)+T$
      Else If Len(T$)<22
         T$=_SPACE$+T$
      End If 
      Text 600-Text Length(T$),WVE_H+24+16,T$
      Gosub GFXRESTORE
   End If 
End If 
Return 
'
_NORMALPIANO:
PIANO=False
_POLY=False
REQ=True
Goto _DRAWALL
'
_POLYPHONICPIANO:
PIANO=True
_POLY=True
REQ=True
Goto HIGHPIANO
'
_SINGLEPIANO:
PIANO=True
_POLY=False
REQ=True
HIGHPIANO:
If PIANO
   Ink _HIGHLIGHT
   Bar 0,HDR_H+2 To 3,WVE_H+HDR_H-2
   Bar 0,HDR_H To SCR_W-1,HDR_H+1
   Bar SCR_W-4,HDR_H+2 To SCR_W-1,WVE_H+HDR_H-2
   Bar 0,WVE_H+HDR_H-1 To SCR_W-1,WVE_H+HDR_H
End If 
Return 
'
_OPENASSEQUENCE:
PF$=F$ : F$=_$
WTXT$="Open As: sequence"
PPROGDIR$=Dir$
If Dir$<>SEQDIR$ and Exist(SEQDIR$)
   Dir$=SEQDIR$
   Gosub RSTFILES
End If 
Gosub FREQUEST
If Not FRQ
   Dir$=PPROGDIR$
   Gosub RSTFILES
   Return 
End If 
SEQDIR$=Dir$
If Dir$<>PROGDIR$
   Dir$=PPROGDIR$
   Gosub RSTFILES
End If 
If Not Exist(SEQDIR$+F$)
   Gosub CANTFIND
   F$=PF$
   Return 
End If 
_TEXT=True
T$="SEQ "+F$
MACRO=True : Gosub CMD : MACRO=False
F$=PF$
_TEXT=False
Return 
