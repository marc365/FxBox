'
'
'***************************************************************************** 
'*direct********************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'   ::::::-.   :::  :::::::..  .,::::::  .,-:::::::::::::::: 
'   ;;,   `';, ;;;  ;;;;``;;;; ;;;;'''',;;;'````' ;;;;;;;''' 
'   `[[     [[ [[[  \[[[,/[[['  [[cccc [[[            [[ 
'    $$,    $$ $$$, "$$$$$$c    $$"""" $$$            $$ 
'    888_,o8P'o88888,888b "88bo 888oo,_`88bo,__,o,    88,
'   "MMMMP"`  MMM"MM"MMMM   "W" """"YUM  "YUMMMMMP    MMM
'
'
'
NEWCLI:
Inc _DIRECT : _TEXT=True
Gosub NUDGEPOS
RENDERING=True
Gosub CLISHW
ŻLOOP:
T$=Str$(_DIRECT)-_SPACE$ : TXT_X=0 : N=0
Print T$+"."+Dir$;"> ";_SCORE$;
_LOC=Len(Dir$)+Len(T$)+1
If _LOC>80
   Add _LOC,-80
End If 
_MAX=156-_LOC
T$=_$
Repeat 
   Gosub GVAL
   If Fn KEY_PRESS
      If Fn KEY_UP and S=0
         T$=_REPEAT$
         N=Len(_REPEAT$)
      Else 
         Gosub _TEXTINPUT
      End If 
      If( Fn KEY_LEFTAMIGA and Fn KEY_D) or Fn KEY_ESC
         Goto CLIEND
      End If 
      S$="> "+T$
      Locate _LOC,
      If _NEXTLINE
         Cup 
      Else If Fn KEY_BACKSPACE
         If Len(S$)+_LOC=79
            Cup 
         End If 
      Else 
         If Len(S$)>80-_LOC
            If Fn KEY_UP
               Print Left$(S$,80);
            End If 
            Locate 0,
            S$=Mid$(S$,(80-_LOC)+1)
         End If 
         Print S$;
      End If 
      _NEXTLINE=False
      If _LOC=Len(S$)>80
         Add _LOC,-80
      End If 
      If Fn KEY_BACKSPACE or Fn KEY_DEL
         If _LOC+Len(S$)<80
            Locate _LOC+Len(S$),
            If _LOC+Len(S$)<78
               Print _SPACER$;
            Else If _LOC+Len(S$)=78
               Print _SPACER$;
               Cup 
            Else If _LOC+Len(S$)=79
               Print _SPACE$;
               Locate 0, : Print _SPACE$ : Cup 
               Cup 
            End If 
         Else If _LOC+Len(S$)=80
            Locate 0,
            Print "_ ";
         Else If _LOC+Len(S$)>80
            Locate(Len(S$)-80)+_LOC,
            Print "_ ";
         End If 
      End If 
      If N=Len(T$)-1
         Print _SPACE$;
      End If 
      If Not _NEXTLINE
         If Not Fn KEY_ESC
            Writing 2,2
            If _LOC+N+2<80
               Locate _LOC+N+2, : Print _SCORE$;
               If _LOC+N+2=79
                  Cup 
               End If 
            Else If _LOC+N=80 and C-65 : Rem backspace
               Print _SCORE$;
            Else If _LOC+N+2>80
               Locate _LOC+N+2-80,
               If C-65 and C-70 : Rem backspace del
                  Print _SCORE$;
               End If 
            End If 
            Writing 0,0
         Else 
            Print _SPACE$
         End If 
      End If 
   End If 
Until Fn KEY_RETURN
Print 
S$=T$
T$=Upper$(T$)
_REPEAT$=T$
CMD:
Trap If Upper$(S$)<>T$ Then S$=T$
If Errtrap Then Goto NOSPACEERROR
DCN=0
Repeat 
   CMDL=Len(CMD$(DCN))
   If Left$(T$,CMDL)=CMD$(DCN)
      Inc CMDL
      If Peek(Varptr(T$)+CMDL-1)=CHR_SPACE
         Inc CMDL
      End If 
      T$=Mid$(S$,CMDL)
      Gosub CMDG$(DCN)
      CMDL=True
      Exit 
   End If 
   Inc DCN
Until DCN>_CM
If Not CMDL
   If MACRO
      G$=T$
      Trap Gosub G$
      T$=G$
      If Errtrap
         Gosub MACROERROR
      Else 
         Gosub CHECKFX
         If Not MENFX
            T$=Left$(G$,Len(G$)-1)
            Gosub CHECKFX
         End If 
         If MENFX
            MENFX=False
            If RL>1
               Gosub STEREOQUAD
            End If 
         End If 
      End If 
      Return 
   Else 
      _REPEAT$=T$
      Gosub MACROSET
      Trap Gosub T$
      If Errtrap
         Gosub MACRORESTORE
         If T$<>_$
            Print "Unknown command|subroutine: ";T$
         End If 
      Else 
         If _REPEAT$="_INIT"
            Goto CLIEND
         End If 
         Gosub CHECKFX
         If Not MENFX
            T$=Left$(T$,Len(T$)-1)
            Gosub CHECKFX
         End If 
         If MENFX
            MENFX=False
            G$=T$
            If RL>1
               Gosub STEREOQUAD
            End If 
            'from MCHOOSE
            Gosub CLRPOS
            RENDERING=True
            Gosub _DRAW
            Gosub FRSHSEL
            Gosub HEADER
         End If 
         Gosub MACRORESTORE
         If _TOAST$<>_$
            Print _TOAST$
            _TOAST$=_$
         End If 
      End If 
   End If 
End If 
If Not MACRO
   If Not _REPEATING
      Goto ŻLOOP
   End If 
End If 
Return 
'
INITCLI:
Inc _DIRECT : _TEXT=True
Gosub NUDGEPOS
RENDERING=True
Gosub CLISHW
Goto CMD
'
CLISHW:
Gosub R4INBOW
Trap Screen Show 2
If Errtrap
   Screen Open 2,SCR_W,CLI_H,2,Hires
   Palette $0,$DDD,,,,,,,,,,,,,,,,$444,$500,$111
   Flash Off : Curs Off 
Else 
   Screen 2 : Screen To Front 2
   Gosub ŻCLS
End If 
I#=-90 : DD#=1.5
Repeat 
   Screen Display 2,128,Int(I#),320,CLI_H
   Gosub GTASK
   I#=I#+DD#
   DD#=DD#+3.25
Until I#>CLI_Y
CLISCR:
Screen Display 2,128,CLI_Y,320,CLI_H
Return 
'
CLIMVE:
If Fn MOUSEDOWN and((CY>0 and CY<HDR_H) or _DIRECTMOVE)
   CLI_Y=Y Mouse-5
   _DIRECTMOVE=True
   Goto CLISCR
Else 
   _DIRECTMOVE=False
End If 
Return 
'
PAGECLI:
Inc NN
If NN=15
   NN=1
   Print "[press SPACE to continue - ESC to cancel]";
   Repeat 
      Gosub GVAL
   Until Fn KEY_ESC or Fn KEY_SPACE
   Locate 0, : Print Space$(41); : Locate 0,
End If 
Return 
'
ŻEXIT:
Pop 
CLIEND:
I#=CLI_Y
Repeat 
   Screen Display 2,128,Int(I#),320,CLI_H
   Gosub GTASK
   I#=I#-DD#
Until I#<-90
Screen Hide 2 : Screen 0
If Fn MULTI Then Gosub R4INSET
Dec _DIRECT
If _DIRECT>0 Then Goto CLISHW
RENDERING=False : _TEXT=False : REQ=False
Goto CLRPOS
'
ŻBANK:
B=Val(T$)
If B>_FL Then B=_FL
Gosub MACROSET
Gosub SETBANK
Goto MACRORESTORE
'
ŻSWAP:
N=Val(T$)
If B=N Then Return 
If N>_FL Then N=_FL
Gosub MACROSET
Bank Swap PBANK,N+7
Swap FB$(B),FB$(N)
Swap FPATH$(B),FPATH$(N)
If Fn MULTI
   If Fn INVIEW
      If N<=_CH
         Swap D_LENGTH(B),D_LENGTH(N)
         Swap OFFSET(B),OFFSET(N)
      Else 
         D_LENGTH(B)=Length(PBANK)
      End If 
   Else If N<=_CH
      D_LENGTH(N)=Length(N+7)
   End If 
End If 
If B<11
   F$=Right$(MENB$(B),8)
   If N<11
      Right$(MENB$(B),8)=Right$(MENB$(N),8)
   Else 
      Right$(MENB$(B),7)=Left$(FB$(B),7)
   End If 
Else 
   F$=Space$(8)
   Right$(F$,7)=Left$(FB$(N),7)
End If 
If N<11
   Right$(MENB$(N),8)=F$
End If 
Swap NAME$(B),NAME$(N)
Swap CPYR$(B),CPYR$(N)
Swap AUTH$(B),AUTH$(N)
Swap TXT$(B),TXT$(N)
Swap ANNO$(B),ANNO$(N)
Swap COMP(B),COMP(N)
F$=FB$(B)
Gosub POSCAL
Gosub MAGICWAND
Gosub SETSELV
Gosub SETCORDS
If RENDERING=False and SETTING$(27)<>_FALSE$ : Rem always draw
   Gosub CLRPOS
   RENDERING=True
   Gosub _DRAW
   Gosub HEADER
   RENDERING=False
End If 
Goto MACRORESTORE
'
ŻMODE:
_MODEP=Val(T$)
Gosub MACROSET
_M3SEL=_MODEP
Gosub M0DEMENU
Goto MACRORESTORE
'
ŻDIV:
Gosub MACROSET
Gosub TIMEDIV
Goto MACRORESTORE
'
ŻRNG:
R=Val(T$)
If R<1 or R>Int(_TIMEDIV#) Then Goto FLSHSCR
Gosub MACROSET
RL=Int(P_LENGTH/_TIMEDIV#) : RST=(R*(P_LENGTH/_TIMEDIV#))-RL : RFIN=P_LENGTH-RST-RL
Gosub SETCORDS
Gosub _SHOWCOPY
Gosub SETZN
Gosub HEADERCORDS
Goto MACRORESTORE
'
ŻFREQ:
TVAL=Val(T$)
If TVAL>500 and TVAL<=MFREQ : Rem +music.s SAM RAW cmp.l #500,d3 Rble L_IFonc
   Gosub MACROSET
   FREQ=TVAL
   _AMIHZ=False
   RENDERING=False
   Gosub SETHZ : Rem round to CLOCK 
   Ink _PANE : Gosub AMIHZDIAL : _HIGHDIAL=False
   Gosub DIALMAIN
   FREQ=TVAL : Gosub DRWTIME : Rem redisplay actual chosen frequency  
   RENDERING=True
   Gosub MACRORESTORE
End If 
Return 
'  
ŻNOTE:
If Fn MULTIINVIEW
   I=B
Else 
   I=1
End If 
OFFSET= Fn CHUNKY(OFFSET(I))
If OFFSET>=P_LENGTH
   OFFSET=0
End If 
If Val(T$)<>0
   FINE$=Str$(_FINETUNE)-_SPACE$-_MINUS$
   If _FINETUNE<0
      FINE$="_"+FINE$
   End If 
   Restore "PER"+FINE$
   I=Val(T$)
   Repeat 
      Read KEYF
      Dec I
   Until I<0
   KEYF=CLOCK/KEYF
   _FINETUNE=0
Else 
   Restore KAL
   Repeat 
      Read KEYC,KEYS$,KEYF
      If KEYS$=T$
         Return 
      End If 
   Until KEYC=-1
End If 
Return 
'
ŻFINE: Rem finetune 
_FINETUNE=Val(T$)
If _FINETUNE>7
   _FINETUNE=7
Else If _FINETUNE<-8
   _FINETUNE=-8
End If 
Return 
'
ŻVOL:
TVAL=Val(T$)
If TVAL<0 or TVAL>64 Then Goto ŻBADARGS
VOL=TVAL : ROT#(1)=(VOL/13.3334)+8.5
Gosub MACROSET
Gosub SETVOL
Goto MACRORESTORE
'
ŻSIZE:
S_LENGTH=Val(T$)
Gosub MACROSET
If S_LENGTH=0
   Gosub _NEW
   Goto MACRORESTORE
End If 
If Fn STEREO
   FX_LENGTH=S_LENGTH*2
   CCOUNTN=1
Else If Fn QUAD
   FX_LENGTH=S_LENGTH*4
   CCOUNTN=3
Else 
   FX_LENGTH=S_LENGTH
   CCOUNTN=0
End If 
Trap Reserve As Work WBANK,FX_LENGTH
If Errtrap
   Gosub NOMEMORY
   Goto MACRORESTORE
End If 
If Length(PBANK)>0
   CCOUNT=0
   Repeat 
      If S_LENGTH>P_LENGTH
         Copy Start(PBANK)+(P_LENGTH*CCOUNT),Start(PBANK)+(P_LENGTH*CCOUNT)+P_LENGTH To Start(WBANK)+(S_LENGTH*CCOUNT)
      Else 
         Copy Start(PBANK)+(P_LENGTH*CCOUNT),Start(PBANK)+(P_LENGTH*CCOUNT)+S_LENGTH To Start(WBANK)+(S_LENGTH*CCOUNT)
      End If 
      Inc CCOUNT
   Until CCOUNT>CCOUNTN
Else 
   Gosub SETUNNAMED
End If 
S_LENGTH=Length(PBANK)
Gosub _WORKSWAP
If S_LENGTH>Length(PBANK) Then Gosub _RANGENONE
Gosub _RESIZED
Goto MACRORESTORE
'
ŻNAME: NAME$(B)=T$ : Return 
ŻCPYR: CPYR$(B)=T$ : Return 
ŻAUTH: AUTH$(B)=T$ : Return 
ŻTXT: TXT$(B)=T$ : Return 
ŻANNO: ANNO$(B)=T$ : Return 
'
ŻWAND:
XD2=Val(T$)
XD=XD2-(640/_TIMEDIV#)
If XD<0 Then XD=0
Goto WAND
ŻZOOML:
XD=Val(T$)
Goto WAND
ŻZOOMR:
XD2=Val(T$)
WAND:
Gosub MACROSET
Gosub MAGICWAND
If SETTING$(27)<>_FALSE$ : Rem always draw
   If RENDERING=False and _MENUDO=False and OSCILLO=False
      Gosub WREFRSH
   End If 
End If 
Goto MACRORESTORE
'
ŻCDDD:
T$="/"
ŻCD:
If T$=_$
   Print Dir$
Else If Exist(T$)
   Dir$=T$
   Gosub RSTFILES
Else 
   Goto ŻCANTFIND
End If 
Return 
'
ŻMD:
If T$=_$
   Gosub ŻBADARGS
Else If Exist(T$)
   Print T$;" exists"
Else 
   Mkdir T$
End If 
Return 
'
ŻDIR:
If T$=_$
   Goto ŻD
Else If Exist(T$)
   PPROGDIR$=Dir$
   Trap Dir$=T$
   If Errtrap
      Goto ŻCANTFIND
   End If 
   Gosub ŻD
   Dir$=PPROGDIR$
Else 
   Goto ŻCANTFIND
End If 
Return 
'
ŻD:
Gosub SETFILENAMELENGTH
D$=Dir First$(_$)
NN=1
Repeat 
   Print Left$(D$,30)
   D$=Dir Next$
   Gosub PAGECLI
Until D$=_$ or Fn KEY_ESC
Return 
'
ŻDEL:
If T$=_$
   Goto ŻBADARGS
Else If Exist(T$)
   Kill T$
Else 
   Goto ŻCANTFIND
End If 
Return 
'
ŻCLS:
Cls 
Return 
'
ŻED:
If T$=_$
   Goto ŻBADARGS
Else 
   Gosub _STOP
   Amos To Back 
   Exec 'ed "'+Dir$+T$-'"'+'"'
   Amos To Front 
End If 
Return 
'
ŻOPEN:
If T$=_$ Then Goto ŻBADARGS
Gosub MACROSET
If Instr(T$,_COLON$)=0 and Instr(T$,"/")>0
   F$=PROGDIR$+T$
Else 
   F$=T$
End If 
_APPEND=B-1
Gosub _OPENF
Goto MACRORESTORE
'
ŻMACRO:
If T$=_$ Then Goto ŻBADARGS
Gosub MACROSET
S$=T$
Gosub MACROP
Goto MACRORESTORE
'
ŻSEQ:
If T$=_$
   If _DIRECT=0
      _TOAST$=Str$(Len(SEQ$))-_SPACE$+_BYTE$
   Else 
      I=0
      NN=1
      Repeat 
         N=I
         Inc N
         I=Instr(SEQ$,_NEWLINE$,N)
         Print _SPACE$+Mid$(SEQ$,N,I-N)
         Gosub PAGECLI
      Until I=0 or Fn KEY_ESC
   End If 
Else If T$=SEQF$
   SEQ$=SEQP$
   If _DIRECT=0
      _TOAST$=T$
   Else 
      Print T$
   End If 
Else If Exist(SEQDIR$+T$)
   Gosub MACROSET
   Trap Open In 1,SEQDIR$+T$
   If Errtrap
      F$=T$ : Gosub FILEERROR
   Else 
      N=Lof(1)
      If N> Fn BUFFER
         Gosub NOSPACE
      Else 
         SEQP$=Space$(N)
         Sload 1 To Varptr(SEQP$),N
         If Instr(SEQP$,_COMMA$+_NEWLINE$)=False
            TXT1$="Not a" : TXT2$="sequence"
            If _DIRECT=0
               Gosub _NOTICE
            Else 
               Print TXT1$;_SPACE$;TXT2$
            End If 
         Else 
            SEQF$=T$
            SEQ$=SEQP$
            If _DIRECT=0
               _TOAST$=T$
            End If 
         End If 
      End If 
   End If 
   Close 1
   Gosub MACRORESTORE
Else 
   Gosub ŻCANTFIND
End If 
Return 
'
ŻRX:
If Not REXX
   Print "Arexx: ";_NOTACTIVE$
Else If T$=_$
   Goto ŻBADARGS
Else If Exist(RXDIR$)
   Gosub MACROSET
   Exec "run "+RXDIR$+_SPACE$+T$
   Gosub SPIN
   Gosub MACRORESTORE
Else 
   T$=RXDIR$
   Gosub ŻCANTFIND
End If 
Return 
'
ŻHELP:
Restore HLP
H:
Read N
I=1 : NN=1
Repeat 
   Read T$
   Print _SPACER$;T$
   Inc I
   Gosub PAGECLI
Until I>N or Fn KEY_ESC
Return 
'
ŻHELPCUT:
If _DIRECT=0
   T$="HELP CUT"
   Goto INITCLI
End If 
Restore CUT
Goto H
'  
ŻHELPSUB:
If _DIRECT=0
   T$="HELP SUB"
   Goto INITCLI
End If 
Print 
TXT1$=_$
M1=1 : NN=1
Repeat 
   M2=1
   Repeat 
      Restore 0+Val(Str$(M1)+Str$(M2))
      Read S$
      If Instr(S$,_»$)
         M3=1
         Repeat 
            Restore 0+Val(Str$(M1)+Str$(M2)+Str$(M3))
            Read S$
            If Peek(Varptr(S$)+2)<>CHR_MINUS and S$<>_NULL$
               Gosub DRWSUB
            End If 
            Inc M3
         Until S$=_NULL$
         S$=_$
      Else If Peek(Varptr(S$)+2)<>CHR_MINUS and S$<>_NULL$
         Gosub DRWSUB
      End If 
      Inc M2
   Until S$=_NULL$ or(M1=3 and M2=11) : Rem menu collision   
   Inc M1
Until M1>_M1
Print "_RANGESET_RANGERESTORE_TGLDITHER_TGLINTERPOLATE_TGLLOOP_TGLMIXLOOP"
Print "_TGLOSCILLOSCOPE_PLAY_PLAYRANGE_PLAYDISPLAY_REWIND_STOP_NDPQ_NOP"
Print 
Return 
'
DRWSUB:
Read MENFX,G$
If Left$(G$,1)=_SCORE$
   If Len(TXT1$)+Len(G$)>79
      Gosub PAGECLI
      Print TXT1$
      TXT1$=G$
   Else 
      TXT1$=TXT1$+G$
   End If 
End If 
Return 
'
ŻHELPCOM:
If _DIRECT=0
   T$="HELP COM"
   Goto INITCLI
End If 
Restore COM
Goto H
'
ŻHELPOPT:
If _DIRECT=0
   T$="HELP OPT"
   Goto INITCLI
End If 
Restore OPT
Goto H
'
ŻHELPDITHER:
If _DIRECT=0
   T$="HELP DITHER"
   Goto INITCLI
End If 
Restore D24
Goto H
'
ŻSKIN:
If T$=_$ Then Goto ŻBADARGS
Gosub MACROSET
Load Iff T$
Gosub MCOL
Goto MACRORESTORE
'
ŻCANTFIND:
If SEQUENCER
   SETTING$(24)=_FALSE$ : Rem scroller 
   _TOAST$="Can'"+'t Find "'+T$+'"'
Else If MACRO
   F$=T$
   Goto CANTFIND
Else 
   Print "Can'";'t Find "';T$;'"'
End If 
Return 
'
ŻBADARGS:
Print "Bad Args"
Return 
