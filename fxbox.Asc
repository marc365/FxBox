Data "MACRO <name>        Run Macro"
Data "SEQ <filename>      Load Sequence"
Data "SKIN <filename>     Load Iff Skin"
Data ,"Iff Meta:"
Data "NAME=... (c)=... AUTH=... TEXT=... ANNO=..."
Data ,"DOS:"
Data "CD, MD, DIR, DEL, ED, CLS"
Data ,'Arexx: RX "address '+FXBOX_REXX$+' <subroutine|command>"',
'
OPT:
Data 23,,"Filter: toggle the hardware low pass filter"
Data "50Hz: toggle 60Hz for the playback calculations"
Data "Light Mode: toggle dark mode palette"
Data "Debug: toast underruns and other debug messages"
Data "Net Sync: toggle network bpm synchronization"
Data "Hires: toggle lowres"
Data "Position: show the play position marker"
Data "Level Meter: show the level meter"
Data "Metronome: show the metronome"
Data "Realtime: preview the effects in realtime"
Data "Zoom Draw: draw the graph while using zoom, or wait until mouse is released"
Data "Graph: toggle low graph for a faster waveform update"
Data "Wheel Zoom: use the mouse wheel for zooming"
Data "Arexx Sync: toggle octamed arexx play trigger"
Data "Scroller: scroll the toast messages, can also click the scroller"
Data "VST: send the audio to the network VST host"
Data "Quantizer: schedule actions on the sequencer, delaying the trigger"
Data "Always Draw: always draw the waveform when swapping and editing"
Data "-0.2Hz: experimental for slightly undercutting the frame rate"
Data "Dither: cycle through the dither options"
Data "Interpolation: cycle through the interpolation options",
'
