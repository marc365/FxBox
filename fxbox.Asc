'
'*****************************************************************************   
'*macros********************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    .        :    :::.       .,-:::::::::::::..      ...      .::::::.
'    ;;,.    ;;;   ;;`;;    ,;;;'````' ;;;;``;;;;  .;;;;;;;.  ;;;`    `; 
'    [[[[, ,[[[[, ,[[ '[[,  [[[        \[[[,/[[[' ,[[     \[[,'[==/[[[[, 
'    $$$$$$$$"$$$c$$$cc$$$c $$$        "$$$$$$c   $$$,     $$$  '''    $ 
'   888 Y88" 888o 888   888,`88bo,__,o,,888b "88bo"888,_ _,88P,88b    dP 
'   MM  M'  "MMMM YMM   ""`   "YUMMMMMP"MMMM   "W"  "YMMMMMP"   "YMmMY"
'
'
'
CHECKFX:
C1=1
Repeat 
   C2=1
   Repeat 
      Restore 0+Val(Str$(C1)+Str$(C2))
      Read X$
      If Instr(X$,_»$)
         C3=1
         Repeat 
            Restore 0+Val(Str$(C1)+Str$(C2)+Str$(C3))
            Read X$
            If Peek(Varptr(X$)+2)<>CHR_MINUS and X$<>_NULL$
               Read MENFX,C$
               If C$=T$
                  Return 
               End If 
            End If 
            Inc C3
         Until X$=_NULL$
         X$=_$
      Else If Peek(Varptr(X$)+2)<>CHR_MINUS and X$<>_NULL$
         Read MENFX,C$
         If C$=T$
            Return 
         End If 
      End If 
      Inc C2
   Until X$=_NULL$
   Inc C1
Until C1>_M1
MENFX=False
Return 
'
MACROSET:
If MACRO or _DIRECT=0 Then Return 
Screen Hide 2 : Screen 0
Return 
'
MACRORESTORE:
If MACRO or _DIRECT=0 Then Return 
Screen Show 2 : Screen 2
Return 
'
MACRO:
S$=FMACRO$(_M2SEL-1+MOFF)
MACROP:
_TOAST$=S$ : Gosub T0AST
D$=MACRODIR$+S$+".asc"
If Not Exist(D$)
   T$=D$ : Goto MACROERROR
End If 
Gosub _UNDOSET
MACRO=True : _TEXT=True
_MODEP=_MODE
Trap Open In 1,D$
If Errtrap
   F$=D$ : Goto FILEERROR
End If 
If Not _REPEATING
   If Instr(_REPEAT$,S$)=False and MI=-1
      _REPEAT$=_REPEAT$+_SPACE$+S$
   End If 
End If 
I=Lof(1)
If I> Fn BUFFER Then Goto NOSPACE
Inc MI
MN(MI)=I
MACROT$(MI)=Space$(MN(MI))
Sload 1 To Varptr(MACROT$(MI)),MN(MI) : Close 1 : MP(MI)=1
Gosub _COPYCOPY
Repeat 
   MA(MI)=Instr(MACROT$(MI),_NEWLINE$,MP(MI))
   If MA(MI)
      T$=Mid$(MACROT$(MI),MP(MI),MA(MI)-MP(MI))
      _TOAST$=T$
      T$=Upper$(T$)
      Gosub CMD
      Gosub T0AST
   End If 
   MP(MI)=MA(MI)+1
   Gosub GVAL
Until Fn KEY_ESC or MA(MI)=False or MP(MI)>=MN(MI)
_MODE=_MODEP
Dec MI
If MI=-1
   Gosub _CLEARCOPY
   Gosub _COPYCOPY
   If Not _REPEATING
      MACRO=False
   End If 
   If _CHOICE=3
      RL=0 : XR=0 : XR2=0
      _CHOICE=False
      Gosub POSCAL
      Gosub HEADERCORDS
   End If 
   _TEXT=False
End If 
Return 
'
_MACROMENU:
MOFF=0
If Exist(MACRODIR$)
   PPROGDIR$=Dir$
   Dir$=MACRODIR$
   MACRODIR$=Dir$
   D$=Dir First$(_$)
   TCOUNT=1
   If D$<>_$
      Repeat 
         I=Len(D$)-9
         Repeat 
            Exit If Mid$(D$,I,1)<>_SPACE$
            Dec I
         Until I<0
         D$=Upper$(Mid$(D$,2,1))+Mid$(D$,3,I-6)
         FMACRO$(TCOUNT)=D$
         Inc TCOUNT
         D$=Dir Next$
      Until D$=_$ or TCOUNT>_MR : Rem max macros 
      _MRC=TCOUNT
   End If 
   TCOUNT=0
   Dir$=PPROGDIR$
End If 
M:
I=0
Repeat 
   MENM$(I)=Space$(17)
   Mid$(MENM$(I),1)=FMACRO$(I+MOFF)
   Inc I
Until I>18
Return 
'
MACRODOWN:
Inc MOFF
If MOFF>_MRC-19
   MOFF=_MRC-19
   Return 
End If 
Goto M
'
MACROUP:
Dec MOFF
If MOFF<0
   MOFF=0
   Return 
End If 
Goto M
'  
'
'
'***************************************************************************** 
'*sys************************************************************************* 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    .::::::. -:.     ::-.: .::::::. 
'   ;;;`    `;';;.   ;;;;'';;;`    `;
'   '[==/[[[[,   '[[,[[['  '[==/[[[[,
'     '''    $     c$$"      '''    $
'   ,88b    dP   ,8P"`     ,88b    dP
'     "YMmMY"   mM"          "YMmMY" 
'
'
'
'
KEY:
K$=Inkey$
C=Scancode
Return 
'
GVAL:
Gosub TASK
Gosub MKEY
S=Key Shift
Gosub KEY
'If C=95 : Rem page down / help                                                    
'   TXT1$="Screen saved to" : TXT2$="RAM:screen_"+Str$(_GRAB)-_SPACE$+".iff" : 
'   Save Iff TXT2$ 
'   Inc _GRAB
'   If _DIRECT 
'      Cleft : Print _SPACE$ : Print TXT1$;_SPACE$;TXT2$ 
'      Pop : Goto ŻLOOP
'   Else 
'      Gosub _NOTICE 
'   End If 
'End If  
Gosub MPOS
Z=Zone(CX,CY)
If SCR_R=Lowres Then Screen Offset 0,X Mouse-128,
If _DIRECT>0 Then Gosub CLIMVE
If _TOAST$<>_$ Then Gosub T0AST
Return 
'
MATH:
If Not MATH
   TXT1$="mathtrans.library"
   Trap Lib Open 1,TXT1$,0
   If Errtrap
      TXT2$=_NOTAVAILABLE$ : Goto _ERROR
   Else 
      MATH=True
   End If 
End If 
Return 
'  
BSD:
TXT1$="bsdsocket.library"
Trap Lib Open 2,TXT1$,0
If Errtrap
   If _INIT and Not ABOUT
      TXT2$=_NOTAVAILABLE$ : Gosub _ERROR
      SETTING$(NN)=_FALSE$ : Rem net sync / vst 
      Pop : Pop : Goto _OPTIONS
   End If 
Else 
   BSD=True
End If 
Return 
'
SIGN3:
If CN3>127 Then CN3=CN3-256
SIGN2:
If CN2>127 Then CN2=CN2-256
SIGN:
If CN>127 Then CN=CN-256
Return 
'
UNSIGN2:
If CN2<0 Then CN2=CN2+256
UNSIGN:
Gosub CHECKCLIP
If CN<0 Then CN=CN+256
Return 
'
FLOAT2:
If CN2>127 Then CN2=CN2-256
If CN2<0 Then CN#=128 Else CN#=127
CN2#=CN2/CN#
FLOAT:
If CN>127 Then CN=CN-256
If CN<0 Then CN#=128 Else CN#=127
CN#=CN/CN#
Return 
'
UNFLOAT:
If CN#<0 Then CN=128 Else CN=127
CN=Int(CN#*CN)
Gosub CHECKCLIP
If CN<0 Then CN=CN+256
Return 
'
FLOATCLIP:
If CN#>1
   CN#=1
Else If CN#<-1
   CN#=-1
End If 
Return 
'
CHECKCLIP:
If CN>127
   CN=127
Else If CN<-128
   CN=-128
End If 
Return 
'  
UNCHECKCLIP:
If CN>255
   CN=255
Else If CN<0
   CN=0
End If 
Return 
'
FLSHSCR:
_PANEC=Colour(_PANE)
Colour _PANE,Colour(_HIGHLIGHT)
Gosub FLSHR4IN
If BGPLYING
   _TOASTWAIT=1
   Return 
End If 
Gosub TASK : Gosub TASK
Goto FLSHSCRC
'
FLSHSCRC:
Colour _PANE,_PANEC
If Fn MULTI Then Goto R4INSET
Goto R4INRESTORE
'
GFXSET:
GFXX=Xgr : GFXY=Ygr
Return 
'
GFXRESTORE:
Gr Locate GFXX,GFXY
Return 
'
STATESET:
_FX_START=FX_START : _FX_LENGTH2=FX_LENGTH2
_FX=FX : _FXE=FXE
_CN=CN
Return 
'
STATERESTORE:
FX_START=_FX_START : FX_LENGTH2=_FX_LENGTH2
FX=_FX : FXE=_FXE
CN=_CN
Return 
'
MEMORY:
Trap MEMORY=Fast Free+Chip Free
If Errtrap or MEMORY<0
   MEMORY=Fast Free
End If 
Return 
'
TASK:
If Not BGPLYING Then Multi Wait 
Return 
'  
GTASK:
If Not BGPLYING
   Multi Wait 
Else If PLYING
   PTGL=TGL
   Repeat 
   Until TGL<>PTGL
   PTGL=TGL
   Repeat 
   Until TGL<>PTGL
End If 
Return 
'
SPIN:
_SPIN=Timer+4 : Repeat : Gosub DISPATCH : Until Timer>_SPIN
Return 
'
TIME_ALL:
If T_LENGTH>0
   DIV#=FREQ
   DIV#=((DIV#/T_LENGTH)*60)*4
   If DIV#<32
      DIV#=FREQ
      DIV#=T_LENGTH/DIV#
      T$=" Secs"
      If DIV#>60
         ADV#=DIV#
         DIV#=DIV#/60
         DIV#=Int(DIV#)
         T$=" Mins"+Str$(Int(ADV#-(DIV#*60)))+T$
      End If 
      If DIV#>60
         ADV#=DIV#
         DIV#=DIV#/60
         DIV#=Int(DIV#)
         T$=" Hrs"+Str$(Int(ADV#-(DIV#*60)))+T$
      End If 
   Else If DIV#>320
      DIV#=FREQ
      DIV#=(T_LENGTH/DIV#)*1000
      T$=" Ms"
   Else 
      T$=_BPM$
   End If 
Else 
   DIV#=0
End If 
Return 
'
TIME_PLY:
If PTGL=TGL Then Return 
PTGL=TGL
If PLYING
   DIV#=(Timer-PLYTIME)/MONHZ#
Else 
   DIV#=(STPTIME-PLYTIME)/MONHZ#
End If 
ADV#=DIV#
DIV#=Int(DIV#/60)
ADV#=ADV#-(DIV#*60)
TIME$=Str$(ADV#)-_SPACE$
If ADV#<10
   TIME$=_FALSE$+TIME$
End If 
ADV#=DIV#
DIV#=Int(DIV#/60)
ADV#=ADV#-(DIV#*60)
TIME$=Str$(ADV#)-_SPACE$+":"+TIME$
If ADV#<10
   TIME$=_FALSE$+TIME$
End If 
TIME$=Str$(DIV#)-_SPACE$+":"+TIME$
If DIV#<10
   TIME$=_FALSE$+TIME$
End If 
Ink _BLACK,_WHITE
Text 320,104,Left$(TIME$,11)
Return 
'
DISPATCH:
If DISPATCH$=_$ Then Return 
P$=DISPATCH$ : DISPATCH$=_$
SEQUENCER=True : MACRO=True
SET$=SETTING$(27) : SETTING$(27)=_FALSE$ : Rem always draw
PT$=T$ : PREALTIME=REALTIME : REALTIME=False
DL=0
Repeat 
   DP=DL+1
   DL=Instr(P$,_COMMA$,DP)
   If DL>0
      T$=Mid$(P$,DP,DL-DP)
      Gosub CMD
   End If 
Until DL=0
T$=PT$ : REALTIME=PREALTIME
SETTING$(27)=SET$ : Rem always draw
SEQUENCER=False : MACRO=False
P$=_$
Return 
'
POWERPACKER:
If Not PP20
   TXT1$="powerpacker.library"
   Trap Lib Open 3,TXT1$,0
   If Errtrap
      TXT2$=_NOTAVAILABLE$ : Goto _ERROR
   Else 
      PP20=True
   End If 
End If 
Close 1
_TOAST$="Power Packer " : Gosub T0AST
PPROGDIR$=Dir$
'**************************************************************************
'PowerPacker.library Procedure originally by Marcin Szumiela 
'(C) Copright 1990 Nico François     
'  
S$=Dir$+F$+_NULL$
Areg(0)=Varptr(S$)
Areg(1)=Varptr(S_START)
Areg(2)=Varptr(S_LENGTH)
Areg(3)=0
Dreg(0)=3 : Rem effect 
Dreg(1)=0
CN=Lib Call(3,-$1E)
If CN=-1
   TXT1$="Power Packer" : TXT2$="decompression failed!" : Goto _NOTICE
End If 
Dir$="T:"
F$=_DEFAULT$
Open Out 1,F$
Ssave 1,S_START To S_START+S_LENGTH
Close 1
Areg(1)=S_START
Dreg(0)=S_LENGTH
CN=Execall(-$D2)
'
'**************************************************************************
_PPCOMPRESSED=True
Return 
'
'
'
'***************************************************************************** 
'*mouse*********************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    .        :      ...      ...    ::: .::::::. .,:::::: 
'    ;;,.    ;;;  .;;;;;;;.  ';;     ;;;;;;`    `;;;;;'''' 
'    [[[[, ,[[[[,,[[     \[[,[['     [[['[==/[[[[, [[cccc  
'    $$$$$$$$"$$$$$$,     $$$$$      $$$  '''    $ $$""""  
'   888 Y88" 888o"888,_ _,88P88    .d888,88b    dP 888oo,_ 
'   MM  M'  "MMMM  "YMMMMMP"  "YmmMMMM""  "YMmMY"  """"YUM 
'
'
'
SETZN:
If RL<2
   Set Zone ZN_LEFTRANGESPACE,0,HDR_H To SCR_W,WVE_H+HDR_H-1
   I=ZN_LEFTRANGE : N=ZN_RIGHTRANGESPACE : Gosub RESETZN
Else If XR>1 and XR2>0
   Set Zone ZN_LEFTRANGESPACE,0,HDR_H To XR-1,WVE_H+HDR_H-1
   Set Zone ZN_LEFTRANGE,XR,RNG_T+HDR_H To XR+12,RNG_B+HDR_H-1
   If XR+24<XR2
      Set Zone ZN_MIDDLERANGESPACE,XR+12,HDR_H To XR2-12,WVE_H+HDR_H-1
   Else 
      Reset Zone ZN_MIDDLERANGESPACE
   End If 
   If XR2>12 and XR2<SCR_W
      Set Zone ZN_RIGHTRANGE,XR2-12,RNG_T+HDR_H To XR2+1,RNG_B+HDR_H-1
   Else 
      If RFIN-FIN=0
         If XR<614
            Set Zone ZN_MIDDLERANGESPACE,XR+12,HDR_H To 626,WVE_H+HDR_H-1
         Else 
            Reset Zone ZN_MIDDLERANGESPACE
         End If 
         Set Zone ZN_RIGHTRANGE,627,RNG_T+HDR_H To SCR_W,RNG_B+HDR_H-1
      Else 
         Reset Zone ZN_RIGHTRANGE
      End If 
   End If 
   Set Zone ZN_RIGHTRANGESPACE,0,HDR_H To SCR_W,WVE_H+HDR_H-1
Else If XR=0 and XR2>0 and XR2<25
   Reset Zone ZN_LEFTRANGESPACE
   Set Zone ZN_LEFTRANGE,0,RNG_T+HDR_H To 6,RNG_B+HDR_H-1
   Reset Zone ZN_MIDDLERANGESPACE
   Set Zone ZN_RIGHTRANGE,6,RNG_T+HDR_H To 12,RNG_B+HDR_H-1
   Set Zone ZN_RIGHTRANGESPACE,0,HDR_H To SCR_W,WVE_H+HDR_H-1
Else If XR=0 and XR2>24 and XR2<SCR_W-2
   Reset Zone ZN_LEFTRANGESPACE
   If RST-ST=0
      Set Zone ZN_LEFTRANGE,0,RNG_T+HDR_H To 12,RNG_B+HDR_H-1
      Set Zone ZN_MIDDLERANGESPACE,12,HDR_H To XR2-12,WVE_H+HDR_H-1
   Else 
      Reset Zone ZN_LEFTRANGE
      Set Zone ZN_MIDDLERANGESPACE,0,HDR_H To XR2-12,WVE_H+HDR_H-1
   End If 
   Set Zone ZN_RIGHTRANGE,XR2-12,RNG_T+HDR_H To XR2+1,RNG_B+HDR_H-1
   Set Zone ZN_RIGHTRANGESPACE,0,HDR_H To SCR_W,WVE_H+HDR_H-1
Else If XR2>0
   Reset Zone ZN_LEFTRANGESPACE
   Set Zone ZN_LEFTRANGE,0,RNG_T+HDR_H To 12,RNG_B+HDR_H-1
   Set Zone ZN_MIDDLERANGESPACE,13,HDR_H To 628,WVE_H+HDR_H-1
   If((RFIN/CON#)-(FIN/CON#))<1
      Set Zone ZN_RIGHTRANGE,628,RNG_T+HDR_H To SCR_W,RNG_B+HDR_H-1
   Else 
      Reset Zone ZN_RIGHTRANGE
      If RST-ST=0
         Set Zone ZN_MIDDLERANGESPACE,13,HDR_H To SCR_W,WVE_H+HDR_H-1
      Else 
         Set Zone ZN_MIDDLERANGESPACE,0,HDR_H To SCR_W,WVE_H+HDR_H-1
      End If 
   End If 
   Set Zone ZN_RIGHTRANGESPACE,0,HDR_H To SCR_W,WVE_H+HDR_H-1
End If 
Return 
'
RESETZN:
Repeat 
   Reset Zone I
   Inc I
Until I>N
Return 
'
TESTMOVE:
Gosub MPOS : PX=CX : PY=CY
Gosub MKEY : MK=M
Repeat 
   Gosub GVAL
   Gosub DISPATCH
Until Fn KEY_PRESS or MK-M or CY-PY or CX-PX
Return 
'
MUP:
Repeat 
   Gosub TASK
   Gosub MKEY
Until Fn MOUSEUP
Return 
'
MKEY:
M=Mouse Key
If M=4
   M=0 : Rem mouseup
Else If M=5 or Fn KEY_LEFTAMIGAALT
   M=1 : Rem mousedown
Else If Fn KEY_RIGHTAMIGAALT
   M=2 : Rem mousemenu
End If 
Return 
'
MPOS:
If S>0
   If C>75 and C<80 : Rem emulate standard amiga keyboard mouse
      If( Fn KEY_LEFTAMIGA or Fn KEY_RIGHTAMIGA or Fn KEY_LEFTAMIGAALT or Fn KEY_RIGHTAMIGAALT)
         If Fn KEY_UP
            Y Mouse=Y Mouse-1
         Else If Fn KEY_DOWN
            Y Mouse=Y Mouse+1
         Else If Fn KEY_RIGHT
            X Mouse=X Mouse+1
         Else If Fn KEY_LEFT
            X Mouse=X Mouse-1
         End If 
      End If 
   End If 
End If 
CX=X Screen(X Mouse)
CY=Y Screen(Y Mouse)
Return 
'
MCOL:
Palette ,,,,,,,,,,,,,,,,,$DDD,$E11,$111
Return 
'
SLOW:
If CX<PX Then X Mouse=X Mouse+1 Else X Mouse=X Mouse-1
Return 
'
STICKY:
If CY<PY Then Y Mouse=Y Mouse+(PY-CY) Else Y Mouse=Y Mouse-(CY-PY)
If CX<PX Then X Mouse=X Mouse+((PX-CX)/2) Else X Mouse=X Mouse-((CX-PX)/2)
Return 
'
'
'
'***************************************************************************** 
'*choice********************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'     .,-::::::  ::   .:     ...      :::    .,-::::::.,:::::: 
'   ,;;;'````'  ,;;   ;;, .;;;;;;;.   ;;;  ,;;;'````' ;;;;'''' 
'   [[[        ,[[[,,,[[[,[[     \[[, [[[  [[[         [[cccc  
'   $$$        "$$$"""$$$$$$,     $$$ $$$, $$$         $$""""  
'   `88bo,__,o, 888   "88"888,_ _,88Po88888`88bo,__,o, 888oo,_ 
'     "YUMMMMMP MMM    YM  "YMMMMMP" MMM"MM  "YUMMMMMP """"YUM 
'
'
'
MCHOOSE:
_CHOICE=False
If G$=_$ Then Return 
If RL=0 and MENFX
   If _M1SEL=3 and _M2SEL=2 : Rem resample 
   Else If M1SEL=3 and _M2SEL=7 : Rem convert
   Else 
      RL=P_LENGTH
      _CHOICE=3
   End If 
End If 
_REPEATP$=_REPEAT$
S$=M$
If G$="_UNDO" Then _REPEAT$=_REPEATP$ Else _REPEAT$=G$
If _REPEAT$=_MACRO$ Then _REDRAW=True Else _REDRAW=False
Gosub G$
If _REDRAW
   MENFX=True : REQ=True
Else If MENFX and RL>1
   Gosub STEREOQUAD
End If 
If MENFX
   If _CHOICE=3
      RL=0 : XR=0 : XR2=0
      _CHOICE=False
      Gosub POSCAL
      Gosub HEADERCORDS
   End If 
   If REQ or FX=>FXE
      Gosub _DRAWALL
   End If 
End If 
If Right$(_REPEAT$,4)<>"MENU" and REQ
   _TOAST$=_TOAST$+_REPEAT$
End If 
Goto CAL_BCK
'
BCHOOSE:
If CX=SCR_W : Rem mouse zone does not allow 640  
   If CY>HDR_H and CY<WVE_H+HDR_H
      If XR2=SCR_W
         Z=ZN_RIGHTRANGE
      Else 
         Z=ZN_RIGHTRANGESPACE
      End If 
   End If 
End If 
If Z=ZN_OSCCLOSE
   Goto _TGLOSCILLOSCOPE
Else If Z=ZN_OSCMODE
   Goto _TGLOSCILLOMODE
Else If Z=ZN_CALCLOSE
   Goto _TGLCALCULATOR
End If 
If CALC
   If CX>CAL_X and CX<CAL_W and CY>CAL_Y and CY<CAL_Y+CAL_H
      Gosub CAL_DRW
      Return : Rem protect range beneath  
   End If 
End If 
If RENDERING Then Goto DRWDIALS
If Z>=ZN_PLAY and Z<ZN_PLAY+_AB+1
   PZN=Z : Gosub PRESSBTN
   If Not _ON
      Return 
   End If 
End If 
If Z=ZN_PLAY and PLYING and CX>56 : Rem half button
   _TOAST$="_STOP"
   Goto _STOP
Else If Z=ZN_TOAST
   N=24 : Gosub SETSET : Gosub MUP
Else If Z>0
   If P_LENGTH=0 and Fn MONOORSTEREOORQUAD and Z<>ZN_PASTE
      Goto FLSHSCR
   End If 
End If 
If Z>0
   On Z-(ZN_LEFTWAND-1) Goto LEFTWAND,RIGHTWAND,MOVEWAND,RANGE,SELLEFT,RANGE,SELRIGHT,RANGE
   If Z<ZN_PLAY+_AB+1
      G$=BUTG$(Z-ZN_PLAY)
      If Z=ZN_MIX and RL=0 : Rem stereo quad
         RL=P_LENGTH
      End If 
      Gosub G$
      If Z=ZN_MIX
         If RL>1
            Gosub STEREOQUAD
         End If 
      End If 
      If Z=ZN_MIX or Z=ZN_REPEAT
         Gosub _DRAWALL
      End If 
      _TOAST$=G$
   End If 
End If 
Goto DRWDIALS
'
KCHOOSE:
If Fn KEY_LEFTAMIGA or Fn KEY_RIGHTAMIGA
   If Not RENDERING
      If C<5 : Rem 1 2 3 4
         _M3SEL=C : Goto M0DEMENU
      Else If Fn KEY_D
         Goto NEWCLI
      Else If C=54 : Rem n
         Goto _NEW
      Else If C=24 : Rem o
         Goto _OPEN
      Else If C=25 : Rem p
         Goto _APPEND
      Else If C=19 : Rem r
         Goto _REVERT
      Else If C=50 : Rem x
         Goto _CUT
      Else If C=51 : Rem c
         Goto _COPY
      Else If C=52 : Rem v
         Goto _PASTE
      Else If C=49 : Rem z
         Goto _UNDO
      End If 
   End If 
Else If C=11 : Rem -
   Goto _PREVIOUS
Else If C=12 : Rem +
   Goto _NEXT
Else If C=74 : Rem numpad - 
   Add KMUL,-10
   If KMUL<0
      KMUL=0
   End If 
   B=KMUL
   If B<1
      B=1
   End If 
   C=B+79
   Goto FKEY
Else If C=94 : Rem numpad + 
   Add KMUL,10
   B=KMUL
   C=B+79
   Goto FKEY
Else If Fn KEY_SPACE
   Goto _STOP
Else If Fn KEY_BACKSPACE
   If PLYING
      If Fn MULTI
         T$="_REWINDALL"
      Else 
         T$="_REWIND"
      End If 
      _TOAST$=T$
      If SETTING$(26)=_FALSE$ : Rem quantizer
         Goto T$
      Else 
         T$=T$+_COMMA$+_NEWLINE$
         Goto ACTION
      End If 
   End If 
Else If Fn KEY_RETURN
   Goto _TGLLOOP
Else If Fn KEY_ESC
   Goto _QUIT
Else If C>28 and C<32 : Rem numpad 1 2 3 
   C=C+51+KMUL
   Goto FKEY
Else If C>44 and C<48 : Rem numpad 4 5 6 
   C=C+38+KMUL
   Goto FKEY
Else If C>60 and C<64 : Rem numpad 7 8 9 
   C=C+25+KMUL
   Goto FKEY
Else If C>79 and C<90 : Rem function keys
   Goto FKEY
Else If Fn MOUSEWHEELUP or Fn MOUSEWHEELDOWN
   Goto WHEELZOOM
Else If Fn KEY_PRESS
   If Not Fn KEY_CURSOR
      If P_LENGTH=0
         Goto FLSHSCR
      End If 
   End If 
   Gosub PIANO
   If KEYC<>-1
      _TOAST$=KEYS$
      If PIANO
         If PLYING
            If Fn MULTIINVIEW
               I=B
            Else 
               I=1
            End If 
            OFFSET=OFFSET(I)
            If OFFSET>=P_LENGTH
               OFFSET=0
            End If 
         Else 
            OFFSET=RST
         End If 
         G$="_RENDER"
         If PLYING and CON#>0 and SETTING$(26)<>_FALSE$ : Rem quantizer
            T$="NOTE="+KEYS$+_COMMA$+G$+_COMMA$+_NEWLINE$
            Goto ACTION
         Else 
            Gosub G$
            Goto STEREOQUAD
         End If 
      Else 
         FREQ=KEYF
         Gosub SETHZ
         Gosub DIALMAIN
         If RENDERING
            Gosub DRWHZ
            Gosub DRWTIMENOW
         End If 
         If RL>0 and RNGEPLY
            Goto _PLAYRANGE
         Else If DISPPLY
            Goto _PLAYDISPLAY
         Else 
            Goto _PLAY
         End If 
      End If 
   End If 
End If 
Return 
'
ACTION:
N=Instr(SEQ$,_NEWLINE$)
If N=0
   SEQ$=T$
Else If N=Len(SEQ$)
   SEQ$=SEQ$+T$
Else 
   SEQ$=Left$(SEQ$,N-1)+T$+Mid$(SEQ$,N)
End If 
Return 
'
PIANO:
If Fn KEY_CAPSLOCK Then Restore KLO Else Restore KHI
Repeat 
   Read KEYC,KEYS$,KEYF
   If KEYC=C
      Return 
   End If 
Until KEYC=-1
Return 
'
ZCHOOSE:
If PZ=ZN_LEFTRANGE
   Gosub UNR0LLLEFT
   PZ=0
Else If PZ=ZN_RIGHTRANGE
   Gosub UNR0LLRIGHT
   PZ=0
Else If Z=ZN_LEFTRANGE
   Gosub R0LLLEFT
   PZ=Z
Else If Z=ZN_RIGHTRANGE
   Gosub R0LLRIGHT
   PZ=Z
End If 
Return 
'
'
'
'***************************************************************************** 
'*menu************************************************************************ 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    .        :  .,::::::::.    :::. ...    :::  
'    ;;,.    ;;; ;;;;'''';;;;,  `;;;';;     ;;;  
'    [[[[, ,[[[[, [[cccc  [[[[[. '[[[['     [[[  
'    $$$$$$$$"$$$ $$""""  $$$ "Y$c$$$$      $$$  
'   888 Y88" 888o 888oo,_888    Y88 88    .d888    
'   MM  M'  "MMMM """"YUMMM     YM   "YmmMMMM""    
'
'
'  
INITMENU:
_BAR$=String$(_MINUS$,14)
BANKMENU$="BANKMENU"
M0DEMENU$="M0DEMENU"
RATEMENU$="RATEMENU"
SWPMENU$="SWPMENU"
_MACRO$="MACRO"
_RECORD$="Record        "
If Not Fn A1200 Then _OSCILLOSCOPE$="Oscilloscope  " Else _OSCILLOSCOPE$=_NULL$
M2=1 : I=9
Repeat 
   MENB$(M2)="F"+Str$(M2)-_SPACE$+" -"+Space$(I)
   Inc M2
   If M2=10 Then Dec I
Until M2>10
Return 
'
DRWMENU:
If Not _MENUDO
   _MENUDO=True
   _M1SEL=0 : _M2SEL=0 : _M3SEL=0
   Gosub NUDGEPOS
   Gosub CLRPOS
End If 
If _MENUSUB
   Restore 0+Val(Str$(M1)+Str$(M2-2))
   Gosub RMENU
   If _M1SEL=0 or CY<HDR_H+1 or CX<MENX(_M1SEL-1) or(CX>MENX(_M1SEL-1)-8 and CX<MENX(_M1SEL-1)+Text Length(_BAR$)-16 and((CY-5)/8)-_M2SEL)
      _MENUSUB=False
      _SPIN=0
      If CY<HDR_H+1
         _MENUDRW=True
      Else 
         MENH=0
         _MENUDRW=False
      End If 
      _MENUBOX=True
      Gosub CLRMENU
      Goto MDO
   End If 
   If _MENUSUB
      _M3SEL=(CY-8)/8-_M2SEL+1
      If _M3SEL>_M3 or CX<SUBX or CX>SUBX+SUBW
         _M3SEL=0
      End If 
      Restore 0+Val(Str$(M1)+Str$(_M2SEL))
      Gosub RMENU
      _L2=(MENX(M1-1)/8+Text Length(M$)/8)-4
      SUBX=(_L2*8)
      SUBY=(_M2SEL*8)-3
      M3=1
      SZ=1
      Repeat 
         Restore 0+Val(Str$(_M1SEL)+Str$(_M2SEL)+Str$(M3))
         Gosub RMENU
         If _M3SEL-M3
            If SETTING$(12)=_FALSE$ : Rem light mode 
               Ink _BLACK,_WHITE
            Else 
               Ink _BLACK,_SHADOW
            End If 
         Else 
            If SETTING$(12)=_FALSE$ : Rem light mode 
               Ink _WHITE,_BLACK
            Else 
               Ink _BLACK,_PANE
            End If 
         End If 
         If Len(M$)>1
            Text _L2*8+2,(_M2SEL+M3-1)*8+14,M$
            SUBW=Text Length(M$)+4
            Inc SZ
         End If 
         Inc M3
      Until M$=_NULL$
   End If 
   If SUBH=0
      SUBH=SZ*8
   End If 
   If _M3SEL<0 or _M3SEL>_M3
      _M3SEL=0
   End If 
   If SETTING$(12)=_FALSE$ : Rem light mode 
      Ink _WHITE
   Else 
      Ink _SHADOW
   End If 
   Box SUBX+1,SUBY+10 To SUBX+SUBW-2,SUBY+SUBH+3
   Ink _BLACK : Box SUBX,SUBY+9 To SUBX+SUBW-1,SUBY+SUBH+4
   Gosub TESTMOVE
   Return 
End If 
MDO:
If _MENUON and _MENUDO
   If CY<HDR_H
      _M1SEL=0
      _PM2SEL=-1
      M1=_M1
      Repeat 
         If CX>=MENX(M1-1) and CX<=MENX(M1)
            _M1SEL=M1
            Exit 
         End If 
         Dec M1
      Until M1<1
   End If 
   If M1>_M1 or M1=0
      M1=0
      MENH=0
      Return 
   End If 
   If _PM1SEL-_M1SEL
      Gosub CLRMENU
      _SPIN=0 : SUBH=0 : MENH=0
   End If 
   _PM1SEL=_M1SEL
   _PM2SEL=_M2SEL
   _M2SEL=(CY-5)/8
   Restore 0+M1
   Read M$
   If CY<HDR_H+2 or _M2SEL>M2-2 or CX<MENX(M1-1) or CX>(MENX(M1-1)+(Len(_BAR$)*8))
      _M2SEL=0
      _MENUDRW=False
   End If 
   _M3SEL=0
   _L1=(MENX(M1)/8)-Len(M$)
   MENX=(_L1*8)+2
   MENY=2
   M2=1
   SZ=1
   Repeat 
      If M1>0 and M2>0
         If M1=3 and M2>10 : Rem menu collision 
            If M2=11
               M$=" Reverse        "
            Else If M2=12
               M$=" Invert         "
            Else If M2=13
               M$=_NULL$
            End If 
         Else 
            Restore 0+Val(Str$(M1)+Str$(M2))
            Gosub RMENU
         End If 
         If _M2SEL=M2 and Peek(Varptr(M$)+2)<>CHR_MINUS
            If _PM2SEL-_M2SEL
               If SETTING$(12)=_FALSE$ : Rem light mode 
                  Ink _WHITE,_BLACK
               Else 
                  Ink _BLACK,_PANE
               End If 
               Text MENX+2,(M2*8)+MENY+9,M$
            End If 
            If Instr(M$,_»$)
               _MENUSUB=True
            End If 
            If Instr(M$,"­") : Rem the other minus
               _MENUACTION=True
               Read MENFX,G$
               If _SPIN>0
                  Gosub G$
                  Repeat 
                     Gosub TASK
                     Gosub MKEY
                     Gosub DISPATCH
                  Until Timer>_SPIN or Fn MOUSEUP
               End If 
               Gosub SPIN
               _SPIN=Timer+8
               _MENUDRW=True
            Else 
               _MENUDRW=False
               _MENUACTION=False
               _SPIN=0
            End If 
         Else If _M2SEL=0
            If _PM2SEL=M2
               If Len(M$)>1
                  If SETTING$(12)=_FALSE$ : Rem light mode 
                     Ink _BLACK,_WHITE
                  Else 
                     Ink _BLACK,_SHADOW
                  End If 
                  Text MENX+2,(M2*8)+MENY+9,M$
               End If 
               If SUBH>0
                  SUBH=0 : _MENUDRW=True
               End If 
               Gosub DRWMENUGFX
            End If 
            _SPIN=0
         Else If _PM2SEL=M2
            If SETTING$(12)=_FALSE$ : Rem light mode 
               Ink _BLACK,_WHITE
            Else 
               Ink _BLACK,_SHADOW
            End If 
            Text MENX+2,(M2*8)+MENY+9,M$
            Gosub DRWMENUGFX
         End If 
         If MENH=0 or _MENUDRW
            If _M2SEL-M2 or Peek(Varptr(M$)+2)=CHR_MINUS
               If SETTING$(12)=_FALSE$ : Rem light mode 
                  Ink _BLACK,_WHITE
               Else 
                  Ink _BLACK,_SHADOW
               End If 
            Else 
               If SETTING$(12)=_FALSE$ : Rem light mode 
                  Ink _WHITE,_BLACK
               Else 
                  Ink _BLACK,_PANE
               End If 
            End If 
            If Len(M$)>1
               Text MENX+2,(M2*8)+MENY+9,M$
               MENW=Text Length(M$)+4
               Inc SZ
            End If 
            Gosub DRWMENUGFX
         End If 
      End If 
      Inc M2
   Until M$=_NULL$
   If MENH=0
      _MENUBOX=True
   Else 
      _MENUBOX=False
   End If 
   If MENH=0
      MENH=SZ*8
   End If 
   If _MENUBOX
      If SETTING$(12)=_FALSE$ : Rem light mode 
         Ink _WHITE
      Else 
         Ink _SHADOW
      End If 
      Polyline MENX+1,MENY+9 To MENX+MENW-2,MENY+9 To MENX+MENW-2,MENY+MENH+3 To MENX+1,MENY+MENH+3 To MENX+1,MENY+10 To MENX+MENW-2,MENY+10
      Ink _BLACK
      Polyline MENX+MENW-1,MENY+9 To MENX+MENW-1,MENY+MENH+4 To MENX,MENY+MENH+4 To MENX,MENY+9
   End If 
   If _MENUSUB=False and _MENUACTION=False
      Gosub TESTMOVE
   End If 
End If 
If Not _MENUON
   If OSCILLO
      Gosub _SHOWCOPY
   End If 
   M1=1
   If SETTING$(12)=_FALSE$ : Rem light mode 
      Ink _WHITE
   Else 
      Ink _SHADOW
   End If 
   Bar 0,0 To SCR_W,10
   If SETTING$(12)=_FALSE$ : Rem light mode 
      Ink _BLACK,_WHITE
   Else 
      Ink _BLACK,_SHADOW
   End If 
   Repeat 
      Restore 0+M1
      Read M$
      If Len(M$)>1
         MENX(M1)=Text Length(M$)+MENX(M1-1)
         Text MENX(M1-1)+7,8,M$
      End If 
      Inc M1
   Until M$=_NULL$
   _MENUON=True
   _PM2SEL=-1
End If 
Return 
'
DRWMENUGFX:
If Instr(M$,"­") : Rem the other minus
   If M2>1
      _BOB=6
   Else 
      _BOB=5
   End If 
   Paste Bob MENX-8+MENW/2,M2*8+5,_BOB
End If 
Return 
'
RMENU:
Read M$
If Len(M$)>1
   If Peek(Varptr(M$))=CHR_MINUS or Left$(M$,1)="­" : Rem the other minus
      M$=_SPACE$+M$+_SPACE$
   Else 
      M$=_SPACE$+M$+_SPACER$
   End If 
End If 
Return 
'  
DRWMENUC:
If _M1SEL>0
   If _M3SEL=0
      M$=Str$(_M1SEL)+Str$(_M2SEL)-_SPACE$
   Else 
      M$=Str$(_M1SEL)+Str$(_M2SEL)+Str$(_M3SEL)-_SPACE$
   End If 
   If _M2SEL>0
      Restore 0+Val(M$)
      Read M$
      If Peek(Varptr(M$)+2)=CHR_MINUS or Instr(M$,_»$) or M$=_NULL$ or M$=_$
         MENFX=False : G$=_$
      Else If _M1SEL=3 and _M2SEL=11 : Rem menu collision 
         MENFX=True
         G$="_REVERSE"
      Else If _M1SEL=3 and _M2SEL=12 : Rem menu collision 
         MENFX=True
         G$="_INVERT"
      Else 
         Read MENFX,G$
      End If 
   Else 
      M$=_$ : MENFX=False : G$=_$
   End If 
   _CHOICE=True
End If 
_MENUON=False : _MENUDO=False : _MENUSUB=False
Gosub CLRMENU
Goto HEADER
'
CLRMENU:
If MENH>8
   If Fn MULTI
      Screen Copy 1,MENX,MENY-2,MENX+MENW,RNG_T To 0,MENX,HDR_H+MENY-2
      MENT=RNG_T-1 : MENB=RNG_B
   Else 
      MENT=MENY-2 : MENB=MENY+MENH-6
   End If 
   If XR<=MENX-1 and XR2>MENX and XR2>=MENX+MENW-1
      Screen Copy 1,MENX,MENT,MENX+MENW,MENB To 0,MENX,HDR_H+MENT,%110000
   Else If XR<=MENX-1 and XR2>MENX and XR2<=MENX+MENW-1
      Screen Copy 1,MENX,MENT,XR2,MENB To 0,MENX,HDR_H+MENT,%110000
      Screen Copy 1,XR2,MENT,MENX+MENW,MENB To 0,XR2,HDR_H+MENT
   Else If XR>=MENX-1 and XR2>MENX and XR2>=MENX+MENW-1
      Screen Copy 1,MENX,MENT,XR,MENB To 0,MENX,HDR_H+MENT
      Screen Copy 1,XR,MENT,MENX+MENW,MENB To 0,XR,HDR_H+MENT,%110000
   Else If XR>=MENX-1 and XR2>MENX and XR2<=MENX+MENW-1
      Screen Copy 1,MENX,MENT,XR,MENB To 0,MENX,HDR_H+MENT
      Screen Copy 1,XR,MENT,XR2,MENB To 0,XR,HDR_H+MENT,%110000
      Screen Copy 1,XR2,MENT,MENX+MENW,MENB To 0,XR2,HDR_H+MENT
   Else 
      Screen Copy 1,MENX,MENT,MENX+MENW,MENB To 0,MENX,HDR_H+MENT
   End If 
   If Fn MULTI
      Screen Copy 1,MENX,RNG_B,MENX+MENW,MENY+MENH-6 To 0,MENX,HDR_H+RNG_B
   End If 
   If RL>0
      Gosub DRWMARKS
   End If 
   If MENY+MENH+4>WVE_H+HDR_H
      Gosub CONTROLS
   End If 
   If CALC
      If MENX+MENW>CAL_X and((MENY+MENH+4)>CAL_Y or(MENB+HDR_H)>CAL_Y)
         Gosub CAL_BCK
      End If 
   End If 
End If 
MENH=0
CLRSUBMENU:
If SUBH>0
   If Fn MULTI
      Screen Copy 1,SUBX,SUBY-2,SUBX+SUBW,RNG_T To 0,SUBX,HDR_H+SUBY-2
      SUBT=RNG_T-1 : SUBB=RNG_B
   Else 
      SUBT=SUBY-2 : SUBB=SUBY+SUBH-6
   End If 
   If XR<=SUBX-1 and XR2>SUBX and XR2>=SUBX+SUBW-1
      Screen Copy 1,SUBX,SUBT,SUBX+SUBW,SUBB To 0,SUBX,HDR_H+SUBT,%110000
   Else If XR<=SUBX-1 and XR2>SUBX and XR2<=SUBX+SUBW-1
      Screen Copy 1,SUBX,SUBT,XR2,SUBB To 0,SUBX,HDR_H+SUBT,%110000
      Screen Copy 1,XR2,SUBT,SUBX+SUBW,SUBB To 0,XR2,HDR_H+SUBT
   Else If XR>=SUBX-1 and XR2>SUBX and XR2>=SUBX+SUBW-1
      Screen Copy 1,SUBX,SUBT,XR,SUBB To 0,SUBX,HDR_H+SUBT
      Screen Copy 1,XR,SUBT,SUBX+SUBW,SUBB To 0,XR,HDR_H+SUBT,%110000
   Else If XR>=SUBX-1 and XR2>SUBX and XR2<=SUBX+SUBW-1
      Screen Copy 1,SUBX,SUBT,XR,SUBB To 0,SUBX,HDR_H+SUBT
      Screen Copy 1,XR,SUBT,XR2,SUBB To 0,XR,HDR_H+SUBT,%110000
      Screen Copy 1,XR2,SUBT,SUBX+SUBW,SUBB To 0,XR2,HDR_H+SUBT
   Else 
      Screen Copy 1,SUBX,SUBT,SUBX+SUBW,SUBB To 0,SUBX,HDR_H+SUBT
   End If 
   If Fn MULTI
      Screen Copy 1,SUBX,RNG_B,SUBX+SUBW,SUBY+SUBH To 0,SUBX,HDR_H+RNG_B
   End If 
   If RL>0
      Gosub DRWMARKS
   End If 
   If SUBY+SUBH+4>WVE_H+HDR_H
      Gosub CONTROLS
   End If 
   If CALC
      If SUBX+SUBW>CAL_X and SUBY+SUBH+4>CAL_Y
         Gosub CAL_BCK
      End If 
   End If 
End If 
SUBH=0
Goto HIGHPIANO
'
M0DEMENU:
If _M3SEL=_MODE and _TEXT=False Then Goto _TOASTMODE
If _REC Then Gosub _TGLRECORD
If _M3SEL=4 and Fn MONOORSTEREOORQUAD
   Gosub CLRPLY
   Bank Swap PBANK,B+7
   PBANK=B+7
   Gosub R4INSET
Else If Fn MULTI and _M3SEL-4
   If Length(B+7)=0
      Gosub CLRPLY
   End If 
   PBANK=5
   Bank Swap B+7,PBANK
   Gosub R4INRESTORE
End If 
If B>1 and Fn INVIEW and Length(B+7)>0
   Swap ADVPOS#(B),ADVPOS#(1)
   Swap XP(B),XP(1)
   Swap XP(B),XP(1)
   Swap OFFSET(B),OFFSET(1)
End If 
_MODE=_M3SEL
Gosub _TOASTMODE
Gosub PBANKLEN
Gosub SETPBANK
Gosub BANKSET
Gosub _RANGENONE
Gosub CLRPOS
RENDERING=True
Gosub _DRAW
Gosub SETCORDS
RENDERING=False
Gosub DRWTIME
Gosub HEADERCORDS
If _VST Then Gosub SOCK_SENDVSTUP
Return 
'
_14BIT:
Volume PAULA(4),1
Volume PAULA(3),1
_TOAST$="14bit"
Return 
'
_TOASTMODE:
If Fn MONO
   _TOAST$=_TOAST$+"Mono"
   _CHANNELS=1
Else If Fn STEREO
   _TOAST$=_TOAST$+"Stereo"
   _CHANNELS=2
Else If Fn QUAD
   _TOAST$=_TOAST$+"Quad"
   _CHANNELS=4
Else 
   _TOAST$=_TOAST$+"Multi"
   _CHANNELS=1
End If 
Goto T0AST
'
RATEMENU:
T$=M$
Gosub ŻFREQ
RENDERING=False
Return 
'
'
'
'***************************************************************************** 
'*windows********************************************************************* 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'.::    .   .:: :::  ::.    :::.::::::-.      ...     .::    .   .:: .::::::.  
'';;,  ;;  ;;;' ;;;  ;;;;,  `;;;;;,   `';, .;;;;;;;.  ';;,  ;;  ;;;';;;`    `; 
' '[[, [[, [['  [[[   [[[[[. '[[`[[     [[,[[     \[[, '[[, [[, [[' '[==/[[[[, 
'   Y$c$$$c$P   $$$,  $$$ "Y$c$$ $$,    $$$$$,     $$$   Y$c$$$c$P    '''    $ 
'    "88"888   o88888888    Y88  888_,o8P'"888,_ _,88P    "88"888   ,88b    dP 
'     "M "M"   MMM"MMMM     YM  "MMMMP"`    "YMMMMMP"      "M "M"     "YMmMY"  
'
'
'
WIN:
Gosub NUDGEPOS
Gosub CLRPOS
RENDERING=True
If _COL=_PANE Then Ink _SHADOW Else Ink _COL-1
Bar WX-4,WY-3 To WX-1,WY2+3
Bar WX2+1,WY-3 To WX2+4,WY2+3
Bar WX,WY-3 To WX2,WY-1
Bar WX,WY2+1 To WX2,WY2+3
Ink _BLACK
Box WX-5,WY-4 To WX2+5,WY2+4
Ink _COL
Bar WX,WY To WX2,WY2
Ink _SHADOW
Bar WX+1,WY+1 To WX2-1,WY+13
Ink _COL-1
Box WX+1,WY+1 To WX2-1,WY2-1
Ink _WHITE,_SHADOW
Text WX+4,WY+10,WTXT$
Return 
'
WINWAITC:
_COL=_WHITE
PTGL=1 : Rem show play time 
BTXT1$=_OK$ : BX=267 : BY=WY2-BUT_H-4 : BZN=ZN_OK : Gosub GRAYBTN
Repeat 
   Gosub GVAL
   If ABOUT and _AMIVER>3
      If PLYTIME>0
         Gosub TIME_PLY
      End If 
   End If 
   If Z=ZN_OK and Fn MOUSEDOWN
      PZN=Z : Gosub PRESS
      If _ON
         REQ=True
         Exit 
      End If 
   End If 
Until Fn KEY_RETURN or Fn KEY_ESC
Reset Zone ZN_OK
WINC:
I=ZN_OK : N=ZN_CANCEL : Gosub RESETZN
If _INIT Then Gosub SH0WWAVE
If _CHOICE-3 Then Gosub FRSHSEL
If Fn MULTI Then Gosub R4INSET
RENDERING=False
_TEXT=False
Return 
'
FREQUEST:
If Fn A500 Then Gosub _STOP
FRQ=False : _TEXT=True
WX=100 : WY=21 : WX2=540 : WY2=174 : _COL=_WHITE : Gosub WIN
Paste Bob WX2-22,WY+4,4
Set Zone ZN_FILES,WX2-22,WY+4 To WX2-10,WY+10
Ink _SHADOW
Draw 104,156 To 420,156
Set Zone ZN_FILESUP,402,40 To 424,48
Set Zone ZN_FILESDOWN,402,144 To 424,154
Set Zone ZN_FILESTEXT,110,157 To 420,173
_COL=_WHITE
BX=432
BTXT1$=_OK$ : BY=39 : BZN=ZN_FILESOK : Gosub GRAYBTN
BTXT1$="Parent" : Add BY,BUT_H : BZN=ZN_FILESPARENT : Gosub GRAYBTN
BTXT1$="Volumes" : Add BY,BUT_H : BZN=ZN_FILESVOLUMES : Gosub GRAYBTN
Gosub DEVBUT
BTXT1$=_CANCEL$ : Add BY,BUT_H+6 : BZN=ZN_FILESCANCEL : Gosub GRAYBTN
If FTOTAL=0
   Gosub GDR
   FPOS=0
End If 
Gosub DRWDR
Gosub DRWSLI
CR$=_$ : TXT_X=0 : _MAX=128
Gosub DRWFILE
Repeat 
   Gosub TESTMOVE
   J:
   If( Fn MOUSEWHEELUP or Fn KEY_UP or(Z=ZN_FILESUP and Fn MOUSEDOWN)) and FTOTAL>15
      Repeat 
         Dec FPOS
         If Fn MOUSEWHEELUP
            Add FPOS,-4
         End If 
         If FPOS<0
            FPOS=0
         End If 
         Gosub DRWDR
         Gosub DRWSLI
         Gosub SPIN
         Gosub MKEY
      Until Fn MOUSEUP
   Else If( Fn MOUSEWHEELDOWN or Fn KEY_DOWN or(Z=ZN_FILESDOWN and Fn MOUSEDOWN)) and FTOTAL>15
      Repeat 
         Inc FPOS
         If Fn MOUSEWHEELDOWN
            Add FPOS,4
         End If 
         If FPOS>FTOTAL-16
            FPOS=FTOTAL-16
         End If 
         Gosub DRWDR
         Gosub DRWSLI
         Gosub SPIN
         Gosub MKEY
      Until Fn MOUSEUP
   Else If((Z>ZN_FILESCANCEL and Z<ZN_FILESLISTEND+1) or(Z>=ZN_LEFTRANGESPACE and Z<=ZN_RIGHTRANGESPACE)) and PZN-Z : Rem filename rollover rollout
      Gosub DRWDR
      PZN=Z
   Else If Fn KEY_RETURN
      FRQ=True
      Exit 
   Else If Fn MOUSEDOWN
      PZN=Z
      If Z=ZN_FILESOK : Rem ok 
         PZN=Z : BY=39 : Gosub PRESS
         If _ON
            FRQ=True
            Exit 
         End If 
      Else If Z=ZN_FILESTEXT : Rem text input 
         I:
         N=Len(F$)
         N=N-(N-((CX/8)-15)) : Rem mouse position cursor
         If N>Len(F$)
            N=Len(F$)
         End If 
         Repeat 
            T$=F$
            Gosub _TEXTINPUT
            F$=T$
            Ink _BG
            CR$=_SCORE$
            FOFF=Len(F$)-37
            Gosub DRWFILE
            Gosub TESTMOVE
            If Z=ZN_FILESTEXT and Fn MOUSEDOWN : Rem click again inside the text gadget 
               Goto I
            End If 
         Until Fn KEY_RETURN or Fn KEY_ESC or Fn MOUSEDOWN
         If Fn KEY_ESC
            Exit 
         End If 
         CR$=_$
         Gosub DRWFILE
         If Z<>ZN_FILESTEXT or Fn KEY_RETURN : Rem another button was selected
            Goto J
         End If 
      Else If Z=ZN_FILESBAR and FTOTAL>15 : Rem scroll bar 
         MY=CY-((FPOS*SLISIZE#)/14)
         Repeat 
            Gosub TESTMOVE
            FPOS=((CY-MY)/SLISIZE#)*14
            If FPOS<0
               FPOS=0
            End If 
            If FPOS>FTOTAL-16
               FPOS=FTOTAL-16
            End If 
            Gosub DRWDR
            Gosub DRWSLI
         Until Fn MOUSEUP
      Else If Z=ZN_FILESPARENT : Rem parent 
         PZN=Z : BY=53 : Gosub PRESS
         If _ON
            Parent 
            Gosub GDR : FPOS=0
            Gosub DRWDR
            Gosub DRWSLI
         End If 
      Else If Z=ZN_FILESVOLUMES : Rem volumes
         PZN=Z : BY=67 : Gosub PRESS
         If _ON
            Gosub VLUMES : FPOS=0
            Gosub DRWDR
            Gosub DRWSLI
         End If 
      Else If Z>ZN_FILESVOLUMES and Z<ZN_FILESCANCEL : Rem devices  
         PZN=Z : BY=67+((Z-ZN_FILESVOLUMES)*BUT_H) : Gosub PRESS
         If _ON
            Trap Dir$=DEVS$(Z-ZN_FILESVOLUMES)
            If Errtrap
               Gosub FLSHSCR
            Else 
               Gosub GDR : FPOS=0
               Gosub DRWDR
               Gosub DRWSLI
            End If 
         End If 
      Else If Z=ZN_FILESCANCEL : Rem cancel 
         PZN=Z : BY=157 : Gosub PRESS
         If _ON
            Exit 
         End If 
      Else If Z>ZN_FILESCANCEL and Z<ZN_FILESLISTEND+1 : Rem select file
         PZN=Z
         Gosub MUP
         Gosub GVAL
         If PZN=Z
            Gosub CHOFN
         End If 
      Else If Z=ZN_FILES : Rem reload cache 
         Gosub GDR : FPOS=0
         Gosub DRWDR
         Gosub DRWSLI
         _TOAST$=Dir$ : Gosub T0AST : Rem show current folder
      End If 
   Else If Fn KEY_ESC
      Exit 
   End If 
Until FRQ
I=ZN_FILES : N=ZN_FILESLISTEND : Gosub RESETZN
Gosub MAGICWAND
If FRQ and F$=_$
   FRQ=False
   Gosub FLSHSCR
Else 
   LF$=F$
End If 
REQ=FRQ
Goto WINC
'
DEVBUT:
BY=67
I=1
Repeat 
   Add BY,BUT_H : Inc BZN
   BTXT1$=DEVS$(I) : Gosub GRAYBTN
   Inc I
Until I>5
Return 
'  
CHOFN:
Paper _WHITE : Pen _GRAY
FILES$=FILES$(FPOS+Z-ZN_FILESLIST)
I=Len(FILES$)
Repeat 
   Exit If Peek(Varptr(FILES$)+I-1)<>CHR_SPACE
   Dec I
Until I=0
If FILES$<>_$
   If I=0
      D$=Mid$(FILES$,2,Len(FILES$))
   Else 
      D$=Mid$(FILES$,2,I-1)
   End If 
   I=Peek(Varptr(FILES$))
   If I=CHR_STAR or I=CHR_QUESTIONMARK or I=CHR_HASH
      If I=CHR_QUESTIONMARK
         DEVS$(5)=D$
         BZN=ZN_FILESVOLUMES : Gosub DEVBUT
      End If 
      Trap Dir$=D$
      If Errtrap
         S$=WTXT$
         TXT1$="Error opening" : TXT2$='"'+D$+'"' : Gosub _ERROR
         WTXT$=S$
         Dir$=PROGDIR$
         Pop : Goto FREQUEST
      Else 
         Gosub GDR : FPOS=0
         Gosub DRWDR
         Gosub DRWSLI
      End If 
   Else 
      F$=D$
      If S$=F$ : Rem double click 
         FRQ=True
      Else 
         S$=F$
         FOFF=Len(F$)-37
         Gosub DRWFILE
      End If 
   End If 
End If 
Return 
'
DRWFILE:
If FOFF<0 Then FOFF=0
Ink _BLACK,_WHITE
Text 120,167,Space$(37)
If F$<>_$ Then Text 120,167,Mid$(F$,FOFF+1,Min(Len(F$)-FOFF,37))
Gr Writing %10
If N-FOFF>0 Then Text 120+((N-FOFF)*8),167,CR$+_SPACE$ Else Text 120,167,CR$+_SPACE$
Gr Writing %1
Return 
'  
GDR:
Gosub CLRFILES
Gosub SETFILENAMELENGTH
D$=Dir First$(_$)
While D$<>_$ and TCOUNT<_FR
   If Peek(Varptr(D$))<>CHR_STAR
      FILEL(TCOUNT)=Val(Right$(D$,8))
      I=Len(D$)-8
      Repeat 
         Exit If Peek(Varptr(D$)+(I-1))<>CHR_SPACE
         Dec I
      Until I<0
      If FILEL(TCOUNT)=0 or FILEL(TCOUNT)>999999
         Trap Open In 1,Mid$(D$,2,I-1)
         If Not Errtrap
            FILEL(TCOUNT)=Lof(1)
            Close 1
         End If 
      End If 
   Else 
      I=Len(D$)
   End If 
   FILES$(TCOUNT)=Mid$(D$,0,I)
   Trap D$=Dir Next$
   If Errtrap
      Pop : Goto NOSPACE
   End If 
   Inc TCOUNT
   If TCOUNT=_FR
      Gosub FLSHSCR
      _TOAST$="Error: Over"+Str$(_FR)+" Files" : Gosub T0AST
   End If 
Wend 
FTOTAL=TCOUNT : Inc FTOTAL
Return 
'  
CLRFILES:
I=1
Repeat 
   FILES$(I)=_$
   FILEL(I)=0
   Inc I
Until I>_FR
RSTFILES:
FTOTAL=0
TCOUNT=1
Return 
'
VLUMES:
Gosub CLRFILES
D$=Dev First$("d:") : I=CHR_QUESTIONMARK : Gosub VTYPE
D$=Dev First$("a:") : I=CHR_HASH
VTYPE:
Repeat 
   FILES$(TCOUNT)=Chr$(I)+D$-_SPACE$
   Inc TCOUNT
   D$=Dev Next$
Until D$=_$
FTOTAL=TCOUNT
Return 
'
DRWDR:
Pen _BLACK
TCOUNT=FPOS : N=ZN_FILESLIST+1
Locate ,5
Repeat 
   Inc TCOUNT
   SZ=FILEL(TCOUNT)
   FILES$=Space$(34)
   Mid$(FILES$,0)=FILES$(TCOUNT)
   I=Peek(Varptr(FILES$))
   If I=CHR_STAR
      S$=Zone$("(Dir)"+Mid$(FILES$,2),N)
   Else If I=CHR_QUESTIONMARK
      S$=Zone$("(Dev)"+Mid$(FILES$,2)+Space$(34-Len(FILES$)),N)
   Else If I=CHR_HASH
      S$=Zone$(_SPACE$+Mid$(FILES$,2)+Space$(38-Len(FILES$)),N)
   Else 
      If SZ=0 and FILES$-_SPACE$=_$
         S$=Zone$(Space$(38),N)
      Else 
         If SZ<0
            S$=">2"+_GIGA$
         Else If SZ<1000
            S$=Str$(SZ)-_SPACE$+_BYTE$
         Else If SZ<1000000
            S$=Str$(SZ/1000)-_SPACE$+_KILO$
         Else If SZ<_MEGABYTE
            S$=Left$(Str$(SZ/_MEGABYTE#)-_SPACE$,3)+_MEGA$
         Else If SZ<_GIGABYTE
            S$=Str$(SZ/_MEGABYTE)-_SPACE$+_MEGA$
         Else 
            S$=Left$(Str$(SZ/_GIGABYTE#)-_SPACE$,3)+_GIGA$
         End If 
         S$=Zone$(FILES$+Space$(4-Len(S$))+S$,N)
      End If 
   End If 
   If TCOUNT=FPOS+Z-ZN_FILESLIST and Len(FILES$-_SPACE$)>1 Then Paper _PANE Else Paper _WHITE
   Locate 13, : Print S$
   Inc N
Until N-ZN_FILESLIST>14
Return 
'
DRWSLI:
If FTOTAL<16
   SLISIZE#=1.0
Else 
   SLISIZE#=(FTOTAL-2)/14.0
End If 
SLISIZE#=96/SLISIZE#
SLIPOS#=(SLISIZE#*FPOS)/14.0
Ink _BG
Bar 408,48 To 423,143
Ink _GRAY
Bar 410,Int(48+SLIPOS#) To 421,Int(48+SLIPOS#+SLISIZE#)
Set Zone ZN_FILESBAR,410,Int(48+SLIPOS#) To 421,Int(48+SLIPOS#+SLISIZE#)
Paste Bob 408,40,5
Paste Bob 408,144,6
Return 
'
_REQUEST:
RX=200 : RY=59
WTXT$="Request" : WX=RX : WY=RY-14 : WX2=RX+239 : WY2=104 : _COL=_WHITE : Gosub WIN
Ink _BG,_WHITE
Text RX+120-(Text Length(TXT1$)/2),RY+11,TXT1$
Text RX+120-(Text Length(TXT2$)/2),RY+21,TXT2$
_COL=_WHITE
BX=RX+12 : BY=RY+28 : BZN=ZN_OK : Gosub GRAYBTN
KT$=Lower$(Left$(BTXT1$,1))
BTXT1$=_CANCEL$ : BX=RX+125 : BZN=ZN_CANCEL : Gosub GRAYBTN
Do 
   Gosub TESTMOVE
   PZN=Z
   If( Fn MOUSEDOWN and Z=ZN_OK) or Lower$(K$)=KT$ or Fn KEY_RETURN
      PZN=Z : BX=RX+12 : Gosub PRESS
      If _ON
         REQ=True
         Exit 
      End If 
   Else If( Fn MOUSEDOWN and Z=ZN_CANCEL) or Lower$(K$)="c" or Fn KEY_ESC
      PZN=Z : BX=RX+125 : Gosub PRESS
      If _ON
         REQ=False
         Exit 
      End If 
   End If 
Loop 
I=ZN_OK : N=ZN_CANCEL : Gosub RESETZN
Goto WINC
'
_NOTICE:
If Not _INIT
   Amos To Front : View 
End If 
RENDERING=True : _TEXT=True
RX=216 : RY=59
WTXT$="Notice" : WX=RX-5 : WY=RY-14 : WX2=429 : WY2=104 : _COL=_WHITE : Gosub WIN
Ink _BG,_WHITE
Text RX+104-(Text Length(TXT1$)/2),RY+11,TXT1$
If Len(TXT2$)>25
   TXT2$='"'+_DOTS$+Right$(TXT2$,21)
End If 
Text RX+104-(Text Length(TXT2$)/2),RY+21,TXT2$
Goto WINWAITC
'  
ECHO_WIN:
WX=98 : WY=26 : WX2=536 : WY2=122 : _COL=_WHITE : Gosub WIN
Ink _PANE,_WHITE
Paper _WHITE
Pen _GRAY
Locate ,6 : Centre " 2nd:"+Str$(Length(PBANK)/2)+" 3rd:"+Str$(Length(PBANK)/3)+" 4th:"+Str$(Length(PBANK)/4)+" 5th:"+Str$(Length(PBANK)/5)
Locate ,7 : Centre " 6th:"+Str$(Length(PBANK)/6)+" 7th:"+Str$(Length(PBANK)/7)+" 8th:"+Str$(Length(PBANK)/7)+" 9th:"+Str$(Length(PBANK)/9)
Locate ,8 : Centre " 12th:"+Str$(Length(PBANK)/12)+" 16th:"+Str$(Length(PBANK)/16)+" 24th:"+Str$(Length(PBANK)/24)+" 32nd:"+Str$(Length(PBANK)/32)
Locate ,9 : Centre " 48th:"+Str$(Length(PBANK)/48)+" 64th:"+Str$(Length(PBANK)/64)+" 96th:"+Str$(Length(PBANK)/96)+" 128th:"+Str$(Length(PBANK)/128)
_EFFN=0
T$=_$
Repeat 
   If Fn KEY_PRESS and C<11
      T$=T$+K$
      Inc _EFFN
   End If 
   If C=65 and _EFFN>0
      Dec _EFFN
      T$=Mid$(T$,0,_COUNT)
   End If 
   Ink _BG,_WHITE
   Text 226,89,"bytes:"+T$+_SCORE$+_SPACE$
   Gosub GVAL
Until Fn KEY_RETURN or Fn KEY_ESC
_EFFN=Val(T$)
Return 
'
_OPENFXBIGWIN:
REALTIME=True
_REPEAT$=CHAIN$(1)
RX=215 : RY=59
WTXT$=S$ : WX=RX-5 : WY=RY-15 : WX2=RX+215 : WY2=RY+94 : _COL=_WHITE : Gosub WIN
BTXT1$=_OK$ : BX=RX : BY=RY+77 : BZN=ZN_OK : Gosub BTN
BTXT1$=_CANCEL$ : BX=RX+107 : BZN=ZN_CANCEL : Goto BTN
'
_OPENFXSMALLWIN:
REALTIME=True
_REPEAT$=CHAIN$(1)
FXRUN$=_$
RX=215 : RY=59
WTXT$=S$ : WX=RX-5 : WY=RY-15 : WX2=RX+215 : WY2=RY+25 : _COL=_WHITE : Gosub WIN
BTXT1$=_OK$ : BX=RX : BY=RY+8 : BZN=ZN_OK : Gosub BTN
BTXT1$=_CANCEL$ : BX=RX+107 : BZN=ZN_CANCEL : Goto BTN
'
_OPENFXWIN:
REALTIME=True
_REPEAT$=CHAIN$(1)
_OPENFXTEXTWIN:
RX=215 : RY=59
WTXT$=S$ : WX=RX-5 : WY=RY-15 : WX2=RX+215 : WY2=RY+45 : _COL=_WHITE : Gosub WIN
BTXT1$=_OK$ : BX=RX : BY=RY+28 : BZN=ZN_OK : Gosub BTN
BTXT1$=_CANCEL$ : BX=RX+107 : BZN=ZN_CANCEL : Goto BTN
'
_CLOSEFXWIN:
If Not REQ Then _REPEAT$=_REPEATP$
Reset Zone ZN_OK
Reset Zone ZN_CANCEL
Reset Zone ZN_PIANO
Reset Zone ZN_AUTO
Reset Zone ZN_FX
Goto DIALMAIN
'
_RUNFXWIN:
_EXIT=False
Repeat 
   Gosub GVAL
   If Z=ZN_OK and Fn MOUSEDOWN
      PZN=Z : BX=RX : Gosub PRESS
      If _ON
         REQ=True
         _EXIT=True
      End If 
   Else If Z=ZN_CANCEL and Fn MOUSEDOWN or Fn KEY_ESC
      PZN=Z : BX=RX+106 : Gosub PRESS
      If _ON
         REQ=False
         _EXIT=True
      End If 
   Else If Z=ZN_FX and Fn MOUSEDOWN and FXRUN$<>_$
      Repeat 
         Gosub FXSET
         Gosub FXRUN$
         Gosub FXDRW
         Gosub KCHOOSE
      Until Fn MOUSEUP
   Else If Fn MOUSEDOWN
      Gosub BCHOOSE
   Else If Fn KEY_PRESS
      Gosub KCHOOSE
   End If 
   Gosub DISPATCH
Until _EXIT
Gosub MUP
Gosub _CLOSEFXWIN
Gosub WINC
REALTIME=False : CHAIN$(1)=_$ : _CHANNEL=1
If REQ
   Gosub _UNDOSET
End If 
Return 
'
_TEXTINPUT:
If(( Fn KEY_PRESS and C<59) or Fn KEY_SPACE) and N<_MAX
   T$=Left$(T$,N)+K$+Right$(T$,Len(T$)-N)
   Inc N
End If 
If Fn KEY_LEFT and N>0
   Dec N
Else If Fn KEY_BACKSPACE and N>0
   Dec N
   T$=Left$(T$,N)+Right$(T$,(Len(T$)-1)-N)
Else If Fn KEY_DEL and N<Len(T$)-1
   T$=Left$(T$,N)+Right$(T$,(Len(T$))-N-1)
Else If Fn KEY_DEL and N<Len(T$)
   T$=Left$(T$,N)
Else If Fn KEY_RIGHT and N<Len(T$)
   Inc N
End If 
If TXT_X=0 Then Return 
Ink _BLACK,_WHITE
Text X+TXT_X-Text Length(TXT1$),TXT_Y,TXT1$+T$+_SPACER$
Gr Writing %10
Text X+TXT_X+(N*8),TXT_Y,_SCORE$
Gr Writing %1
Return 
'
_RUNFXTEXTWIN:
_TEXT=True : _EXIT=False
T$=_$
TXT_X=340 : TXT_Y=Y+72 : N=0 : _MAX=9
Repeat 
   Gosub _TEXTINPUT
   Repeat 
      Gosub GVAL
      If Z=ZN_OK and Fn MOUSEDOWN or Fn KEY_RETURN
         PZN=Z : BX=RX+2 : Gosub PRESS
         If _ON
            REQ=True
            _EXIT=True
         End If 
      Else If Z=ZN_CANCEL and Fn MOUSEDOWN or Fn KEY_ESC
         PZN=Z : BX=RX+108 : Gosub PRESS
         If _ON
            REQ=False
            _EXIT=True
         End If 
      End If 
   Until _EXIT or C
Until _EXIT
Gosub _CLOSEFXWIN
Goto WINC
'
FXDRW:
Ink _WHITE,_SHADOW
N=Text Length(Str$(FXSN)-_SPACE$)+Text Length(FXS$)
Text RX+204-N,RY-5,Space$(Len(Str$(FXSN)-_SPACE$))
Text RX+212-N,RY-5,Str$(FXSN)-_SPACE$+FXS$
Ink _BG
Bar RX+1,RY+6 To RX+209,RY+6+BUT_H
Ink _GRAY
Bar RX+1+FXN,RY+6 To RX+1+FXN+8,RY+6+BUT_H
Set Zone ZN_FX,RX+FXN,RY+6 To RX+FXN+10,RY+6+BUT_H
Return 
'
FXSET:
Gosub TESTMOVE
FXN=CX-224
If FXN=<0
   FXN=0
Else If FXN>199
   FXN=200
End If 
Return 
'  
SETREALTIME:
If REALTIME or MACRO
   FXSHOW=False
Else 
   FXSHOW=True
End If 
Return 
'  
'
'
'***************************************************************************** 
'*buttons********************************************************************* 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
' :::::::.   ...    :::::::::::::::::::::::    ...     ::.    :::. .::::::.  
'  ;;;'';;' ';;     ;;;;;;;;;;''';;;;;;;''' .;;;;;;;.  ;;;;,  `;;;;;;`    `; 
'  [[[__[[\.[['     [[[    [[        [[    ,[[     \[[, [[[[[. '[['[==/[[[[, 
'  $$""""Y$$$$      $$$    $$        $$    $$$,     $$$ $$$ "Y$c$$  '''    $ 
' _88o,,od8P88    .d888    88,       88,   "888,_ _,88P888    Y88 ,88b    dP 
' ""YUMMMP"  "YmmMMMM""    MMM       MMM     "YMMMMMP" MM     YM    "YMmMY"  
'
'
'
ALLBTN:
_COL=_PANE
BZN=ZN_PLAY
Repeat 
   Gosub ZBTN
   Inc BZN
Until BZN>ZN_PLAY+_AB-2
Gosub LPBTN
Goto LPMIXBTN
'
PLYBTN:
Gosub GFXSET
_COL=_WHITE
If RNGEPLY
   BZN=ZN_PLAYRANGE : Gosub ZBTN
End If 
If DISPPLY
   BZN=ZN_PLAYDISPLAY : Gosub ZBTN
End If 
BTXT1$="Play|Stop" : BZN=ZN_PLAY : BX=BUTX(BZN-ZN_PLAY) : BY=BUTY(BZN-ZN_PLAY) : Gosub BTN
Goto GFXRESTORE
'
_TGLLOOP:
If _LP Then _LP=False Else _LP=True
LPBTN:
If _LP Then _COL=_WHITE Else _COL=_PANE
BZN=ZN_LOOP : Goto ZBTN
'
_TGLMIXLOOP:
If _LPMIX Then _LPMIX=False Else _LPMIX=True
LPMIXBTN:
If _LPMIX Then _COL=_WHITE Else _COL=_PANE
BZN=ZN_MIXLOOP : Goto ZBTN
'
_REPEAT:
If _REPEAT$=_$
   TXT1$="No subroutine to" : TXT2$="repeat" : Goto _ERROR
End If 
Gosub _UNDOSET
T$=_REPEAT$
_TOAST$=T$
MACRO=True
_REPEATING=True
Gosub CMD
_REPEATING=False
MACRO=False
Return 
'
GRAYBTN:
Ink _GRAY
Goto B
'
ZBTN:
BTXT1$=BUTS$(BZN-ZN_PLAY) : BX=BUTX(BZN-ZN_PLAY) : BY=BUTY(BZN-ZN_PLAY)
'
BTN:
Ink _BLACK
B:
Box BX,BY To BX+BUT_W,BY+BUT_H
Ink _COL+4 : Box BX+1,BY+1 To BX+BUT_W-1,BY+BUT_H-1
Ink _COL,-1 : Bar BX+2,BY+2 To BX+BUT_W-2,BY+BUT_H-2
Ink _BLACK,_COL : Text BX+((BUT_W-(Text Length(BTXT1$)))/2)+1,BY+BUT_H-4,BTXT1$
Set Zone BZN,BX,BY To BX+BUT_W,BY+BUT_H
Return 
'
PRESSBTN:
BX=BUTX(PZN-ZN_PLAY) : BY=BUTY(PZN-ZN_PLAY)
PRESS:
_ON=True
Gosub HIGHBTN
Repeat 
   If C=0 Then Gosub TESTMOVE Else Gosub MKEY
   If PZN<>Z and _ON
      _ON=False
      Gosub HIGHBTN
   Else If PZN=Z and _ON=False
      _ON=True
      Gosub HIGHBTN
   End If 
Until Fn MOUSEUP
If Not _ON Then Return 
'
HIGHBTN:
Gr Writing %10
Bar BX,BY To BX+BUT_W,BY+BUT_H
Gr Writing %1
Return 
'
TAB:
Ink _COL
Bar TAB_BX,TAB_BY To TAB_BX+22,TAB_BY+14
Ink _GRAY,_COL
Text TAB_BX+8,TAB_BY+10,OT$
Set Zone BZN,TAB_BX,TAB_BY To TAB_BX+23,TAB_BY+15
Return 
'  
'
'
'***************************************************************************** 
'*gadgets********************************************************************* 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    .,-:::::/    :::.     ::::::-.   .,-:::::/  .,:::::::::::::::: .::::::. 
'   ;;-'````'     ;;`;;    ;;,   `';,;;-'````'   ;;;;'''';;;;;;;''';;;`    `;
'   [[   [[[[[[/ ,[[ '[[,  `[[     [[[[   [[[[[[/ [[cccc     [[    '[==/[[[[,
'   $$c.    "$$ c$$$cc$$$c  $$,    $$$$c.    "$$  $$""""     $$      '''    $
'   `Y8bo,,,o88  888   888, 888_,o8P'`Y8bo,,,o88  888oo,_    88,   ,88b    dP
'     `'YMUP"YMM YMM   ""` "MMMMP"`    `'YMUP"YMM """"YUM    MMM     "YMmMY" 
'
'
'
SETHZ:
PBSIZE=BSIZE
If _AMIHZ
   PERIOD=CLOCK/FREQ
   FREQ=CLOCK/PERIOD
   BSIZE=Int(FREQ/MONHZ#)
   If FREQ>MFREQ
      FREQ=MFREQ
      BSIZE=Int(FREQ/MONHZ#)
      FREQ=BSIZE*MONHZ#
      PERIOD=CLOCK/FREQ
   End If 
Else 
   BSIZE=Int(FREQ/MONHZ#)
   FREQ=BSIZE*MONHZ#
   PERIOD=CLOCK/FREQ
End If 
Doke $DFF0A6,PERIOD
Doke $DFF0B6,PERIOD
Doke $DFF0C6,PERIOD
Doke $DFF0D6,PERIOD
Gosub DRWTIME
ROT#(0)=(((FREQ-601)/13.3)/(256+184))+8.5
If Fn MULTI Then Gosub CLREMPTY
_AMIHZ=True
Return 
'
AMIHZDIAL:
DIA_X=134
DIA_Y=WVE_H+34
Ellipse DIA_X,DIA_Y,15,9
Return 
'
SCR0LL:
If _TEXT or SETTING$(24)=_FALSE$ Then Return : Rem scroller 
Scroll 2
Return 
'
R4INBOW:
Set Rainbow 0,_PANE,WVE_H+1,_$,_$,_$
Return 
'
R4INSET:
WVE_D=WVE_H/_CH
BBARS=0 : CBARS=0
Repeat 
   Inc BBARS
   CCOLS=CBARS
   Repeat 
      If B=BBARS Then CCOL=Colour(_PANE)+$111 Else CCOL=Colour(_PANE)
      Rain(0,CCOLS)=CCOL
      Inc CCOLS
   Until CCOLS>CBARS+WVE_D
   Add CBARS,WVE_D
Until CBARS>WVE_D*(_CH-1)
Rainbow 0,0,56,WVE_H
Return 
'  
R4INRESTORE:
CBARS=0
Repeat 
   Rain(0,CBARS)=Colour(_PANE)
   Inc CBARS
Until CBARS>WVE_H-1
Rainbow 0,0,56,WVE_H
Return 
'  
FLSHR4IN:
CBARS=0
Repeat 
   Rain(0,CBARS)=Colour(_HIGHLIGHT)
   Inc CBARS
Until CBARS>WVE_H-1
Rainbow 0,0,56,WVE_H
Return 
'
T0ASTWAITER:
If _TOASTWAIT>0
   Inc _TOASTWAIT
   If _TOASTWAIT>5
      _TOASTWAIT=0
      Goto FLSHSCRC
   End If 
End If 
Return 
'
T0AST:
_T=Len(_TOAST$)
If Len(_TOAST$)>24
   _TOAST2$=Right$(_TOAST$,Len(_TOAST$)-24)
   _TOAST$=Left$(_TOAST$,24)
Else 
   _TOAST2$=_$
End If 
Repeat 
   Scroll 1
   Dec _T
Until _T<1
Gosub GFXSET
Ink _SHADOW,_PANE
Text TST_W-Text Length(_TOAST$),TST_T,_TOAST$
_TOAST$=_TOAST2$
Goto GFXRESTORE
'
CONTROLS:
Ink _PANE
Bar 0,WVE_H+HDR_H To SCR_W,SCR_H
Gosub MAGICWAND
Gosub ALLBTN
If PLYING or BGPLYING
   Gosub PLYBTN
End If 
Gosub DRWTIMENOW
Gosub DRWHZ
Goto DIALMAIN
'
DIALMAIN:
I=0
DIA_X=120 : DIA_Y=WVE_H+26
DIA_W=33 : DIA_C=0
Repeat 
   Gosub DIALS
   Inc I : Inc DIA_C
Until I>1
Return 
'  
DIALRES:
I=2
DIA_X=220 : DIA_Y=HDR_H+52
DIA_W=104 : DIA_C=0
Ink _GRAY,_WHITE
Text DIA_X+39,DIA_Y+14,"Freq.        Q."
Repeat 
   Gosub DIALS
   Inc I : Inc DIA_C
Until I>3
Return 
'  
DIALCOMP:
I=4
DIA_X=228 : DIA_Y=HDR_H+52
DIA_W=104 : DIA_C=0
Ink _GRAY,_WHITE
Text DIA_X+39,DIA_Y+14,"Thres.       Slope"
Text DIA_X+39,DIA_Y+37,"Window       Ahead"
Text DIA_X+39,DIA_Y+60,"Attack       Re."
Repeat 
   Gosub DIALS
   If I=5 or I=7
      DIA_Y=DIA_Y+23
      DIA_C=DIA_C-2
   End If 
   Inc I : Inc DIA_C
Until I>9
Return 
'  
DIALT0NE:
I=10
DIA_X=228 : DIA_Y=HDR_H+32
DIA_W=104 : DIA_C=0
Ink _GRAY,_WHITE
Text DIA_X+39,DIA_Y+14,"Freq.        Amp."
Repeat 
   Gosub DIALS
   Inc I : Inc DIA_C
Until I>11
Return 
'
DIALS:
Paste Bob DIA_X+(DIA_W*DIA_C),DIA_Y,1
ROTX(I)=DIA_X+14+(DIA_W*DIA_C) : ROTY(I)=DIA_Y+8
ROTX2(I)=ROTX(I)+16 : ROTY2(I)=ROTY(I)+10
STRTX=ROTX(I) : STRTY=ROTY(I)
DESTX=STRTX+7.0*Cos(ROT#(I)) : DESTY=STRTY+5.0*Sin(ROT#(I))
Ink _SHADOW
Draw STRTX,STRTY To DESTX,DESTY
STRTX=STRTX+3.5*Cos(ROT#(I)) : STRTY=STRTY+2.5*Sin(ROT#(I))
Ink _BLACK
Draw STRTX,STRTY To DESTX,DESTY
Return 
'
DIALSET:
PY=CY
PX=CX
PROT#=ROT#(0) : Rem frequency dial click for AMIHZ 
Repeat 
   Gosub TESTMOVE
   If Fn KEY_PRESS
      Gosub KCHOOSE
   End If 
   If Fn KEY_SHIFT
      If CY>PY and _HIGHDIAL=False
         _INC#=0.0075
      Else 
         If _HIGHDIAL
            _INC#=0.0275
         Else 
            _INC#=0.01
         End If 
      End If 
   Else 
      _INC#=0.1
   End If 
   Gosub STICKY
   If CY<PY
      ROT#(_DIAL)=ROT#(_DIAL)+(_INC#*(PY-CY))
      If ROT#(_DIAL)>13.3
         ROT#(_DIAL)=13.3
      End If 
   Else If CY>PY
      ROT#(_DIAL)=ROT#(_DIAL)-(_INC#*((CY-PY)))
      If ROT#(_DIAL)<8.5
         ROT#(_DIAL)=8.5
      End If 
   End If 
   PY=CY
   PX=CX
   If _DIAL=1
      VOL=Int((ROT#(_DIAL)-8.5)*13.3334)
      Gosub SETVOL
   Else If _DIAL=0
      FREQ=(((ROT#(_DIAL)-8.5)*13.3)*(256+184))+601
      If Fn MOUSEUP and PROT#=ROT#(_DIAL)
         If _HIGHDIAL : Rem double click 
            _HIGHDIAL=False
            Ink _PANE
            _AMIHZ=False
         Else 
            _HIGHDIAL=True
            Ink _SHADOW
         End If 
      Else If _HIGHDIAL
         Ink _SHADOW
      Else 
         Ink _PANE
         _AMIHZ=False
      End If 
      Gosub AMIHZDIAL
      Gosub SETHZ
      If RENDERING
         Gosub DRWHZ
         Gosub DRWTIMENOW
      End If 
      Gosub DIALMAIN
   Else If _DIAL=3
      _RQ#=(ROT#(_DIAL)-8.5)/4.8
      Gosub RESET
      Gosub DIALRES
   Else If _DIAL=2
      RESN=Int(((ROT#(_DIAL)-8.5)/4.8)*200.0)
      Gosub RESET
      Gosub DIALRES
   Else If _DIAL=4
      _THRESHOLDN#=((ROT#(_DIAL)-8.5)/4.8)*100.0
      Gosub CPSET
      Gosub DIALCOMP
   Else If _DIAL=5
      _SLOPEN#=((ROT#(_DIAL)-8.5)/4.8)*100.0
      Gosub CPSET
      Gosub DIALCOMP
   Else If _DIAL=6
      _WINDOWN#=((ROT#(_DIAL)-8.5)/4.8)
      Gosub CPSET
      Gosub DIALCOMP
   Else If _DIAL=7
      _LOOKAHEADN#=((ROT#(_DIAL)-8.5)/4.8)*100.0
      Gosub CPSET
      Gosub DIALCOMP
   Else If _DIAL=8
      _ATTACKN#=((ROT#(_DIAL)-8.5)/4.8)*10.0
      Gosub CPSET
      Gosub DIALCOMP
   Else If _DIAL=9
      _RELEASEN#=((ROT#(_DIAL)-8.5)/4.8)*500.0
      Gosub CPSET
      Gosub DIALCOMP
   Else If _DIAL=10 and Fn KEY_CURSOR
      Gosub T0NEUPDOWN
      Gosub DIALT0NE
   Else If _DIAL=10
      T0NEV#=Int((((ROT#(_DIAL)-8.5)/4.8)*(FREQ/8))+5)
      Gosub T0SET
      Gosub DIALT0NE
   Else If _DIAL=11
      T0NEA=((ROT#(_DIAL)-8.5)/4.8)*127
      Gosub DIALT0NE
   End If 
Until Fn MOUSEUP
Return 
'
DRWDIALS:
_DIAL=0
Repeat 
   If Fn DIALZONE Then Goto DIALSET
   Inc _DIAL
Until _DIAL>1
If CHAIN$(1)="_RESONANTP"
   _DIAL=2
   Repeat 
      If Fn DIALZONE
         Goto DIALSET
      End If 
      Inc _DIAL
   Until _DIAL>3
Else If CHAIN$(1)="_COMPRESSORP"
   _DIAL=4
   Repeat 
      If Fn DIALZONE
         Goto DIALSET
      End If 
      Inc _DIAL
   Until _DIAL>9
Else If T0NEGENERATOR
   _DIAL=10
   Repeat 
      If Fn DIALZONE
         Goto DIALSET
      End If 
      Inc _DIAL
   Until _DIAL>11
End If 
Return 
'
SETVOL:
Volume PAULA(_CH+3),VOL
If Fn MOUSEUP
   If VOL=64
      _TOAST$=_TOAST$+"Full"
   Else If VOL=0
      _TOAST$=_TOAST$+"Mute"
   Else 
      _TOAST$=_TOAST$+Str$(VOL)-_SPACE$
   End If 
End If 
Goto DIALMAIN
'  
PROBAR:
If FX=FX_START or FX>=FXE or REALTIME Then Return 
Gosub KEY
If Fn KEY_ESC
   FX=FXE : _STOP=True
   Return 
End If 
PRO#=FX-FX_START : PRO=Int((PRO#/FX_LENGTH)*128)
If PRO<1 or PRO>126 Then Return 
If OSCILLO
   If Not TGL
      PPRO=PRO-1
   End If 
End If 
If PPRO-PRO
   Ink _SHADOW
   Box 255,71 To 256+128,78
   Bar 256,72 To 256+PRO,77
   Ink _BLACK
   Bar 256+PRO,72 To 256+127,77
   PPRO=PRO
End If 
Return 
'
METRO:
Ink _HIGHLIGHT
Bar MET_X,MET_Y To MET_W,MET_H
Return 
'
METROC:
Ink _PANE
Bar MET_X,MET_Y To MET_W,MET_H
Return 
'
LEV:
If RENDERING or _MENUDO or _DIRECT Then Return 
If Fn MULTI
   If Fn INVIEW
      OSC_START=P_BUF+(BSIZE*(B-1))
   Else 
      Return 
   End If 
Else 
   OSC_START=P_BUF
End If 
PI=0
If OSCILLO
   Gosub OSC_BCK
   Ink _BRIGHT
   OI=0 : PI=0 : PPI#=0
   OSC#=256.0/BSIZE
   If Fn MONO or Fn MULTI
      If OSCILLO>2
         OSCILLO=1
      End If 
      If OSC#>1.7
         OSCLOW=True
      Else 
         OSCLOW=False
      End If 
      '
      '********************
      ' oscilloscope 
      Repeat 
         OSC_X=Peek(OSC_START+PI)
         If OSC_X>127
            OSC_X=OSC_X-256
         End If 
         Plot OI+OSC_W-128,(OSC_X/2)+77
         If OSCLOW
            If POI<>OI
               Draw To OI+OSC_W-(128-OSC#),(OSC_X/2)+77
               POI=OI
            End If 
         End If 
         PPI#=PPI#+OSC# : OI=Int(PPI#)
         Inc PI
      Until PI>=BSIZE
   Else 
      '  
      '********************
      ' x/y oscilloscope 
      Repeat 
         OSC_X=Peek(OSC_START+PI)
         If OSC_X>127
            OSC_X=OSC_X-256
         End If 
         OSC_Y=Peek(OSC_START+BSIZE+PI)
         If OSC_Y>127
            OSC_Y=OSC_Y-256
         End If 
         On OSCILLO Gosub O1,O2,O3,O4,O5
         PPI#=PPI#+OSC# : OI=Int(PPI#)
         Inc PI
      Until PI>=BSIZE
   End If 
End If 
If _LEVEL
   If Fn A1200
      '  
      '********************
      ' peak level meter 
      LML=0
      PI=0
      Repeat 
         LMN=(Peek(OSC_START+PI)*32)/256
         If LMN>15
            LMN=LMN-32
         Else 
            LMN=-LMN
         End If 
         If LMN<LML
            LML=LMN
         End If 
         Add PI,10
      Until PI>LMC
   Else 
      '  
      '********************
      ' rms level meter  
      LMC=BSIZE
      If Fn STEREO
         LMC=LMC*2
      Else If Fn QUAD
         LMC=LMC*4
      End If 
      SUMM#=0.0
      PI=0
      Repeat 
         LMN#=Peek(OSC_START+PI)
         If LMN#>127
            LMN#=LMN#-256
         End If 
         LMN#=LMN#/127
         SUMM#=SUMM#+(LMN#*LMN#)
         Inc PI
      Until PI>LMC
      LML=-Int(Sqr(SUMM#/LMC)*16)
   End If 
   Gosub LEVC
   Ink _HIGHLIGHT
   DRWLEV:
   Gosub GFXSET
   Bar LEV_X,LEV_Y+LML To LEV_W,LEV_Y+1
   Gosub GFXRESTORE
End If 
Return 
'
LEVC:
Scroll 3
Return 
'
OSC_BCK:
_COL=_BLACK
OT$="×" : BZN=ZN_OSCCLOSE : TAB_BX=OSC_W+133 : TAB_BY=13 : Gosub TAB
OT$=Str$(OSCILLO)-_SPACE$ : BZN=ZN_OSCMODE : TAB_BY=30 : Gosub TAB
Ink _COL
Bar OSC_W-128,13 To OSC_W+127,140
Return 
'
O1: Plot OSC_Y+OSC_W,-(OSC_X/2)+76 : Return 
O2: Plot OSC_X+OSC_W,-(OSC_Y/2)+76 : Return 
O3: OSC_N=((OI+128))+64 : Plot OSC_N,(OSC_X/2)+77 : Plot OSC_N,(OSC_Y/2)+77 : Return 
O4: Plot -OSC_Y+OSC_W-1,(OSC_X/2)+77 : Return 
O5: Plot -OSC_X+OSC_W-1,(OSC_Y/2)+77 : Return 
'
_TGLOSCILLOSCOPE:
Gosub MUP
If OSCILLO
   OSCILLO=False
   I=ZN_OSCCLOSE : N=ZN_OSCMODE : Gosub RESETZN
   Gosub _SHOWCOPY
Else 
   OSCILLO=1
   Gosub OSC_BCK
End If 
REQ=True
Return 
'
_TGLOSCILLOMODE:
Gosub MUP
Inc OSCILLO
If Fn MONO or Fn MULTI
   OSCILLO=1
Else 
   If OSCILLO>5
      OSCILLO=1
   End If 
End If 
Return 
'
_TGLCALCULATOR:
Gosub MUP
If CALC
   CALC=False
   Gosub _SHOWCOPY
Else 
   CALC=True
   Gosub CAL_BCK
End If 
REQ=True
Return 
'
CAL_BCK:
If Not CALC Then Return 
Gosub GFXSET
Ink _BLACK
Bar CAL_X,CAL_Y To CAL_W,CAL_Y+CAL_H
If Fn MULTI Then CI=Length(B+7) Else CI=Length(PBANK)
Gosub CAL_MUL
If CI>0
   Gosub CAL_LEN
   Ink _PANE,_BLACK
   Text CAL_X,CAL_Y+11,Str$(B)+Str$(CI)
   Text CAL_X,CAL_Y+19,Str$(B)+Str$(CDIV#)+_BPM$
End If 
CI=Length(LB+7)
Gosub CAL_MUL
If CI>0
   Gosub CAL_LEN
   Ink _SHADOW,_BLACK
   Text CAL_X,CAL_Y+30,Str$(LB)+_»$+Str$(CI)
   Text CAL_X,CAL_Y+38,Str$(LB)+_»$+Str$(CDIV#)+_BPM$
End If 
CHI_X=CAL_W-66
CHI_Y=CAL_Y+2
Paste Bob CHI_X,CHI_Y,7 : Rem 64x40 21x13x9  
_COL=_BLACK
OT$="×" : BZN=ZN_CALCLOSE : TAB_BX=CAL_W+6 : TAB_BY=WVE_H+9-CAL_H : Gosub TAB
POC=9 : NC=0
Repeat 
   CI=0
   Repeat 
      If POS=POC
         Ink _HIGHLIGHT
         Box CHI_X+(CI*21)+1,CHI_Y+(NC*13)+1 To CHI_X+(CI*21)+21-1,CHI_Y+(NC*13)+13-1
         Ink _BG
         Box CHI_X+(CI*21)+2,CHI_Y+(NC*13)+2 To CHI_X+(CI*21)+21-2,CHI_Y+(NC*13)+13-2
         Gosub GFXRESTORE
         Return 
      End If 
      Inc CI
      Dec POC
   Until CI>2
   Inc NC
Until NC>2
Goto GFXRESTORE
'
CAL_DRW:
POC=9 : NC=0
Repeat 
   CI=0
   Repeat 
      If Fn MOUSEDOWN and POS-POC
         If CX>CHI_X+(CI*21)+1 and CX<CHI_X+(CI*21)+21-1 and CY>CHI_Y+(NC*13)+2 and CY<CHI_Y+(NC*13)+13-2
            POS=POC
            Gosub CAL_BCK
            Gosub MUP
            Return 
         End If 
      End If 
      Inc CI
      Dec POC
   Until CI>2
   Inc NC
Until NC>2
Return 
'
CAL_LEN:
CDIV#=FREQ
CDIV#=((CDIV#/CI)*60)*4
Return 
'
CAL_MUL:
On POS Goto C1,C2,C3,C4,C5,C6,C7,C8,C9
C1: Return 
C2: CI=CI-(CI/4) : Return 
C3: CI=CI-(CI/3) : Return 
C4: CI=CI/4 : Return 
C5: CI=CI/3 : Return 
C6: CI=CI/2 : Return 
C7: CI=CI*4 : Return 
C8: CI=CI*3 : Return 
C9: CI=CI*2 : Return 
'
'
'
'***************************************************************************** 
'*network********************************************************************* 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'   ::.    :::..,::::::::::::::::.::    .   .::    ...     :::::::..  ::::::  .  
'   ;;;;,  `;;;;;;;'''';;;;;;;'''';;,  ;;  ;;;' .;;;;;;;.  ;;;;``;;;; ```;;; .;;,  
'    [[[[[. '[[ [[cccc     [[     '[[, [[, [[' ,[[     \[[,\[[[,/[[['    [[[[[/' 
'    $$$ "Y$c$$ $$""""     $$       Y$c$$$c$P  $$$,     $$$"$$$$$$c     _$$$$, 
'   888    Y88  888oo,_    88,       "88"888   "888,_ _,88P,888b "88bo "888"88o, 
'   MM     YM   """"YUM    MMM        "M "M"     "YMMMMMP" "MMMM   "W" MMM "MMP""  
'
'   BSDSocket.library Procedures originally by Internext Software (John Bintz) 
'
SOCK_SETIO:
Areg(0)=Varptr(T$)
Dreg(1)=Len(T$)
CONNECT=Lib Call(2,-$36) : Rem _LVOconnect
Dreg(1)=$8004667E : Rem FIONBIO
Gosub SOCK_IO
Dreg(1)=$8004667D : Rem FIOASYNC 
SOCK_IO:
NB=1
Areg(0)=Varptr(NB)
NB=Lib Call(2,-$72) : Rem_LVOIoctlSocket 
Return 
'
SOCK_HOST:
NB=Lib Call(2,-$D2) : Rem _LVOgethostbyname  
NB=Leek(Leek(Leek(NB+16))) : Rem HOSTADDRESS
T$=Chr$(16)+Chr$(2)+String$(_NULL$,14)
Loke Varptr(T$)+4,Leek(Varptr(NB))
Return 
'
SOCK_SEND:
Dreg(2)=0
NB=Lib Call(2,-$42) : Rem _LVOsend 
Return 
'
SOCK_OPENSYNC:
Dreg(0)=2
Dreg(1)=2 : Rem UDP
Dreg(2)=0
SOCKSYNC=Lib Call(2,-$1E) : Rem _LVOsocket 
Areg(0)=Varptr(_ADDRSYNC$)
Gosub SOCK_HOST
Doke Varptr(T$)+2,Deek(Varptr(_PORTSYNC)+2)
Dreg(0)=SOCKSYNC
Goto SOCK_SETIO
'
SOCK_SENDSYNC:
Dreg(0)=SOCKSYNC
Areg(0)=Varptr(MSG$)
Dreg(1)=32
Goto SOCK_SEND
'
SOCK_CLOSESYNC:
If SOCKSYNC--1
   Dreg(0)=SOCKSYNC
   NB=Lib Call(2,-$78) : Rem _LVOCloseSocket
End If 
Return 
'  
SOCK_OPENVST:
Dreg(0)=2
Dreg(1)=2 : Rem UDP
Dreg(2)=0
SOCKVST=Lib Call(2,-$1E) : Rem _LVOsocket 
Areg(0)=Varptr(_ADDRVST$)
Gosub SOCK_HOST
Doke Varptr(T$)+2,Deek(Varptr(_PORTVST)+2)
Dreg(0)=SOCKVST
Goto SOCK_SETIO
'
SOCK_SENDVSTUP:
VCH=_CHANNELS
If Fn MULTI Then VCH=4
VCH$=Str$(VCH)-_SPACE$
Dreg(0)=SOCKVST
Areg(0)=Varptr(VCH$)
Dreg(1)=1
Goto SOCK_SEND
'
SOCK_SENDVST:
Dreg(0)=SOCKVST
Areg(0)=P_BUF
Dreg(1)=BSIZE*VCH
Goto SOCK_SEND
'  
SOCK_CLOSEVST:
If SOCKVST--1
   Dreg(0)=SOCKVST
   NB=Lib Call(2,-$78) : Rem _LVOCloseSocket
End If 
Return 
'
'
'
'***************************************************************************** 
'*init************************************************************************ 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    :::  ::.    :::. :::  ::::::::::  
'    ;;;  ;;;;,  `;;; ;;;  ;;;;;;;'''  
'    [[[   [[[[[. '[[ [[[      [[      
'    $$$,  $$$ "Y$c$$ $$$,     $$      
'   o88888888    Y88 o88888    88,     
'   MMM"MMMM     YM  MMM"MM    MMM     
'
'
'
_INIT:
_INIT=False
Restore DTA
I=1
Repeat 
   Read PAULA(I)
   Inc I
Until I>_CH+3
I=0
If Exist(CFGFILE$)
   Trap Open In 1,CFGFILE$
   If Not Errtrap
      N=Lof(1) : T$=Space$(N)
      Sload 1 To Varptr(T$),N : Close 1
      PX=1
      Repeat 
         CX=Instr(T$,_COMMA$,PX)
         MX=Instr(T$,_NEWLINE$,PX)
         If CX and CX<MX
            MX=CX
         End If 
         If MX
            SETTING$(I)=Mid$(T$,PX,MX-PX)
         End If 
         Inc MX : Inc I
         PX=MX
      Until PX>=N
   End If 
End If 
N=1
Repeat 
   If N<I
      Read T$
   Else 
      Read SETTING$(N)
   End If 
   Inc N
Until N>_OP
I=1
Repeat 
   DEVS$(I)=SETTING$(I)
   Inc I
Until I>4
RXDIR$=SETTING$(5)
_ADDRSYNC$=SETTING$(6)
_PORTSYNC=Val(SETTING$(7))
_ADDRVST$=SETTING$(8)
_PORTVST=Val(SETTING$(9))
CN=Deek(Leek(4)+296) : Rem cpu
I=0 : N=0
Repeat 
   If Btst(I,CN) Then N=I+1
   Inc I
Until I>3
If N=0 : Rem 68000
   _AMIVER=1
Else If N=2 : Rem 68020
   _AMIVER=3
Else 
   _AMIVER=5
End If 
If Fast Free>0 Then Inc _AMIVER
If Fn A1200
   If Fn A500
      SCR_D=4
   End If 
   SETTING$(16)=_FALSE$ : Rem position marker
   SETTING$(17)=_FALSE$ : Rem level meter
   SETTING$(18)=_FALSE$ : Rem metronome
   SETTING$(19)=_FALSE$ : Rem realtime preview 
   SETTING$(20)=_FALSE$ : Rem zoom draw
   SETTING$(21)=_TRUE$ : Rem graph low
   SETTING$(22)=_FALSE$ : Rem mouse wheel zoom 
   SETTING$(24)=_FALSE$ : Rem scroller 
   SETTING$(26)=_FALSE$ : Rem quantizer
End If 
If SCR_D=4
   _HIGHLIGHT=_GRAY
   _BLACK=_BG
   _SHADOW=_GRAY
End If 
If Ntsc
   SCR_H=200
   SETTING$(11)=_FALSE$ : Rem 50hz/60hz
   SETTING$(24)=_FALSE$ : Rem scroller 
End If 
HDR_H=11 : WVE_H=SCR_H-HDR_H-69 : WVE_W=SCR_W-1
_DSTEP=-WVE_H/8 : WVE_D=WVE_H/_CH
DIV_T=HDR_H+1 : DIV_B=HDR_H+WVE_H-1
DIV_U=HDR_H+WVE_D+1 : DIV_L=HDR_H+(WVE_D*3)-1
POS_T=HDR_H+1 : POS_H=WVE_H/_CH
RNG_B=WVE_H
NFO_H=WVE_H+40
WND_Y=HDR_H+WVE_H+1 : WND_H=WND_Y+8
LEV_X=13 : LEV_W=LEV_X+15 : LEV_Y=HDR_H+WVE_H+28
TST_X=SCR_W-210 : TST_W=SCR_W-10
TST_Y=HDR_H+WVE_H+13 : TST_H=HDR_H+WVE_H+20 : TST_T=TST_Y+6
MET_X=SCR_W-30 : MET_W=SCR_W-14 : MET_Y=WVE_H+35 : MET_H=WVE_H+40
XD2=SCR_W : PXD2=XD2
OSC_W=SCR_W/2
CAL_X=395 : CAL_Y=WVE_H-34 : CAL_W=CAL_X+212 : CAL_H=43
'
'
'
'***************************************************************************** 
'*screen********************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    .::::::.   .,-:::::::::::::..  .,::::::.,::::::::.    :::.  
'   ;;;`    `;,;;;'````' ;;;;``;;;; ;;;;'''';;;;'''';;;;,  `;;;  
'   '[==/[[[[,[[[        \[[[,/[[['  [[cccc  [[cccc  [[[[[. '[[  
'     '''    $$$$        "$$$$$$c    $$""""  $$""""  $$$ "Y$c$$  
'   ,88b    dP`88bo,__,o,,888b "88bo 888oo,_ 888oo,_888    Y88   
'     "YMmMY"   "YUMMMMMP"MMMM   "W" """"YUM """"YUMMM     YM    
'
'
'
Auto View Off : Every Off 
Screen Open 1,SCR_W,WVE_H,SCR_D,SCR_R : Screen Hide 1
Flash Off : Curs Off 
Screen Open 0,SCR_W,SCR_H,SCR_D,SCR_R
Flash Off : Curs Off 
Limit Mouse 128,44 To 448,44+SCR_H
Def Scroll 1,TST_X+8,TST_Y To TST_W+1,TST_H+1,-8,0
Def Scroll 2,TST_X,TST_Y To TST_W+1,TST_H+1,-1,0
Def Scroll 3,LEV_X,LEV_Y-17 To LEV_W+2,LEV_Y+1,0,1
Reserve Zone ZN_RIGHTRANGESPACE
Set Zone ZN_TOAST,TST_X,TST_Y To TST_W,TST_H
I=0
Repeat 
   Read BUTS$(I),BUTX(I),BUTY(I),BUTG$(I)
   BUTY(I)=SCR_H-BUTY(I)
   Inc I
Until I>_AB
I=0
Repeat 
   Read CMD$(I),CMDG$(I)
   Inc I
Until I>_CM
I=0
Repeat 
   Read N,T$,N
   CHROM$(I)=Left$(T$,2)
   Inc I
Until I>13
If Arexx Exist("REXX")
   If Not REXX
      Trap Arexx Open FXBOX_REXX$
      If Not Errtrap and Arexx Exist(FXBOX_REXX$)
         REXX=True
      End If 
   End If 
End If 
Gosub SETFILTER : Gosub SETMON : Gosub SETLIGHTMODE : Gosub SETDEBUG
Gosub SETNETSYNC : Gosub SETHIRES : Gosub SETPOSITION : Gosub SETLEVELMETER
Gosub SETMETRONOME : Gosub SETPREVIEW : Gosub SETGRAPH
Gosub SETAREXXSYNC : Gosub SETVST
Gosub SETPOINT2
Screen Display 0,128,-220,320,SCR_H
View : Gosub TASK
_INIT=True
Gosub R4INBOW
Gosub INITMENU
Gosub _MACROMENU
If Exist(SEQDIR$)
   Dir$=SEQDIR$
   SEQDIR$=Dir$
   Dir$=PROGDIR$
End If 
Gosub HEADER
Gosub _DRAW
Gosub MAGICWAND
Gosub SETHZ
Gosub DIALMAIN
Ink _SHADOW : Gosub AMIHZDIAL : _HIGHDIAL=True
Gosub ALLBTN
Auto View On : Amos To Front 
I#=-181 : DD#=0
Repeat 
   Screen Display 0,128,Int(I#),320,SCR_H
   Gosub TASK
   I#=I#+DD#
   DD#=DD#+0.75
Until I#>44
Goto _STOP
'
'
'
'***************************************************************************** 
'*error*********************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'
'   .,:::::::::::::..  :::::::..      ...     :::::::..
'   ;;;;'''';;;;``;;;; ;;;;``;;;;  .;;;;;;;.  ;;;;``;;;; 
'    [[cccc \[[[,/[[[' \[[[,/[[[' ,[[     \[[,\[[[,/[[[' 
'    $$"""" "$$$$$$c   "$$$$$$c   $$$,     $$$"$$$$$$c 
'    888oo,_,888b "88bo,888b "88bo"888,_ _,88P,888b "88bo
'    """"YUM"MMMM   "W""MMMM   "W"  "YMMMMMP" "MMMM   "W"
'
'
'
_ERROR: Gosub FLSHSCR : Goto _NOTICE
'
NOCOPY: TXT1$="Need something in" : TXT2$="the copy buffer" : Goto _ERROR
'
NOUNDO: TXT1$="Nothing in the" : TXT2$="undo buffer" : Goto _ERROR
'
WRONGUNDO: TXT1$="Undo buffer from" : TXT2$="a different waveform" : Goto _ERROR
'
NOMEMORY: TXT1$="Not enough memory" : TXT2$="to complete" : Goto _ERROR
'
NOSPACE: TXT1$="Not enough space in" : TXT2$="the variable buffer" : Gosub _STOP : Gosub _TOASTFREE : Goto _ERROR
'
CANTFIND: TXT1$="Can't find" : TXT2$='"'+F$+'"' : Goto _ERROR
'
FILEERROR: TXT1$="Error opening" : TXT2$='"'+F$+'"' : Goto _ERROR
'
MACROERROR: TXT1$="Macro failed" : TXT2$='"'+T$+'"' : Goto _ERROR
'
OVERWRITE: BTXT1$=_OK$ : TXT1$="File exists" : TXT2$="Overwrite?" : Goto _REQUEST
'
NOSPACEERROR:
DISPATCH$=DISPATCH$+"NOSPACE,"
Return 
'
Procedure TR4P
   Shared _INIT,_EXIT,_DIRECT,PLYING,FX,FXE,_BG,_PANE,_WHITE,_GRAY,BUT_W,BUT_H,TXT2$,_OK$
   If _INIT
      Sam Loop Off : Every Off 
   End If 
   _EXIT=True : PLYING=False
   FX=FXE
   If Errn=11
      TXT2$="out of variable space"
   Else If Errn=20
      TXT2$="division by zero"
   Else If Errn=23
      TXT2$="illegal function"
   Else If Errn=24
      TXT2$="not enough memory"
   Else If Errn=29
      TXT2$="overflow"
   Else If Errn=34
      TXT2$="type mismatch"
   Else If Errn=36
      TXT2$="bank not reserved"
   Else If Errn=40
      TXT2$="unknown subroutine"
   Else If Errn=81
      TXT2$="file not found"
   Else If Errn=82
      TXT2$="file name invalid"
   Else If Errn=84
      TXT2$="disk write protected"
   Else If Errn=88
      TXT2$="disk is full"
   Else If Errn>88 and Errn<92
      TXT2$="file protected"
   Else If Errn=94
      TXT2$="of an I/O error"
   Else If Errn=97
      TXT2$="file name too long"
   Else 
      TXT2$=Str$(Errn)
   End If 
   If _DIRECT>0
      Print "Error ";TXT2$
   Else 
      If Not _INIT
         Amos To Front : View 
      End If 
      RX=216 : RY=59
      WX=RX-5 : WY=RY-15 : WX2=RX+207+5 : WY2=RY+45
      Ink _GRAY
      Bar WX-5,WY-4 To WX2+5,WY2+4
      Ink _BG
      Box WX-5,WY-4 To WX2+5,WY2+4
      Ink _WHITE
      Bar WX,WY To WX2,WY2
      Ink _GRAY
      Bar WX+1,WY+1 To WX2-1,WY+13
      Box WX+1,WY+1 To WX2-1,WY2-1
      Ink _WHITE,_GRAY
      Text WX+4,WY+10,"Error"
      Ink _BG,_WHITE
      Text RX+18,RY+11,"Can't do that because"
      Text RX+103-(Text Length(TXT2$)/2),RY+21,TXT2$
      BX=RX+53 : BY=RY+28
      Ink _BG
      Bar BX,BY To BX+BUT_W,BY+BUT_H
      Ink _WHITE
      Bar BX+1,BY+1 To BX+BUT_W-1,BY+BUT_H-1
      Ink _GRAY
      Bar BX+2,BY+2 To BX+BUT_W-2,BY+BUT_H-2
      Ink _BG,_GRAY
      Text BX+(BUT_W/2)-8,BY+BUT_H-4,_OK$
      Repeat 
         Gosub TASK
      Until Mouse Key=0
      Repeat 
         Gosub TASK
      Until Mouse Key=1
      Repeat 
         Gosub TASK
      Until Mouse Key=0
      Ink _PANE
      Bar WX-5,WY-4 To WX2+5,WY2+4
   End If 
   Resume Next 
   TASK:
   Multi Wait 
   Return 
End Proc
'
