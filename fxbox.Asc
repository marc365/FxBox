Dim MENX(_M1),MENB$(10),MENM$(_M2-2) : Rem                           *menu
Dim BUTS$(_AB),BUTX(_AB),BUTY(_AB),BUTG$(_AB) : Rem                  *windows
Dim PAULA(_CH+3),CHAIN$(_XC),D_START(_CH),D_LENGTH(_CH) : Rem        *buttons
Dim OFFSET(_CH),LEFTOVER(_CH),ADV#(_CH),ADVPOS#(_CH) : Rem           *gadgets 
Dim TIME(_CH),XP(_CH),XP2(_CH) : Rem                                 *network 
'                                                                    *init 
Dim DEVS$(5),SETTING$(_OP),FILES$(_FR),FILEL(_FR) : Rem              *screen 
Dim FB$(_FL),FPATH$(_FL),FMACRO$(_MR) : Rem                          *error
'                                                                    *data 
Dim NAME$(_FL),CPYR$(_FL),AUTH$(_FL),TXT$(_FL),ANNO$(_FL),COMP(_FL)
Dim ROT#(_RT),ROTX(_RT),ROTY(_RT),ROTX2(_RT),ROTY2(_RT)
MI=5 : Dim MACROT$(MI),MA(MI),MP(MI),MN(MI) : MI=-1
Dim CMD$(_CM),CMDG$(_CM),DELTA(15),CHROM$(13),INST(16)
'
_UNNAMED$="Unnamed" : _DEFAULT$="Samples" : _NOTAVAILABLE$="not available"
_NOTACTIVE$="not active" : _HZ$="Hz" : _PERCENT$="%" : _LP$="Ż" : _$=""
_SPACE$=" " : _SCORE$="_" : _COMMA$="," : _COLON$=":" : _MINUS$="-"
_NULL$=Chr$(0) : _NEWLINE$=Chr$(10) : _»$="»" : _ABK$=".ABK" : _CAT$=".CAT"
_TRUE$="-1" : _FALSE$="0" : _TOAST$="ł^°¬" : _OK$="Ok" : _CANCEL$="Cancel"
_DOTS$="..." : _BPM$=" Bpm" : _BYTE$="B" : _KILO$="K" : _MEGA$="M" : _GIGA$="G"
_KILOBYTE=1024 : _MEGABYTE=1048576 : _GIGABYTE=1073741824
_MEGABYTE#=_MEGABYTE : _GIGABYTE#=_GIGABYTE
_SPACER$=String$(_SPACE$,2) : _CHUNK$=String$(_NULL$,4)
'
CHR_MINUS=45 : CHR_STAR=42 : CHR_QUESTIONMARK=63 : CHR_HASH=35 : CHR_SPACE=32
'
_BG=0 : _PANE=1 : _WHITE=2 : _GRAY=3
_BLACK=4 : _SHADOW=5 : _BRIGHT=6 : _HIGHLIGHT=7
'
_COL=_PANE : _COLP=_COL
'  
SCR_W=640 : SCR_W#=SCR_W : SCR_H=256 : SCR_R=Hires : SCR_D=8
BUT_W=103 : BUT_H=14
CLI_Y=92 : CLI_H=128
'
ZN_OK=1 : ZN_CANCEL=ZN_OK+1
ZN_PIANO=ZN_CANCEL+1 : ZN_T0NECANCEL=ZN_PIANO+7
ZN_OPTIONS=ZN_CANCEL+1 : ZN_OPTIONSOK=ZN_OPTIONS+23
ZN_FILES=ZN_CANCEL+1
ZN_FILESUP=ZN_FILES+1 : ZN_FILESDOWN=ZN_FILES+2 : ZN_FILESBAR=ZN_FILES+3
ZN_FILESTEXT=ZN_FILES+4
ZN_FILESOK=ZN_FILES+5 : ZN_FILESPARENT=ZN_FILES+6
ZN_FILESVOLUMES=ZN_FILES+7 : ZN_FILESDEVS=ZN_FILES+8
ZN_FILESCANCEL=ZN_FILESVOLUMES+6
ZN_FILESLIST=ZN_FILESCANCEL+1 : ZN_FILESLISTEND=ZN_FILESLIST+14
ZN_PLAY=ZN_FILESLISTEND+1 : ZN_PLAYRANGE=ZN_PLAY+1 : ZN_PLAYDISPLAY=ZN_PLAY+2
ZN_MIX=ZN_PLAY+3 : ZN_REPEAT=ZN_PLAY+4 : ZN_PASTE=ZN_PLAY+11
ZN_LOOP=ZN_PLAY+12 : ZN_MIXLOOP=ZN_PLAY+13
ZN_OSCCLOSE=ZN_MIXLOOP+1 : ZN_OSCMODE=ZN_OSCCLOSE+1
ZN_CALCLOSE=ZN_OSCMODE+1
ZN_AUTO=ZN_CALCLOSE+1 : ZN_FX=ZN_AUTO+1
ZN_TOAST=ZN_FX+1
ZN_LEFTWAND=ZN_TOAST+1 : ZN_RIGHTWAND=ZN_LEFTWAND+1 : ZN_MIDDLEWAND=ZN_LEFTWAND+2
ZN_LEFTRANGESPACE=ZN_MIDDLEWAND+1 : ZN_LEFTRANGE=ZN_LEFTRANGESPACE+1
ZN_MIDDLERANGESPACE=ZN_LEFTRANGESPACE+2
ZN_RIGHTRANGE=ZN_LEFTRANGESPACE+3 : ZN_RIGHTRANGESPACE=ZN_LEFTRANGESPACE+4
'
_MODE=1 : _MODEP=_MODE : _M3SEL=_MODE : B=1 : PB=B : LB=0 : UB=B
PBANK=5 : UBANK=2 : CBANK=6 : CCBANK=32766 : WBANK=7 : KMUL=0
_FXBUF=20480 : _FXCUR=32767
_CHANNEL=1 : _CHANNELS=1 : PASS=0
FREQ=22448 : PFREQ=FREQ : MFREQ=96000 : _AMIHZ=True : VOL=64
_TIMEDIV#=16.0 : _TIMEBEAT#=SCR_W/_TIMEDIV#
'
REXX=False : SOCKSYNC=-1 : SOCKVST=-1
_CHAIN=1 : _REC=False : _LP=True : _LPMIX=True
_DIRECT=0 : _TEXT=False : _SPIN=0 : _GRAB=1
'
REALTIME=False : RENDERING=False : SEQUENCER=False : PIANO=False : POLY=False
PLYING=False : BGPLYING=False : STPPED=True : RNGEPLY=False : DISPPLY=False
OSCILLO=False : ABOUT=False : PLYTIME=0 : STPTIME=0 : CALC=False : POS=1
'
SEQ$=_$ : SEQF$=_$ : SEQP$=_$ : DISPATCH$=_$
'
_DITHER=1 : _INTERPOLATE=0
'
ROT#(1)=13.3
'
_SCALEMIX=False
VN=60 : VA#=0.6
_DCOFFSETN=0
KDOWN=False
HIGHN=80 : HIGHF=4000
RC#=0.0 : DT#=0.0 : ALPHA#=0.0
Dim HBUF(_CH)
BANDN=80 : BANDF=4000
Dim BBUF0(_CH),BBUF1(_CH)
LOWN=80 : LOWF=4000
Dim LBUF(_CH)
RESN=45 : _RF#=0.225 : _RQ#=0.6666674 : _RFB#=1.52688
ROT#(2)=9.6 : ROT#(3)=11.7
Dim RBUF0#(_CH),RBUF1#(_CH)
Dim SMOBUF(_CH)
ALIN=12 : ALIN2=ALIN
TUBEN=96 : TUBEV#=1.04
SATN=120 : SATV#=1.2
FOLDN=4 : FOLDV#=0.015625
PHAN=0
Dim PHBUF#(_CH),PHBUF0(_CH),PHBUF1(_CH)
_EFFN=0 : _ECHON=0
RVN=20 : RVV#=0.6
Dim RVBUF0(_CH),RVBUF1(_CH)
TREMN=82 : TREMN#=2.5625
Dim TBUF(_CH)
_THRESHOLDN#=50 : ROT#(4)=11
_SLOPEN#=50 : ROT#(5)=11
_WINDOWN#=0.08323324 : ROT#(6)=8.9
_LOOKAHEADN#=25 : ROT#(7)=9.7
_ATTACKN#=0.625 : ROT#(8)=8.8
_RELEASEN#=156.25 : ROT#(9)=10
_ATT#=0.0 : _REL#=0.0
_OFFSET=0 : _RMS=0
Dim CBUFENV#(_CH),CBUFSUMM#(_CH)
_MSB=False
'
_2PI#=Pi#*2
T0NEN=0 : T0NEV#=5.0 : T0NEA=98
ROT#(10)=8.5 : ROT#(11)=12.2
'
Dim RANDRSL(255),MM(255)
'
Dreg(1)=Doscall(-60)
If Dreg(1)
   I=0
   Repeat 
      Read T$
      T$=Space$(4)+T$+_NEWLINE$
      Dreg(2)=Varptr(T$) : Dreg(3)=Len(T$) : N=Doscall(-48)
      Inc I
   Until I>18
End If 
On Error Proc TR4P
'
PROGDIR$=Dir$ : PPROGDIR$=PROGDIR$
MACRODIR$="macros" : SEQDIR$="sequences" : CFGFILE$="fxbox.cfg"
FXBOX_REXX$="FXBOX_REXX" : OCTAMED_REXX$="OCTAMED_REXX"
'
Def Fn T0NE#=(_2PI#*T0NEV#)/FREQ
Def Fn DIALZONE=CX>ROTX(_DIAL)-14 and CX<ROTX2(_DIAL) and CY>ROTY(_DIAL)-9 and CY<ROTY2(_DIAL)
Def Fn KEY_PRESS=C>0
Def Fn KEY_D=C=34
Def Fn KEY_SPACE=C=64
Def Fn KEY_BACKSPACE=C=65
Def Fn KEY_RETURN=C=68
Def Fn KEY_ESC=C=69
Def Fn KEY_DEL=C=70
Def Fn KEY_UP=C=76
Def Fn KEY_DOWN=C=77
Def Fn KEY_RIGHT=C=78
Def Fn KEY_LEFT=C=79
Def Fn KEY_CURSOR=C>75 and C<80
Def Fn KEY_SHIFT=S=1 or S=5
Def Fn KEY_CAPSLOCK=S=4
Def Fn KEY_LEFTAMIGA=S=64 or S=68
Def Fn KEY_RIGHTAMIGA=S=128 or S=132
Def Fn KEY_LEFTAMIGAALT=S=80 or S=84
Def Fn KEY_RIGHTAMIGAALT=S=160 or S=164
Def Fn KEY_UPPER(C)=C<91 and C>64
Def Fn CHUNKY(C)=Int(Int(C/_TIMEBEAT#)*_TIMEBEAT#)
Def Fn BUFFER=Free-5
Def Fn A500=_AMIVER<3
Def Fn A1200=_AMIVER<5
Def Fn WANDZOOM=XD>0 or XD2<SCR_W
Def Fn MONO=_MODE=1
Def Fn STEREO=_MODE=2
Def Fn QUAD=_MODE=3
Def Fn STEREOORQUAD= Fn STEREO or Fn QUAD
Def Fn MONOORSTEREOORQUAD=_MODE-4
Def Fn MULTI=_MODE=4
Def Fn INVIEW=B<=_CH
Def Fn MULTIINVIEW= Fn MULTI and Fn INVIEW
Def Fn MOUSEUP=M=0
Def Fn MOUSEDOWN=M=1
Def Fn MOUSEMENU=M=2
Def Fn MOUSEWHEELUP=C=122
Def Fn MOUSEWHEELDOWN=C=123
'
Gosub _INIT
If Prg State=-1 Then Break Off 
'
'
'
'***************************************************************************** 
'*main************************************************************************ 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    .        :    :::.      :::  ::.    :::.
'    ;;,.    ;;;   ;;`;;     ;;;  ;;;;,  `;;;
'    [[[[, ,[[[[, ,[[ '[[,   [[[   [[[[[. '[[
'    $$$$$$$$"$$$c$$$cc$$$c  $$$,  $$$ "Y$c$$
'   888 Y88" 888o 888   888,o88888888    Y88 
'   MM  M'  "MMMM YMM   ""` MMM"MMMM     YM
'
'
'
Do 
   If _SCROLLING Then Gosub WHEELZOOM
   Gosub GVAL
   If Fn KEY_PRESS : Gosub KCHOOSE
   Else If Fn MOUSEDOWN : Gosub BCHOOSE
   Else If Fn MOUSEMENU : Gosub DRWMENU
   Else If _MENUON : Gosub DRWMENUC
   Else If PZ-Z : Gosub ZCHOOSE
   End If 
   If _CHOICE Then Gosub MCHOOSE
   '
   '********************
   If REXX
      If Arexx
         T$=Upper$(Arexx$(0))
         Arexx Answer 0,Lower$(_OK$)
         DISPATCH$=DISPATCH$+T$+_COMMA$
      End If 
   End If 
   '********************
   '
   Gosub DISPATCH
   '
   If Not PLYING
      If Not STPPED
         _COL=_PANE
         BZN=ZN_PLAY : Gosub ZBTN
         BZN=ZN_PLAYRANGE : Gosub ZBTN
         BZN=ZN_PLAYDISPLAY : Gosub ZBTN
         STPPED=True : BGPLYING=False : RNGEPLY=False : DISPPLY=False
         Ink _PANE
         Gosub DRWLEV
         Gosub METROC
         If _REC : Rem save final buffer
            Add BSIZE,-LEFTOVER(1)
            Gosub REC
            Add BSIZE,LEFTOVER(1)
         End If 
      End If 
   End If 
Loop 
'
'
'
'***************************************************************************** 
'*play************************************************************************ 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'   ::::::::.   :::      :::.     -:.     ::-.:    
'   `;;```.;;;  ;;;      ;;`;;    ';;.   ;;;;''    
'   `]]nnn]]'   [[[     ,[[ '[[,     '[[,[[['      
'    $$$""      $$'    c$$$cc$$$c      c$$"        
'    888o     o88oo,.__ 888   888,   ,8P"`         
'    YMMMb    """YUMMMM YMM   ""`   mM"            
'
'  
'
_PLAYRANGE:
If RL=0 and Not Fn KEY_SHIFT Then Goto FLSHSCR
STA=RST : If RL=1 Then FI=P_LENGTH Else FI=P_LENGTH-RFIN
If PLYING
   If DISPPLY
      _COL=_PANE
      BZN=ZN_PLAYDISPLAY : Gosub ZBTN
   Else If Fn KEY_SHIFT
      _COL=_PANE
      BZN=ZN_PLAYRANGE : Gosub ZBTN
      STA=0 : FI=P_LENGTH
      RNGEPLY=False
      Return 
   End If 
End If 
RNGEPLY=True : DISPPLY=False
Goto P
'
_PLAYDISPLAY:
STA=ST : FI=P_LENGTH-FIN
If STA>0 and FI>0
   If Fn STEREO
      STA=STA/2
      FI=FI/2
   Else If Fn QUAD
      STA=STA/4
      FI=FI/4
   End If 
End If 
If PLYING
   If RNGEPLY
      _COL=_PANE
      BZN=ZN_PLAYRANGE : Gosub ZBTN
   Else If Fn KEY_SHIFT
      _COL=_PANE
      BZN=ZN_PLAYDISPLAY : Gosub ZBTN
      STA=0 : FI=P_LENGTH
      DISPPLY=False
      Return 
   End If 
End If 
DISPPLY=True : RNGEPLY=False
Goto P
'
_PLAY:
STA=0 : FI=P_LENGTH : SBEAT=1
_COL=_PANE
If RNGEPLY
   RNGEPLY=False
   BZN=ZN_PLAYRANGE : Gosub ZBTN
Else If DISPPLY
   DISPPLY=False
   BZN=ZN_PLAYDISPLAY : Gosub ZBTN
End If 
If Not Fn KEY_SHIFT
   PWC=1
   Repeat 
      OFFSET(PWC)=0
      LEFTOVER(PWC)=0
      Inc PWC
   Until PWC>_CH
End If 
'
P:
If Not PLYING Then PLYTIME=Timer
BGPLYING=True : STPPED=False
If Not Fn KEY_SHIFT
   If Fn MULTI
      If Fn INVIEW
         OFFSET(B)=STA
      End If 
   Else 
      OFFSET(1)=STA
   End If 
End If 
PWC=1
Gosub CLRPLY
Repeat 
   TIME(PWC)=0
   Inc PWC
Until PWC>_CH
MBEAT=False
If _TOAST$=_$ Then _TOAST$=_LP$
If Not PLYING
   Gosub CLRPOS
   PLYING=True : TGL=True : _STARTPLAY=True
   Sam Loop On 
   Gosub PLYING
End If 
Gosub PLYBTN
Gosub POSCAL
If STA+FI=0 Then FI=P_LENGTH
Return 
'
_REWIND:
If Fn MULTI
   If Fn INVIEW
      OFFSET(B)=0 : TIME(B)=0
   End If 
Else 
   OFFSET(1)=0 : TIME(1)=0
End If 
SBEAT=1
Return 
'  
_REWINDALL:
PB=B
B=_CH
Repeat 
   Gosub _REWIND
   Dec B
Until B<1
B=PB
Return 
'
_STOP:
Every 2 Gosub STPPED
_FULLSTOP:
Sam Loop Off 
If BGPLYING Then Gosub NUDGEPOS
PLYING=False
STPTIME=Timer
If OCTAMED
   If SETTING$(23)<>_FALSE$ : Rem arexx sync 
      Exec RXDIR$+' "address '+OCTAMED_REXX$+' PL_STOP"'
   End If 
End If 
If NETSYNC
   MSG$="/t_stop"+_NULL$+_COMMA$+String$(_NULL$,23)
   I=1
   Repeat 
      Gosub SOCK_SENDSYNC
      Inc I
   Until I>10
End If 
Comp Test On 
Return 
'
PLYING:
Comp Test Off 
If TGL
   P_BUF=P_STARTB2 : P_SWP=P_STARTB1 : TGL=False
Else 
   P_BUF=P_STARTB1 : P_SWP=P_STARTB2 : TGL=True
End If 
If _STARTPLAY
   If Not _VST
      _STARTED=False
      Sam Raw PAULA(_CH+3),P_SWP,Max(BSIZE,257),FREQ
      Goto PF
   End If 
End If 
If Fn MULTI
   If((RNGEPLY and RL) or DISPPLY)
      If Fn INVIEW and Length(B+7)>0
         B_START=Start(B+7)
         BBUFF=(BSIZE*(B))-BSIZE
         DID=B
         If OFFSET(B)>=FI or OFFSET(B)<STA
            If _RESTART
               LEFTOVER(B)=0
            Else If _LP
               OFFSET(B)=STA+LEFTOVER(B)
               LEFTOVER(B)=0
               _TOAST$=_LP$
            Else 
               Goto _STOP
            End If 
            Goto PB4
         Else 
            If OFFSET(B)+BSIZE>FI and OFFSET(B)-FI
               Copy B_START+OFFSET(B),B_START+FI To P_SWP+BBUFF
               LEFTOVER(B)=BSIZE-(FI-OFFSET(B))
               If _LP
                  Copy B_START+STA,B_START+STA+LEFTOVER(B) To P_SWP+BBUFF+(BSIZE-LEFTOVER(B))
               Else If Not Fn A500 : Rem risk of guru address error. a word or long word access was attempted on an odd address boundary
                  Fill P_SWP+BSIZE-LEFTOVER(1) To P_SWP+BSIZE,0
               End If 
            Else 
               PB4:
               Copy B_START+OFFSET(B),B_START+OFFSET(B)+BSIZE To P_SWP+BBUFF
            End If 
         End If 
      End If 
   End If 
   BBUFF=0
   SBCOUNT=1
   Repeat 
      B_LENGTH=Length(SBCOUNT+7)
      If B_LENGTH>0 and SBCOUNT-DID
         B_START=Start(SBCOUNT+7)
         If OFFSET(SBCOUNT)>=B_LENGTH
            Copy B_START+LEFTOVER(SBCOUNT),B_START+LEFTOVER(SBCOUNT)+BSIZE To P_SWP+BBUFF
            If _RESTART
               LEFTOVER(SBCOUNT)=0
            Else If _LP
               OFFSET(SBCOUNT)=LEFTOVER(SBCOUNT)
               LEFTOVER(SBCOUNT)=0
               _TOAST$=_LP$
            Else 
               Goto _STOP
            End If 
         Else 
            If OFFSET(SBCOUNT)+BSIZE>B_LENGTH
               Copy B_START+OFFSET(SBCOUNT),B_START+B_LENGTH To P_SWP+BBUFF
               LEFTOVER(SBCOUNT)=BSIZE-(B_LENGTH-OFFSET(SBCOUNT))
               If _LP
                  Copy B_START,B_START+LEFTOVER(SBCOUNT) To P_SWP+BBUFF+(BSIZE-LEFTOVER(SBCOUNT))
               Else If Not Fn A500 : Rem risk of guru address error. a word or long word access was attempted on an odd address boundary
                  Fill P_SWP+BSIZE-LEFTOVER(SBCOUNT) To P_SWP+BSIZE,0
               End If 
            Else 
               Copy B_START+OFFSET(SBCOUNT),B_START+OFFSET(SBCOUNT)+BSIZE To P_SWP+BBUFF
            End If 
         End If 
      End If 
      Add BBUFF,BSIZE
      Inc SBCOUNT
   Until SBCOUNT>_CH
   DID=0
Else If P_LENGTH>0
   If((RNGEPLY and RL) or DISPPLY)
      If(OFFSET(1)>=FI) or OFFSET(1)<STA
         If _RESTART
            LEFTOVER(1)=0
         Else If _LP
            OFFSET(1)=STA+LEFTOVER(1)
            LEFTOVER(1)=0
            _TOAST$=_LP$
         Else 
            Goto _STOP
         End If 
      Else 
         If(OFFSET(1)+BSIZE>FI) and OFFSET(1)-FI
            P_OFFSET=P_START+OFFSET(1)
            Copy P_OFFSET,P_START+FI To P_SWP
            LEFTOVER(1)=BSIZE-(FI-OFFSET(1))
            If _LP
               Copy P_START+STA,P_START+STA+LEFTOVER(1) To P_SWP+(BSIZE-LEFTOVER(1))
            Else If Not Fn A500 : Rem risk of guru address error. a word or long word access was attempted on an odd address boundary
               Fill P_SWP+BSIZE-LEFTOVER(1) To P_SWP+BSIZE,0
            End If 
            If Fn STEREOORQUAD
               Copy P_OFFSET+P_LENGTH,P_START+P_LENGTH+FI To P_SWP+BSIZE
               Copy P_START+STA+P_LENGTH,P_START+STA+P_LENGTH+LEFTOVER(1) To P_SWP+BSIZE+(BSIZE-LEFTOVER(1))
            End If 
            If Fn QUAD
               Copy P_OFFSET+P_LENGTH+P_LENGTH,P_START+P_LENGTH+P_LENGTH+FI To P_SWP+BSIZE+BSIZE
               Copy P_START+STA+P_LENGTH+P_LENGTH,P_START+STA+P_LENGTH+P_LENGTH+LEFTOVER(1) To P_SWP+BSIZE+BSIZE+(BSIZE-LEFTOVER(1))
               Copy P_OFFSET+P_LENGTH+P_LENGTH+P_LENGTH,P_START+P_LENGTH+P_LENGTH+P_LENGTH+FI To P_SWP+BSIZE+BSIZE+BSIZE
               Copy P_START+STA+P_LENGTH+P_LENGTH+P_LENGTH,P_START+STA+P_LENGTH+P_LENGTH+P_LENGTH+LEFTOVER(1) To P_SWP+BSIZE+BSIZE+BSIZE+(BSIZE-LEFTOVER(1))
            End If 
            Goto PF
         End If 
      End If 
   End If 
   If OFFSET(1)>=P_LENGTH
      If _RESTART
         LEFTOVER(1)=0
      Else If _LP
         OFFSET(1)=LEFTOVER(1)
         LEFTOVER(1)=0
         _TOAST$=_LP$
      Else 
         Goto _STOP
      End If 
      Goto PB
   Else 
      If(OFFSET(1)+BSIZE>P_LENGTH)
         P_OFFSET=P_START+OFFSET(1)
         Copy P_OFFSET,P_START+P_LENGTH To P_SWP
         LEFTOVER(1)=BSIZE-(P_LENGTH-OFFSET(1))
         If _LP
            Copy P_START,P_START+LEFTOVER(1) To P_SWP+(BSIZE-LEFTOVER(1))
         Else If Not Fn A500 : Rem risk of guru address error. a word or long word access was attempted on an odd address boundary
            Fill P_SWP+BSIZE-LEFTOVER(1) To P_SWP+BSIZE,0
         End If 
         If Fn STEREOORQUAD
            Copy P_OFFSET+P_LENGTH,P_START+P_LENGTH+P_LENGTH+LEFTOVER(1) To P_SWP+BSIZE
            Copy P_START+P_LENGTH,P_START+P_LENGTH+LEFTOVER(1) To P_SWP+BSIZE+(BSIZE-LEFTOVER(1))
         End If 
         If Fn QUAD
            Copy P_OFFSET+P_LENGTH+P_LENGTH,P_START+P_LENGTH+P_LENGTH+P_LENGTH+LEFTOVER(1) To P_SWP+BSIZE+BSIZE
            Copy P_START+P_LENGTH+P_LENGTH,P_START+P_LENGTH+P_LENGTH+LEFTOVER(1) To P_SWP+BSIZE+BSIZE+(BSIZE-LEFTOVER(1))
            Copy P_OFFSET+P_LENGTH+P_LENGTH+P_LENGTH,P_START+P_LENGTH+P_LENGTH+P_LENGTH+P_LENGTH+LEFTOVER(1) To P_SWP+BSIZE+BSIZE+BSIZE
            Copy P_START+P_LENGTH+P_LENGTH+P_LENGTH,P_START+P_LENGTH+P_LENGTH+P_LENGTH+LEFTOVER(1) To P_SWP+BSIZE+BSIZE+BSIZE+(BSIZE-LEFTOVER(1))
         End If 
      Else 
         PB:
         P_OFFSET=P_START+OFFSET(1)
         Copy P_OFFSET,P_OFFSET+BSIZE To P_SWP
         If Fn STEREOORQUAD
            Copy P_OFFSET+P_LENGTH,P_OFFSET+BSIZE+P_LENGTH To P_SWP+BSIZE
         End If 
         If Fn QUAD
            Copy P_OFFSET+P_LENGTH+P_LENGTH+P_LENGTH,P_OFFSET+BSIZE+P_LENGTH+P_LENGTH+P_LENGTH To P_SWP+BSIZE+BSIZE+BSIZE
            Copy P_OFFSET+P_LENGTH+P_LENGTH,P_OFFSET+BSIZE+P_LENGTH+P_LENGTH To P_SWP+BSIZE+BSIZE
         End If 
      End If 
   End If 
End If 
_RESTART=False
PF:
If _STARTPLAY
   _STARTPLAY=False
   Every 1 Gosub PLYING
   If _VST
      Gosub SOCK_SENDVSTUP
   End If 
   If OCTAMED
      If SETTING$(23)<>_FALSE$ : Rem arexx sync 
         Exec RXDIR$+' "address '+OCTAMED_REXX$+' PL_PLAYBLOCK"'
      End If 
   End If 
   If NETSYNC
      PKTCOUNT=0
      MSG$="/t_start"+_CHUNK$+",iff"+String$(_NULL$,16)
      Gosub SOCK_SENDSYNC
      Mid$(MSG$,0,8)="/t_pulse"
      Loke Varptr(MSG$)+20,PKTCOUNT
   End If 
   If Not _VST
      BBUFF=0 : SBCOUNT=1
      If Fn MONO
         SBCOUNT=SBCOUNT+_CH+2 : SB=SBCOUNT
      Else If Fn STEREO
         SBCOUNT=SBCOUNT+_CH : SB=SBCOUNT+1
      Else If Fn QUAD
         SB=4
      Else 
         SB=_CH
      End If 
      Repeat 
         Sam Swap PAULA(SBCOUNT) To P_SWP+BBUFF,BSIZE
         Add BBUFF,BSIZE
         Inc SBCOUNT
      Until SBCOUNT>SB
   End If 
   Return 
End If 
If Not _VST
   BBUFF=0 : SBCOUNT=1
   If Fn MONO
      SBCOUNT=SBCOUNT+_CH+2 : SB=SBCOUNT
   Else If Fn STEREO
      SBCOUNT=SBCOUNT+_CH : SB=SBCOUNT+1
   Else If Fn QUAD
      SB=4
   Else 
      SB=_CH
   End If 
   Repeat 
      Sam Swap PAULA(SBCOUNT) To P_BUF+BBUFF,BSIZE
      Add BBUFF,BSIZE
      Inc SBCOUNT
   Until SBCOUNT>SB
End If 
If _STARTED
   Gosub POS
   Gosub SYNC
   If TGL
      Gosub LEV
   Else 
      Gosub PROBAR
      Gosub SCR0LL
      Gosub LEVC
   End If 
   If Fn MULTI
      SBCOUNT=1
      Repeat 
         OFFSET(SBCOUNT)=OFFSET(SBCOUNT)+BSIZE
         TIME(SBCOUNT)=TIME(SBCOUNT)+BSIZE
         Inc SBCOUNT
      Until SBCOUNT>_CH
   Else 
      OFFSET(1)=OFFSET(1)+BSIZE
      TIME(1)=TIME(1)+BSIZE
   End If 
   If _DEBUG
      If Not _VST
         SBCOUNT=0
         Repeat 
            If Sam Swapped(SBCOUNT)
               _TOAST$="µ" : Rem buffer underrun
               Exit 
            End If 
            Inc SBCOUNT
         Until SBCOUNT>3
      End If 
   End If 
   '  
   '********************
   If REALTIME
      If _PREVIEW
         SBCOUNT=1
         M_SWP=P_SWP
         Gosub STATESET
         Repeat 
            If CHAIN$(SBCOUNT)<>_$
               _CHANNEL=1
               If Fn STEREOORQUAD or( Fn MULTI and Fn KEY_CAPSLOCK)
                  _CHANNEL=1
                  If Fn STEREO
                     SB=2
                  Else 
                     SB=4
                  End If 
                  Repeat 
                     Gosub CHAIN$(SBCOUNT)
                     P_SWP=P_SWP+BSIZE
                     Inc _CHANNEL
                  Until _CHANNEL>SB
               Else : Rem mono or multi
                  If Fn MULTI
                     P_SWP=P_SWP+(BSIZE*(B-1))
                  End If 
                  Gosub CHAIN$(SBCOUNT)
               End If 
            Else 
               Exit 
            End If 
            P_SWP=M_SWP
            Inc SBCOUNT
         Until SBCOUNT>_XC
         Gosub STATERESTORE
      End If 
   End If 
   '******************* 
   '
   If _VST
      Gosub SOCK_SENDVST
   End If 
   If _REC
      Gosub REC
   End If 
Else 
   _STARTED=True
End If 
Gosub T0ASTWAITER
Comp Test On 
Every On 
Return 
'
STPPED:
Comp Test Off 
Gosub PROBAR
Gosub SCR0LL
Gosub T0ASTWAITER
Comp Test On 
Every On 
Return 
'
'
'
'***************************************************************************** 
'*position******************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'   ::::::::.     ...      .::::::.  :::  :::::::::: :::      ...     ::.    :::.
'   `;;```.;;; .;;;;;;;.  ;;;`    `; ;;;  ;;;;;;;''' ;;;   .;;;;;;;.  ;;;;,  `;;;
'   `]]nnn]]' ,[[     \[[,'[==/[[[[, [[[      [[     [[[  ,[[     \[[, [[[[[. '[[
'    $$$""    $$$,     $$$  '''    $ $$$,     $$     $$$, $$$,     $$$ $$$ "Y$c$$
'    888o     "888,_ _,88P,88b    dPo88888    88,   o88888"888,_ _,88P888    Y88 
'    YMMMb      "YMMMMMP"   "YMmMY" MMM"MM    MMM   MMM"MM  "YMMMMMP" MM     YM
'
'
'
POS:
If _MENUDO Then Return 
If _POSITIONOFF Then Return 
If Fn MULTI
   POS_Y=HDR_H
   Gosub GFXSET
   SBCOUNT=1
   Repeat 
      If ADVPOS#(SBCOUNT)>0
         XP(SBCOUNT)=Int((OFFSET(SBCOUNT)+1)/ADVPOS#(SBCOUNT))-1
         If Fn WANDZOOM
            XP(SBCOUNT)=XP(SBCOUNT)-(ST/ADVPOS#(SBCOUNT))
         End If 
         If Not RENDERING
            If XP2(SBCOUNT)-XP(SBCOUNT)
               Gr Writing %10
               Draw XP(SBCOUNT),POS_Y To XP(SBCOUNT),POS_Y+POS_H
               Ink WHITE
               If XP2(SBCOUNT)>-1
                  Draw XP2(SBCOUNT),POS_Y To XP2(SBCOUNT),POS_Y+POS_H
               End If 
               XP2(SBCOUNT)=XP(SBCOUNT)
            End If 
         End If 
      End If 
      POS_Y=POS_Y+POS_H
      Inc SBCOUNT
   Until SBCOUNT>_CH
   Gosub GFXRESTORE
   If Not RENDERING
      Gr Writing %1
   End If 
Else 
   If ADVPOS#(1)>0 and OFFSET(1)>0
      If STA>0
         XP(1)=Int(OFFSET(1)/ADVPOS#(1))
         If Fn WANDZOOM
            If ST>0
               XP(1)=Int(XP(1)-(ST/ADVPOS#(1)))
            End If 
         Else 
            If STA>0 and RST>0
               XP(1)=Int(XP(1)-(STA/ADVPOS#(1))+(RST/ADVPOS#(1)))
            End If 
         End If 
      Else 
         If(OFFSET(1)-ST)>0
            XP(1)=Int(((OFFSET(1)-ST)/ADVPOS#(1)))
         Else 
            XP(1)=0
         End If 
      End If 
      If Not RENDERING
         If XP(1)-XP2(1)
            Gr Writing %10
            Draw XP(1),POS_T To XP(1),WVE_H+HDR_H-1
            Ink _WHITE
            If XP2(1)>-1
               Draw XP2(1),POS_T To XP2(1),WVE_H+HDR_H-1
            End If 
            Gr Writing %1
            XP2(1)=XP(1)
         End If 
      End If 
   End If 
End If 
Return 
'  
SYNC:
If CON#<=0 Then Return 
SBCOUNT=PBANK-7
If SBCOUNT<0
   SBCOUNT=1
Else If SBCOUNT>_MODE
   SBCOUNT=_MODE
End If 
POS#=TIME(SBCOUNT)/CON#
If SEQ$<>_$
   If Not _TEXT
      BEAT=Int(POS#/(SCR_W/_TIMEDIV#))
      If SBEAT-BEAT
         SBEAT=BEAT
         CL=Instr(SEQ$,_NEWLINE$)
         If CL>0
            DISPATCH$=DISPATCH$+Left$(SEQ$,CL-1)
            Trap SEQ$=Mid$(SEQ$,CL+1)
            If Errtrap
               SEQ$=_$ : DISPATCH$="NOSPACE,"
            Else If Left$(DISPATCH$,5)="_NDPQ" : Rem no dispatch queue
               Goto DISPATCH
            End If 
         End If 
      End If 
   End If 
End If 
If NETSYNC
   BEAT=Int(POS#/13.3333)
   If Btst(0,BEAT)
      If NBEAT-BEAT
         Add PKTCOUNT,4
         Loke Varptr(MSG$)+20,PKTCOUNT
         Gosub SOCK_SENDSYNC
         NBEAT=BEAT
      End If 
   End If 
End If 
If _MENUDO or RENDERING Then Return 
If _METRO
   BEAT=Int(POS#/(SCR_W/(_TIMEDIV#/2)))
   If Btst(0,BEAT)
      If MBEAT
         Gosub METROC : MBEAT=False
      End If 
   Else If Not MBEAT
      Gosub METRO : MBEAT=True
   End If 
End If 
Return 
'
POSCAL:
P_LENGTH=Length(PBANK)
If P_LENGTH=0 Then Return 
P_START=Start(PBANK)
If Fn MULTI
   PAC=1
   Repeat 
      ADVPOS#(PAC)=(D_LENGTH(PAC)-BSIZE-ST-FIN)/SCR_W#
      Inc PAC
   Until PAC>_CH
Else 
   If Fn STEREO
      P_LENGTH=P_LENGTH/2
   Else If Fn QUAD
      P_LENGTH=P_LENGTH/4
   End If 
   ADVPOS#(1)=(L-BSIZE)/SCR_W#
End If 
Return 
'
NUDGEPOS:
If Not BGPLYING Then Return 
Gosub GFXSET
If Fn MULTI
   NPSTEP=1
   NPY=HDR_H
   NPCOUNT=1
   Repeat 
      Ink _WHITE
      Gr Writing %10
      Draw XP(NPCOUNT),NPY To XP(NPCOUNT),NPY+POS_H
      NPY=NPY+POS_H
      Inc NPCOUNT
   Until NPCOUNT>_CH
Else 
   Gr Writing %10
   Draw XP2(1),POS_T To XP2(1),WVE_H+HDR_H-1
End If 
Gr Writing %1
Goto GFXRESTORE
'  
NUDGE4POS:
If Not BGPLYING or B>_CH Then Return 
Gosub GFXSET
NPSTEP=1
NPY=HDR_H+(NPH*(B-1))
Ink _WHITE
Gr Writing %10
Draw XP(B),NPY To XP(B),NPY+POS_H
NPY=NPY+POS_H
Gr Writing %1
Goto GFXRESTORE
'
POSSET:
RNG_T=1
If Fn MULTI
   WVE_D=WVE_H/_CH
   B=((CY-HDR_H)/WVE_D)+1
End If 
Return 
'
CLRPOS:
D=1
Repeat 
   XP(D)=0 : XP2(D)=-1
   Inc D
Until D>_CH
Return 
'
CLR4POS:
If Fn MULTIINVIEW
   XP(B)=0 : XP2(B)=-1
End If 
Return 
'
'  
'
'***************************************************************************** 
'*draw************************************************************************ 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'  
'   ::::::-.  :::::::..    :::.     .::    .   .:: 
'   ;;,   `';,;;;;``;;;;   ;;`;;    ';;,  ;;  ;;;' 
'   `[[     [[\[[[,/[[['  ,[[ '[[,   '[[, [[, [['  
'    $$,    $$"$$$$$$c   c$$$cc$$$c    Y$c$$$c$P   
'    888_,o8P',888b "88bo 888   888,    "88"888    
'   "MMMMP"`  "MMMM   "W" YMM   ""`      "M "M"    
'
'
'
_DRAWALL:
Gosub CLRPOS
RENDERING=True
Gosub _DRAW
Gosub FRSHSEL
RENDERING=False
Return 
'
_SHOWCOPY:
Gosub CLRPOS
RENDERING=True
Gosub SH0WWAVE
Gosub FRSHSEL
RENDERING=False
Return 
'
_SHOWALL:
Gosub SETPBANK
XD=0 : XD2=SCR_W : ST=0 : FIN=0 : L=0
Gosub CLRPOS
RENDERING=True
Gosub _DRAW
Gosub MAGICWAND
Gosub FRSHSEL
RENDERING=False
Gosub HEADER
Goto DRWTIME
'
_DRAW:
D=HDR_H+WVE_H
Ink _PANE
Repeat 
   Bar 0,D--_DSTEP To SCR_W,D
   Add D,_DSTEP
Until D<-_DSTEP
Ink _SHADOW
WVE_D=HDR_H+(WVE_H/(_CH/2.0))
Draw 0,WVE_D To SCR_W,WVE_D
If _MODE>1
   WVE_D=HDR_H+(WVE_H/_CH)
   DCY=WVE_D+(WVE_H/(_CH/2.0))
   Draw 0,WVE_D To SCR_W,WVE_D
   Draw 0,DCY To SCR_W,DCY
End If 
If _MODE>2
   WVE_D=WVE_H/_CH
   DCY=-(WVE_H/(_CH*2))
   While DCY<WVE_H
      Draw 0,HDR_H+DCY To SCR_W,HDR_H+DCY
      Add DCY,WVE_D
   Wend 
End If 
If Fn MONOORSTEREOORQUAD and P_LENGTH=0 Then Goto C0PYWAVE
Ink _WHITE
If SCR_H<256 Then DRWDIV=270 Else DRWDIV=192
On _MODE Goto D1,D2,D3,D4
D1:
DRWSUB=(127*128)/DRWDIV
DRWSUB2=-(DRWSUB*2)
If SCR_H>200 Then Add DRWSUB2,-2
WVE_D=HDR_H+(WVE_H/2)
ADV#=(P_LENGTH-ST-FIN)/SCR_W#
D_START(1)=P_START+ST
DN=(Peek(D_START(1))*128)/DRWDIV
If DN>DRWSUB Then Add DN,DRWSUB2
Gr Locate 0,DN+WVE_D
DI=0
Repeat 
   DN=Int(DI*ADV#)
   DN=(Peek(D_START(1)+DN)*128)/DRWDIV
   If DN>DRWSUB Then Add DN,DRWSUB2
   Draw To DI,DN+WVE_D
   Add DI,_STEP
Until DI>WVE_W
Goto C0PYWAVE
D2:
DRWDIV=(DRWDIV*2)-3
DRWSUB=(127*128)/DRWDIV
DRWSUB2=-DRWSUB*2
If SCR_H>200 Then Add DRWSUB2,-1
WVE_D=WVE_H/2
ADV#=(P_LENGTH-ST-FIN)/SCR_W#
D_START(1)=P_START+ST
D_START(2)=D_START(1)+P_LENGTH
DCY=HDR_H+(WVE_D/2)
DC=1
Repeat 
   DN=(Peek(D_START(DC))*128)/DRWDIV
   If DN>DRWSUB-2 Then Add DN,DRWSUB2
   Gr Locate 0,DN+DCY
   DI=1
   Repeat 
      DN=Int(DI*ADV#)
      DN=(Peek(D_START(DC)+DN)*128)/DRWDIV
      If DN>DRWSUB Then Add DN,DRWSUB2
      Draw To DI,DN+DCY
      Add DI,_STEP
   Until DI>WVE_W
   Add DCY,WVE_D
   Inc DC
Until DC>2
Goto C0PYWAVE
D3:
DRWDIV=(DRWDIV*4)+7
DRWSUB=(127*128)/DRWDIV
DRWSUB2=-(DRWSUB*2)-2
WVE_D=WVE_H/4
ADV#=(P_LENGTH-ST-FIN)/SCR_W#
DI=0
DC=1
Repeat 
   D_START(DC)=P_START+ST+DI
   Add DI,P_LENGTH
   Inc DC
Until DC>4
DCY=HDR_H+(WVE_D/2)
DC=1
Repeat 
   DN=(Peek(D_START(DC))*128)/DRWDIV
   If DN>DRWSUB Then Add DN,DRWSUB2
   Gr Locate 0,DN+DCY
   DI=1
   Repeat 
      DN=Int(DI*ADV#)
      DN=(Peek(D_START(DC)+DN)*128)/DRWDIV
      If DN>DRWSUB Then Add DN,DRWSUB2
      Draw To DI,DN+DCY
      Add DI,_STEP
   Until DI>WVE_W
   Add DCY,WVE_D
   Inc DC
Until DC>4
Goto C0PYWAVE
D4:
DRWDIV=(DRWDIV*_CH)+7
DRWSUB=(127*128)/DRWDIV
DRWSUB2=-(DRWSUB*2)-2
WVE_D=WVE_H/_CH
DC=1
Repeat 
   D_LENGTH(DC)=Length(DC+7)
   If D_LENGTH(DC)>0
      ADV#(DC)=(D_LENGTH(DC)-ST-FIN)/SCR_W#
      D_START(DC)=Start(DC+7)+ST
   Else 
      ADV#(DC)=0
   End If 
   Inc DC
Until DC>_CH
DCY=HDR_H+(WVE_D/2)
DC=1
Repeat 
   If ADV#(DC)>0
      DN=(Peek(D_START(DC)+1)*128)/DRWDIV
      If DN>DRWSUB
         Add DN,DRWSUB2
      End If 
      Gr Locate 0,DN+DCY
      DI=1
      Repeat 
         DN=Int(DI*ADV#(DC))
         DN=(Peek(D_START(DC)+DN)*128)/DRWDIV
         If DN>DRWSUB
            Add DN,DRWSUB2
         End If 
         Draw To DI,DN+DCY
         Add DI,_STEP
      Until DI>WVE_W
   End If 
   Add DCY,WVE_D
   Inc DC
Until DC>_CH
C0PYWAVE:
If Fn MOUSEUP
   Gosub DRWDIV
   D=HDR_H+WVE_H
   Repeat 
      Screen Copy 0,0,D--_DSTEP,WVE_W,D To 1,0,(D--_DSTEP)-HDR_H
      Add D,_DSTEP
   Until D<0
   Gosub HIGHPIANO
End If 
Return 
'
SH0WWAVE:
D=WVE_H
Repeat 
   Screen Copy 1,0,D--_DSTEP,WVE_W,D To 0,0,HDR_H+D--_DSTEP
   Add D,_DSTEP
Until D<0
Gosub CAL_BCK
Gosub HIGHPIANO
If SCR_H<256 Then Goto CONTROLS
Return 
'
DRWTIME:
If RENDERING Then Return 
DRWTIMENOW:
Gosub GFXSET
T_LENGTH=P_LENGTH
Gosub TIME_ALL
Ink _SHADOW,_PANE
If DIV#>0
   If DIV#>9
      T$=Str$(DIV#)-_SPACE$+T$
   Else 
      T$=Str$(DIV#)+T$
   End If 
   If Len(T$)<16
      T$=Space$(22-Len(T$))+T$
   End If 
Else 
   T$=Space$(22)
End If 
Text 600-Text Length(T$),NFO_H,T$
If Len(T$)>22 : Rem mix loop button fix  
   _NUDGETIME=True
Else If _NUDGETIME
   _NUDGETIME=False
   Gosub LPMIXBTN
End If 
DRWHZ:
Ink _SHADOW,_PANE
T$=Str$(FREQ)+_SPACE$+_HZ$
Text 108-Text Length(T$),NFO_H,T$
Gosub CAL_BCK
Goto GFXRESTORE
'
HEADER:
Gosub MEMORY
If MEMORY<1000000
   MEMORY=MEMORY/1000
   T$=_KILO$
Else 
   MEMORY=MEMORY/_MEGABYTE
   T$=_MEGA$
End If 
T$="Free:"+Str$(MEMORY)-_SPACE$+T$
H=Max(0,10-Len(T$))
Gosub GFXSET
Ink _PANE
Bar 0,0 To SCR_W,HDR_H-1
Ink _SHADOW,_PANE
If Len(F$)<19+H Then Text 6,8,Str$(B)-_SPACE$+_COLON$+F$ Else Text 6,8,Str$(B)-_SPACE$+_COLON$+Left$(F$,17+H)+_DOTS$
H=H*8
Text SCR_W-83+H,8,T$
HEADERCORDS:
Ink _SHADOW,_PANE
T$=Str$(P_LENGTH)-_SPACE$ : Text 186+H,8,"Size:"+T$+Space$(10-Len(T$))
T$=Str$(RST)-_SPACE$ : Text 304+H,8,"Start:"+T$+Space$(10-Len(T$))
T$=Str$(RL)-_SPACE$ : Text 430+H,8,"Range:"+T$+Space$(10-Len(T$))
Goto GFXRESTORE
'  
'
'
'***************************************************************************** 
'*zoom*wand******************************************************************* 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'   ::::::::     ...         ...      .        :   
'   `````;;;  .;;;;;;;.   .;;;;;;;.   ;;,.    ;;;  
'       .n[[',[[     \[[,,[[     \[[, [[[[, ,[[[[, 
'     ,$$P"  $$$,     $$$$$$,     $$$ $$$$$$$$"$$$ 
'   ,888bo,_ "888,_ _,88P"888,_ _,88P888 Y88" 888o 
'    `""*UMM   "YMMMMMP"   "YMMMMMP" MM  M'  "MMMM 
'
'
'
WHEELZOOM:
If SETTING$(22)=_FALSE$ or P_LENGTH=0 or RENDERING Then Return 
If CY>HDR_H and CY<WND_H
   If Fn MULTIINVIEW
      _MIN=B
   Else 
      _MIN=1
   End If 
   _MIN=Int(ADVPOS#(_MIN)/2)
   _MIN=Min(10,_MIN) : _MIN=Max(1,_MIN)
   _SCROLLING=False
   If Fn MOUSEWHEELUP : Rem zoom in
      If XD<XD2
         If XD2>XD+40
            XD=XD+Int((CX-XD)/_MIN)
            If XD2>0
               XD2=XD2-Int((XD2-CX)/_MIN)
            End If 
         Else If XD+2<XD2
            Add XD,1
            If XD2>0
               Add XD2,-1
            End If 
         End If 
      End If 
   Else If Fn MOUSEWHEELDOWN : Rem zoom out 
      If XD2>XD+40
         If CX>XD+40
            XD=XD-Int((CX-XD)/_MIN)
         Else 
            XD=XD-20
         End If 
         If XD2>CX+40
            XD2=XD2+Int((XD2-CX)/_MIN)
         Else 
            XD2=XD2+20
         End If 
      Else 
         Add XD,-1
         Add XD2,1
      End If 
      If XD<0
         XD=0
      End If 
      If XD2>SCR_W
         XD2=SCR_W
      End If 
   End If 
   Gosub KEY
   If C=0 : Rem check if still scrolling 
      Gosub WREFRSH
   Else 
      _SCROLLING=True
   End If 
End If 
Return 
'
MAGICWAND:
If DISPPLY
   If ST+FIN=0
      STA=0 : FI=P_LENGTH
   Else 
      STA=ST : FI=P_LENGTH-FIN
   End If 
End If 
Gosub SETCORDS
Gosub SETZN
WND_L=XD+43 : WND_R=XD2-43
Gosub GFXSET
If WND_L<WND_R
   If XD>0
      Ink _PANE
      Bar 0,WND_Y To XD,WND_H
   End If 
   Ink _BLACK
   Bar WND_L,WND_Y To WND_R,WND_H
   Ink _WHITE
   Bar XD,WND_Y To WND_L,WND_H
   Bar WND_R,WND_Y To XD2,WND_H
   If XD2<SCR_W
      Ink _PANE
      Bar XD2,WND_Y To SCR_W,WND_H
   End If 
   Set Zone ZN_MIDDLEWAND,WND_L,WND_Y To WND_R,WND_H
   Set Zone ZN_LEFTWAND,XD,WND_Y To WND_L,WND_H
   Set Zone ZN_RIGHTWAND,WND_R,WND_Y To XD2,WND_H
Else : Rem micro zoom 
   WND_Z=XD+23 : WND_N=WND_Z+43 : WND_S=WND_N+23
   If XD2<SCR_W and WND_S<SCR_W
      If XD>0
         Ink _PANE
         Bar 0,WND_Y To XD,WND_H
      End If 
      Ink _BLACK
      Bar WND_Z,WND_Y To WND_N,WND_H
      Ink _HIGHLIGHT
      Bar XD,WND_Y To WND_Z,WND_H
      Bar WND_N,WND_Y To WND_S,WND_H
      If WND_S<SCR_W
         Ink _PANE
         Bar WND_S,WND_Y To SCR_W,WND_H
      End If 
      Set Zone ZN_MIDDLEWAND,WND_Z,WND_Y To WND_N,WND_H
      Set Zone ZN_LEFTWAND,XD,WND_Y To WND_Z,WND_H
      Set Zone ZN_RIGHTWAND,WND_N,WND_Y To WND_S,WND_H
   Else : Rem visual stop at right hand side movement off screen   
      WND_Z=SCR_W-23 : WND_N=WND_Z-43 : WND_S=WND_N-23
      If WND_S>0
         Ink _PANE
         Bar 0,WND_Y To WND_S,WND_H
      End If 
      Ink _BLACK
      Bar WND_N,WND_Y To WND_Z,WND_H
      Ink _HIGHLIGHT
      Bar WND_S,WND_Y To WND_N,WND_H
      If WND_Z<SCR_W
         Bar WND_Z,WND_Y To SCR_W,WND_H
      End If 
      Set Zone ZN_MIDDLEWAND,WND_N,WND_Y To WND_Z,WND_H
      Set Zone ZN_LEFTWAND,WND_S,WND_Y To WND_N,WND_H
      Set Zone ZN_RIGHTWAND,WND_Z,WND_Y To SCR_W,WND_H
   End If 
End If 
Gosub GFXRESTORE
ZXD=XD
Return 
'  
LEFTWAND:
RENDERING=True
MX=CX : PXD=XD
_SLOW= Fn KEY_SHIFT
Repeat 
   PX=CX
   Gosub TESTMOVE
   Gosub KCHOOSE
   Exit If _SLOW<> Fn KEY_SHIFT
   If PX-CX
      Gosub LREFRESH
   Else If Fn KEY_RIGHT
      Inc XD
      Gosub LRREFRSH
   Else If Fn KEY_LEFT
      Dec XD
      Gosub LRREFRSH
   End If 
Until Fn MOUSEUP
Goto AFTERWAND
'
LREFRESH:
If Fn KEY_SHIFT
   XD=PXD-((MX-CX)/3)
   Gosub SLOW
Else 
   XD=PXD-(MX-CX)
End If 
If XD<0 Then XD=0
If XD>SCR_W-2 Then XD=SCR_W-2
If XD>XD2-1 Then XD=XD2-1
Goto WANDDRAW
'
RIGHTWAND:
RENDERING=True
MX=CX : PXD2=XD2
_SLOW= Fn KEY_SHIFT
Repeat 
   PX=CX
   Gosub TESTMOVE
   Gosub KCHOOSE
   Exit If _SLOW<> Fn KEY_SHIFT
   If PX-CX
      Gosub RREFRESH
   Else If Fn KEY_RIGHT
      Inc XD2
      Gosub LRREFRSH
   Else If Fn KEY_LEFT
      Dec XD2
      Gosub LRREFRSH
   End If 
Until Fn MOUSEUP
Goto AFTERWAND
'
RREFRESH:
If Fn KEY_SHIFT
   XD2=PXD2-((MX-CX)/3)
   Gosub SLOW
Else 
   XD2=PXD2-(MX-CX)
End If 
If XD2>SCR_W Then XD2=SCR_W
If XD2<1 Then XD2=1
If XD2<XD+1 Then XD2=XD+1
Goto WANDDRAW
'
MOVEWAND:
Gosub CLRPOS
RENDERING=True
MX=CX : PXD=XD : PXD2=XD2
_SLOW= Fn KEY_SHIFT
Repeat 
   PX=CX
   Gosub TESTMOVE
   Gosub KCHOOSE
   Exit If _SLOW<> Fn KEY_SHIFT
   If PX-CX
      Gosub MREFRESH
   Else If Fn KEY_RIGHT
      Inc XD : Inc XD2
      Gosub LRREFRSH
   Else If Fn KEY_LEFT
      Dec XD : Dec XD2
      Gosub LRREFRSH
   End If 
Until Fn MOUSEUP
AFTERWAND:
Gosub SETSELV
Gosub SETCORDS
Gosub SETZN
Gosub _DRAW
Gosub FRSHSEL
Gosub CAL_BCK
RENDERING=False
Goto CLRPOS
'
MREFRESH:
If Fn KEY_SHIFT
   XD=PXD-((MX-CX)/3)
   XD2=PXD2-((MX-CX)/3)
   Gosub SLOW
Else 
   XD=PXD-(MX-CX)
   XD2=PXD2-(MX-CX)
End If 
If XD2<1 Then XD2=1
LRREFRSH:
If XD<0 Then XD=0
If XD>SCR_W-2 Then XD=SCR_W-2
If XD2>SCR_W Then XD2=SCR_W
WANDDRAW:
Gosub MAGICWAND
If SETTING$(20)<>_FALSE$ : Rem zoom draw
   Gosub SETSELV
   Gosub SETCORDS
   Gosub _DRAW
   Gosub DRWMARKS
End If 
Return 
'
WREFRSH:
Gosub MAGICWAND
RENDERING=True
Goto AFTERWAND
'  
SETCORDS:
If CON#>0
   If RL>0 and RST>0
      XR=Int((RST/CON#)-(ST/CON#))
      If RL=1
         XR2=XR
      Else 
         XR2=Int(SCR_W-((RFIN/CON#)-(FIN/CON#)))
      End If 
   Else If RST=0
      XR=0
      If RL>1
         XR2=Int(SCR_W-((RFIN/CON#)-(FIN/CON#)))
      Else 
         XR2=0
      End If 
   End If 
End If 
If XR<0
   XR=0
Else If XR>SCR_W
   XR=SCR_W
End If 
If XR2>SCR_W
   XR2=SCR_W
Else If XR2<0
   XR2=0
End If 
CON#=P_LENGTH/SCR_W#
ST=Int(XD*CON#)
FIN=Int((SCR_W-XD2)*CON#)
L=P_LENGTH-ST-FIN
Goto POSCAL
'
'
'
'***************************************************************************** 
'*range*********************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'   :::::::..    :::.     ::.    :::. .,-:::::/  .,::::::
'   ;;;;``;;;;   ;;`;;    ;;;;,  `;;;;;-'````'   ;;;;''''
'   \[[[,/[[['  ,[[ '[[,   [[[[[. '[[[[   [[[[[[/ [[cccc 
'   "$$$$$$c   c$$$cc$$$c  $$$ "Y$c$$$$c.    "$$  $$"""" 
'   ,888b "88bo 888   888,888    Y88 `Y8bo,,,o88  888oo,_
'   "MMMM   "W" YMM   ""` MM     YM    `'YMUP"YMM """"YUM
'
'
'
_RANGEALL:
Gosub SETPBANK
If FX_LENGTH=0 Then Goto FLSHSCR
Gosub PBANKLEN
REQ=True
STA=0 : RL=FI : ST=0 : RST=0 : RFIN=0 : XR=0 : XR2=SCR_W
If MACRO Then Return 
If Fn MONOORSTEREOORQUAD or Fn MULTIINVIEW
   Gosub SETCORDS
   If MACRO
      Return 
   End If 
   If Fn MULTI
      Gosub CLR4POS
   Else 
      Gosub CLRPOS
   End If 
   RENDERING=True
   Gosub FRSHSEL
   RENDERING=False
   Gosub SETZN
   Gosub CAL_BCK
   Gosub HIGHPIANO
End If 
Goto HEADERCORDS
'
_RANGEDISPLAY:
Gosub SETPBANK
If FX_LENGTH=0 or(B>_CH and Fn MULTI) Then Goto FLSHSCR
REQ=True
XR=0 : XR2=SCR_W
Gosub SETSELCORDS
STA=RST : FI=RST+RL
If Fn MULTI Then Gosub CLR4POS Else Gosub CLRPOS
RENDERING=True
Gosub FRSHSEL
RENDERING=False
Gosub SETZN
Gosub CAL_BCK
Gosub HIGHPIANO
Goto HEADERCORDS
'
_RANGENONE:
If RL=0 Then Return 
REQ=True
Gosub NUDGEPOS
If RNGEPLY
   STA=0 : ST=0 : FI=P_LENGTH
End If 
Gosub CLRRNG
If Fn MULTI Then Gosub NUDGEPOS
XR=0 : XR2=0 : LXR=0 : LXR2=0
RST=0 : RL=0 : RFIN=0
Gosub SETZN
If Fn MONOORSTEREOORQUAD Then Gosub NUDGEPOS
Gosub CAL_BCK
Gosub HIGHPIANO
Goto HEADERCORDS
'
_SHOWRANGE:
If RL<2 Then Goto FLSHSCR
Gosub SETPBANK
If FX_LENGTH=0 Then Goto FLSHSCR
Gosub SETCORDS
ST=RST : FIN=RFIN
XD=ST/CON# : Inc XD
XD2=(P_LENGTH-FIN)/CON#
Gosub MAGICWAND
Gosub HIGHPIANO
RENDERING=True
Goto AFTERWAND
'
RANGE:
PLP=_LP
_LP=True
Gosub NUDGEPOS
If Fn MULTI
   Gosub CLRPOS
   Gosub POSSET
   Gosub SETBANK
   Gosub DRWTIME
   If Fn MULTI
      If XP(B)>XR and XP(B)<XR2
         Gosub NUDGEPOS
      End If 
   End If 
Else 
   Gosub CLRRNG
End If 
RENDERING=True
Gosub HIGHPIANO
MX=CX
If Fn KEY_SHIFT Then MX= Fn CHUNKY(MX)
PXR=XR : PXR2=XR2
XR=MX : LXR=XR
XR2=XR : LXR2=XR2
Gosub RNG
Gosub CLRPOS
RENDERING=True
Repeat 
   PX=CX
   Gosub TESTMOVE
   If Fn KEY_ESC
      Gosub MUP
      XR=PXR : XR2=PXR2
      Gosub _DRAWALL
      If Fn MONOORSTEREOORQUAD
         Goto NUDGEPOS
      End If 
      Return 
   End If 
   Gosub KCHOOSE
   If PX-CX
      Gosub SMREFRESH
   Else If Fn KEY_RIGHT
      Inc XR2
      Gosub MKEYREFRSH
   Else If Fn KEY_LEFT
      Dec XR2
      Gosub MKEYREFRSH
   End If 
Until Fn MOUSEUP
Gosub XRSWAP
Gosub DRWRNG
Gosub SETSELCORDS
Gosub SETZN
If RL<=0 or XR=XR2 Then RL=1
If RNGEPLY and RL=1
   If Fn MULTI
      OFFSET(B)=RST
   Else 
      OFFSET(1)=RST
   End If 
   RFIN=P_LENGTH
   _RESTART=True
   If XR=XR2
      STA=RST
      FI=P_LENGTH
   End If 
End If 
Gosub HEADERCORDS
Gosub HIGHPIANO
_LP=PLP
RENDERING=False
Return 
'
R0LLLEFT:
If _MENUDO or RL<2 Then Return 
If XR2>XR+10
   Ink _HIGHLIGHT
   Bar XR+1,RNG_T+HDR_H To XR+10,RNG_B+HDR_H-1
End If 
Return 
'  
UNR0LLLEFT:
If _MENUDO or RL<2 Then Return 
If XR2-XR>12 and XR2>XR Then Screen Copy 1,XR+1,RNG_T-1,XR+HDR_H,RNG_B To 0,XR+1,RNG_T+HDR_H-1,%110000
If XR+12>CAL_X Then Gosub CAL_BCK
Goto HIGHPIANO
'
R0LLRIGHT:
If _MENUDO or RL<2 Then Return 
If XR2>10 and XR2>XR+10
   Ink _HIGHLIGHT
   Bar XR2-10,RNG_T+HDR_H To XR2-1,RNG_B+HDR_H-1
End If 
Return 
'
UNR0LLRIGHT:
If _MENUDO or RL<2 Then Return 
If XR2>12 and XR2>XR+12 Then Screen Copy 1,XR2-11,RNG_T-1,XR2,RNG_B To 0,XR2-11,RNG_T+HDR_H-1,%110000
If XR2>CAL_X Then Gosub CAL_BCK
Goto HIGHPIANO
'
SMREFRESH:
If Fn KEY_SHIFT
   CX= Fn CHUNKY(CX)
   If CX=MX
      Return 
   End If 
End If 
XR2=XR-(MX-CX)
MKEYREFRSH:
If XR2<0 Then XR2=0
If XR2>SCR_W Then XR2=SCR_W
Gosub SETSELCORDS
Gosub HIGHPIANO
Goto RNG
'
SELLEFT:
RENDERING=True
Gosub NUDGEPOS
Gosub UNR0LLLEFT
Gosub CLRPOS
RENDERING=True
MX=CX
If Fn KEY_SHIFT Then MX= Fn CHUNKY(MX)
PXD=XR
LXR=XR
Repeat 
   PX=CX
   Gosub TESTMOVE
   Gosub KCHOOSE
   If PX-CX
      Gosub SLREFRESH
   Else If Fn KEY_RIGHT
      Inc XR : Inc PXD
      Gosub LKEYREFRSH
   Else If Fn KEY_LEFT
      Dec XR : Dec PXD
      Gosub LKEYREFRSH
   End If 
Until Fn MOUSEUP
Gosub XRSWAP
Gosub R0LLLEFT
Gosub HEADERCORDS
Gosub SETZN
RENDERING=False
Goto HIGHPIANO
'  
SLREFRESH:
If Fn KEY_SHIFT
   CX= Fn CHUNKY(CX)
   If CX=MX
      Return 
   End If 
   PXD= Fn CHUNKY(PXD)
End If 
XR=PXD-(MX-CX)
LKEYREFRSH:
If XR<0 Then XR=0
If XR>SCR_W Then XR=SCR_W
Gosub SETLSELCORDS
Gosub HIGHPIANO
Goto DRWRNGL
'
SELRIGHT:
RENDERING=True
Gosub NUDGEPOS
Gosub UNR0LLRIGHT
Gosub CLRPOS
RENDERING=True
MX=CX
If Fn KEY_SHIFT Then MX= Fn CHUNKY(MX)
PXD=XR2
LXR=XR
LXR2=XR2
Repeat 
   PX=CX
   Gosub TESTMOVE
   Gosub KCHOOSE
   If PX-CX
      Gosub SRREFRESH
   Else If Fn KEY_RIGHT
      Inc XR2 : Inc PXD
      Gosub RKEYREFRSH
   Else If Fn KEY_LEFT
      Dec XR2 : Dec PXD
      Gosub RKEYREFRSH
   End If 
Until Fn MOUSEUP
Gosub XRSWAP
Gosub R0LLRIGHT
Gosub HEADERCORDS
Gosub SETZN
RENDERING=False
Goto HIGHPIANO
'
SRREFRESH:
If Fn KEY_SHIFT
   CX= Fn CHUNKY(CX)
   If CX=MX
      Return 
   End If 
   PXD= Fn CHUNKY(PXD)
End If 
XR2=PXD-(MX-CX)
RKEYREFRSH:
If XR2<0 Then XR2=0
If XR2>SCR_W Then XR2=SCR_W
Gosub SETRSELCORDS
Gosub HIGHPIANO
Goto DRWRNG
'
FRSHSEL:
If RL=0 Then Return 
If XR=XR2 or XR+1=XR2 Then Goto DRWMARK
D=RNG_B
Repeat 
   Screen Copy 1,XR,D--_DSTEP,XR2,D To 0,XR,HDR_H+(D--_DSTEP),%110000
   Add D,_DSTEP
Until D<RNG_T
DRWMARKS:
Ink _BG
Draw XR,RNG_T+HDR_H To XR,RNG_B+HDR_H-1
DRWMARK:
Ink _BG
Draw XR2,RNG_T+HDR_H To XR2,RNG_B+HDR_H-1
Return 
'
DRWRNG:
If RNGEPLY
   If RST+RFIN=0
      FI=P_LENGTH
   Else 
      STA=RST
      FI=P_LENGTH-RFIN
   End If 
End If 
RNG:
If XR>XR2
   If LXR2>XR
      D=RNG_B
      Repeat 
         Screen Copy 1,XR,D--_DSTEP,LXR2+1,D To 0,XR,HDR_H+(D--_DSTEP)
         Add D,_DSTEP
      Until D<RNG_T
      LXR2=XR
   End If 
   If XR2<LXR
      D=RNG_B
      Repeat 
         Screen Copy 1,XR2,D--_DSTEP,LXR+1,D To 0,XR2,HDR_H+(D--_DSTEP),%110000
         Add D,_DSTEP
      Until D<RNG_T
      LXR=XR2
   End If 
   If XR2>LXR
      D=RNG_B
      Repeat 
         Screen Copy 1,LXR,D--_DSTEP,XR2,D To 0,LXR,HDR_H+(D--_DSTEP)
         Add D,_DSTEP
      Until D<RNG_T
      LXR=XR2
   End If 
Else 
   If LXR<XR
      D=RNG_B
      Repeat 
         Screen Copy 1,LXR,D--_DSTEP,XR,D To 0,LXR,HDR_H+(D--_DSTEP)
         Add D,_DSTEP
      Until D<RNG_T
      LXR=XR
   End If 
   If XR2>LXR2
      D=RNG_B
      Repeat 
         Screen Copy 1,LXR2,D--_DSTEP,XR2,D To 0,LXR2,HDR_H+(D--_DSTEP),%110000
         Add D,_DSTEP
      Until D<RNG_T
      LXR2=XR2
   End If 
   If XR2<LXR2
      D=RNG_B
      Repeat 
         Screen Copy 1,XR2,D--_DSTEP,LXR2+1,D To 0,XR2,HDR_H+(D--_DSTEP)
         Add D,_DSTEP
      Until D<RNG_T
      LXR2=XR2
   End If 
End If 
RNGEND:
Gosub DRWMARKS
Gosub SETZN
If RL>1 and Fn MOUSEUP Then Gosub CAL_BCK
Goto HEADERCORDS
'
DRWRNGL:
If RNGEPLY
   If RST+RFIN=0
      FI=P_LENGTH
   Else 
      STA=RST
      FI=P_LENGTH-RFIN
   End If 
End If 
If XR>XR2
   If LXR<XR2
      D=RNG_B
      Repeat 
         Screen Copy 1,LXR,D--_DSTEP,XR2,D To 0,LXR,HDR_H+(D--_DSTEP)
         Add D,_DSTEP
      Until D<RNG_T
      LXR=XR2
   End If 
   If XR>LXR2
      D=RNG_B
      Repeat 
         Screen Copy 1,LXR2,D--_DSTEP,XR,D To 0,LXR2,HDR_H+(D--_DSTEP),%11000
         Add D,_DSTEP
      Until D<RNG_T
      LXR2=XR
   End If 
   If XR<LXR2
      D=RNG_B
      Repeat 
         Screen Copy 1,XR,D--_DSTEP,LXR2+1,D To 0,XR,HDR_H+(D--_DSTEP)
         Add D,_DSTEP
      Until D<RNG_T
      LXR2=XR
   End If 
Else 
   If LXR2>XR2
      D=RNG_B
      Repeat 
         Screen Copy 1,XR2,D--_DSTEP,LXR2+1,D To 0,XR2,HDR_H+(D--_DSTEP)
         Add D,_DSTEP
      Until D<RNG_T
      LXR2=XR2
   End If 
   If XR>LXR
      D=RNG_B
      Repeat 
         Screen Copy 1,LXR,D--_DSTEP,XR,D To 0,LXR,HDR_H+(D--_DSTEP)
         Add D,_DSTEP
      Until D<RNG_T
      LXR=XR
   End If 
   If XR<LXR
      D=RNG_B
      Repeat 
         Screen Copy 1,XR,D--_DSTEP,LXR+1,D To 0,XR,HDR_H+(D--_DSTEP),%110000
         Add D,_DSTEP
      Until D<RNG_T
      LXR=XR
   End If 
End If 
Goto RNGEND
'
CLRRNG:
D=RNG_B
Repeat 
   Screen Copy 1,XR,D--_DSTEP,XR2+1,D To 0,XR,HDR_H+(D--_DSTEP)
   Add D,_DSTEP
Until D<RNG_T
Return 
'
XRSWAP:
If XR>XR2
   XR=XR2 xor XR : XR2=XR2 xor XR : XR=XR xor XR2
   Gosub SETSELCORDS
End If 
Return 
'
SETSELV:
P_LENGTH=Length(PBANK)
If Fn STEREO
   P_LENGTH=P_LENGTH/2
Else If Fn QUAD
   P_LENGTH=P_LENGTH/4
End If 
If L>0 Then CON#=L/SCR_W# Else CON#=P_LENGTH/SCR_W#
Return 
'
SETSELCORDS:
Gosub SETSELV
RST#=XR*CON#
RFIN#=(SCR_W-XR2)*CON#
CON#=P_LENGTH/SCR_W#
ST#=XD*CON#
FIN#=(SCR_W-XD2)*CON#
RST#=ST#+RST#
RST=Int(RST#)
ST=Int(ST#)
FIN=Int(FIN#)
L=P_LENGTH-ST-FIN
RFIN#=FIN#+RFIN#
RFIN=Int(RFIN#)
If RFIN<0 Then RFIN=0
RL=P_LENGTH-RST-RFIN
Return 
'
SETLSELCORDS:
Gosub SETSELV
RST#=XR*CON#
CON#=P_LENGTH/SCR_W#
ST#=XD*CON#
RST#=ST#+RST#
RST=Int(RST#)
ST=Int(ST#)
L=P_LENGTH-ST-FIN
If XR=0 and XR=XR2 Then RL=0 Else RL=P_LENGTH-RST-RFIN
Return 
'
SETRSELCORDS:
Gosub SETSELV
RFIN#=(SCR_W-XR2)*CON#
CON#=P_LENGTH/SCR_W#
ST#=XD*CON#
FIN#=(SCR_W-XD2)*CON#
FIN=Int(FIN#)
L=P_LENGTH-ST-FIN
RFIN#=FIN#+RFIN#
RFIN=Int(RFIN#)
If RFIN<0 Then RFIN=0
If XR=0 and XR=XR2 Then RL=0 Else RL=P_LENGTH-RST-RFIN
Return 
'
BANKSET:
If Fn MULTI
   If Fn INVIEW
      RNG_T=1+(WVE_D*(B-1)) : RNG_B=WVE_D+(WVE_D*(B-1))
   End If 
Else 
   RNG_T=0 : RNG_B=WVE_H
End If 
Return 
'
_RANGESET:
_RST=RST
_RFIN=RFIN
_RL=RL
Return 
'
_RANGERESTORE:
RST=_RST
RFIN=_RFIN
RL=_RL
Return 
'
'
'
'***************************************************************************** 
'*file************************************************************************ 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    .-:::::' :::    :::    .,:::::: 
'    ;;;'''', ;;;    ;;;    ;;;;'''' 
'    [[[,,==[ [[[    [[[     [[cccc  
'    `$$$"``" $$$,   $$'     $$""""  
'   _ 888    o88888o88oo,.__ 888oo,_ 
'   MM"MM,   MMM"MM"""YUMMMM """"YUM 
'
'
'
_NEW:
If Not MACRO
   BTXT1$="New" : TXT1$="Clear the current" : TXT2$="waveform?" : Gosub _REQUEST
   If Not REQ
      Return 
   End If 
End If 
If B=UB Then Gosub _CLEARUNDO
If Fn MULTI Then Gosub CLRPLY Else Gosub _STOP
Erase PBANK
F$=_$ : Gosub SETFILENAME
Gosub CLRMETA
XD=0 : XD2=SCR_W : XR=0 : XR2=0 : ST=0 : FIN=0 : RST=0 : RFIN=0 : RL=0 : STA=0 : FI=0
Gosub SETPBANK
RENDERING=True
Gosub _DRAW
RENDERING=False
Gosub HEADER
Goto MAGICWAND
'
_OPEN:
PB=B
_APPEND=B-1 : Rem always insert
WTXT$="Open"
Goto O
_APPEND:
PB=B
_APPEND=B-1
If Fn MULTI Then PBANK=B+7
N=Length(PBANK)
While N>0
   Inc B
   Inc _APPEND
   N=Length(B+7)
Wend 
If PB-B
   LB=PB : Gosub SETBANK : PB=LB
End If 
WTXT$="Append"
O:
WTXT$=WTXT$+": raw iff aif wav cat abk med"
PF$=F$ : F$=LF$ : RST=0 : RL=0 : _RST=0 : _RL=0
Gosub FREQUEST
If Not FRQ
   Swap B,PB
   If B-PB
      Gosub SETBANK
      PF$=F$
   End If 
   F$=PF$
   Return 
End If 
_OPENF:
If Not Exist(F$)
   Gosub CANTFIND
   F$=PF$
   Return 
End If 
RENDERING=True : _TEXT=True
If B=UB Then Gosub _CLEARUNDO
_CHANNELS=1 : _RATE=0 : _TAG=0 : _BITS=8
BANKNAME$=_$ : _MULTIPLE=False
_IFF=False : _WAV=False : _FLOAT=False : _INTERLEAVED=True
_NAME$=_$ : _CPYR$=_$ : _AUTH$=_$ : _TXT$=_$ : _ANNO$=_$ : _UNTY=$10000
F:
Trap Open In 1,F$
If Errtrap Then Goto FILEERROR
LF=Lof(1)
If LF=0
   F$=PF$
   Close 1
   Return 
End If 
Gosub SETFILENAME
FH$=Input$(1,4)
If FH$="PP20"
   Gosub POWERPACKER
   Goto F
Else If FH$="PACK" or FH$="SFCD"
   TXT1$=FH$+" format" : TXT2$="not decompressed" : Gosub _NOTICE
   F$=PF$
   Close 1
   Return 
Else If FH$="CAT "
   _MULTIPLE=True
   Gosub OPENCAT
Else If FH$="AmBk"
   _MULTIPLE=True
   Gosub OPENABK
Else If Mid$(FH$,0,3)="MMD"
   _MULTIPLE=True
   Gosub OPENMMD
Else 
   If FH$="FORM"
      _IFF=True
   Else If FH$="RIFF"
      _WAV=True
   End If 
   If Fn MULTI and _APPEND>0
      PBANK=_APPEND+8
   End If 
   Trap Reserve As Work PBANK,_KILOBYTE
   If Errtrap
      Close 1
      F$=_$
      Goto NOMEMORY
   End If 
   Pof(1)=0
   Sload 1 To PBANK,_KILOBYTE
   Gosub PARSEHEADER
   Gosub SETMETA
   S_START=S_START-Start(PBANK)
   If S_LENGTH=0
      S_LENGTH=LF-S_START
   End If 
   Trap Reserve As Work PBANK,S_LENGTH
   If Errtrap
      Close 1
      F$=_$
      Goto NOMEMORY
   End If 
   Gosub HEADER
   Pof(1)=S_START
   Sload 1 To PBANK,S_LENGTH
   Close 1
   B=1+_APPEND : PB=1+_APPEND : F$=FB$(1+_APPEND)
End If 
If _RATE>0
   If Fn MONOORSTEREOORQUAD or _APPEND=0
      T$=Str$(_RATE)
      Gosub ŻFREQ
      Gosub DIALMAIN
   End If 
End If 
If Not MACRO
   If NN>0
      Gosub _NOTICE : NN=0
   End If 
End If 
S$=_$
PMACRO=MACRO
MACRO=True
If _IFF
   If _BITS>8 or _TAG>0
      If Fn MONOORSTEREOORQUAD or Fn MULTIINVIEW
         Gosub _STOP
      End If 
   End If 
   If _IFF
      If _TAG=1
         _TOAST$=_TOAST$+"Fibonacci Delta "
      Else If _TAG=2
         _TOAST$=_TOAST$+"Exponential Delta "
      End If 
   End If 
   If _BITS=16
      Gosub _16BITTO8BIT
   Else If _BITS=24
      Gosub _24BITTO8BITFLIP
   Else If _BITS=32 and _FLOAT
      Gosub _32BITTO8BIT
   End If 
Else If _WAV
   If Fn MONOORSTEREOORQUAD or Fn MULTIINVIEW
      Gosub _STOP
   End If 
   If _BITS=8
      Gosub _8BITUNSIGNEDTO8BIT
   Else If _BITS=16
      Gosub _16BITTO8BITFLIP
   Else If _BITS=24
      Gosub _24BITTO8BITFLIP
   Else If _BITS=32 and _FLOAT
      Gosub _32BITTO8BITFLIP
   Else If _TAG=0
      TXT1$="Encoding not" : TXT2$="decoded" : Gosub _NOTICE
      _CHANNELS=1
   End If 
End If 
_MODEP=_MODE
If _CHANNELS>1
   If _INTERLEAVED
      Gosub _DEINTERLEAVE
   End If 
   If _CHANNELS>2
      If _INTERLEAVED
         Gosub _DEINTERLEAVE
      End If 
      If Fn MONOORSTEREOORQUAD
         _MODE=3
      End If 
   Else If Fn MONOORSTEREOORQUAD
      _MODE=2
   End If 
Else If _MULTIPLE and _APPEND=0
   _MODE=4
   Gosub R4INSET
Else If _CHANNELS=1 and Fn MONOORSTEREOORQUAD
   _MODE=1
End If 
MACRO=PMACRO
XD=0 : XD2=SCR_W : XR=0 : XR2=0 : ST=0 : FIN=0 : RST=0 : RFIN=0 : RL=0
STA=0 : Gosub PBANKLEN
RENDERING=False
If _MODEP-_MODE
   _M3SEL=_MODE
   _MODE=_MODEP
   Gosub M0DEMENU
   Gosub SETZN
   Gosub HEADER
Else 
   Gosub _SHOWALL
End If 
Gosub SETPBANK
If Fn MULTI
   Gosub SETBANK
   Gosub POSCAL
End If 
If _IFF
   If _TAG>0
      RST=0 : RL=P_LENGTH
      On _TAG Gosub _DECODEFIBONACCIDELTA,_DECODEEXPONENTIALDELTA
      RL=0
      Gosub _SHOWALL
   End If 
   If HI_REPEAT>0
      HI_REPEAT=0
      RST=_RST : RL=_RL
      Gosub _SHOWALL
      Gosub FRSHSEL
   End If 
End If 
COMP(B)=0
Q:
_TEXT=False : RENDERING=False
If _PPCOMPRESSED
   _PPCOMPRESSED=False
   Kill _DEFAULT$
   Dir$=PPROGDIR$
   Gosub RSTFILES
End If 
Goto MAGICWAND
'  
'***************************************************************************** 
'    ¦   ¦¦ ¦¦¦  ¦  ¦ ¦ ¦¦¦ ¦¦ 
'   ¦ ¦ ¦    ¦  ¦ ¦ ¦¦¦ ¦   ¦ ¦
'   ¦ ¦ ¦    ¦  ¦¦¦ ¦¦¦ ¦¦  ¦ ¦
'   ¦ ¦ ¦    ¦  ¦ ¦ ¦ ¦ ¦   ¦ ¦
'    ¦   ¦¦  ¦  ¦ ¦ ¦ ¦ ¦¦¦ ¦¦   
'  
OPENMMD:
_REMAP=True
BANKNAME$=F$ : PB=PBANK
Pof(1)=32 : Rem expdata
S$=Input$(1,4) : P=Leek(Varptr(S$)) : Rem exp pointer
Pof(1)=P+4
S$=Input$(1,4) : P=Leek(Varptr(S$)) : Rem exp_smp pointer
S$=Input$(1,2) : ENTRIES=Deek(Varptr(S$)) : Rem s_ext_entries
S$=Input$(1,2) : ENTSIZE=Deek(Varptr(S$)) : Rem s_ext_entrsz   
Pof(1)=P
For I=1 To ENTRIES
   S$=Input$(1,ENTSIZE)
   CN=Peek(Varptr(S$)+3)
   Gosub SIGN
   RANDRSL(I)=CN : Rem strans 
Next I
Pof(1)=8 : Rem song pointer 
S$=Input$(1,4) : P=Leek(Varptr(S$))
If Not MACRO
   BTXT1$=_OK$ : TXT1$="Octamed module music" : TXT2$="as waveforms?" : Gosub _REQUEST
Else 
   REQ=False
End If 
If REQ
   Gosub _STOP : SEQ$=_$
   Pof(1)=P
   For I=1 To 63
      S$=Input$(1,8)
      CN=Peek(Varptr(S$)+7) : Rem strans 
      Gosub SIGN
      MM(I)=CN : Rem transpose
   Next I
   Rem P+504  
   S$=Input$(1,2) : NUMBLOCKS=Deek(Varptr(S$))
   Pof(1)=P+764
   S$=Input$(1,2) : DEFTEMPO#=Deek(Varptr(S$))
   Pof(1)=P+767
   S$=Input$(1,1) : FLAGS=Peek(Varptr(S$))
   S$=Input$(1,1) : FLAGS2=Peek(Varptr(S$))
   S$=Input$(1,1) : TEMP02=Peek(Varptr(S$))
   If Btst(7,FLAGS2) : Rem mixing   
      _OCTAVE=1
   Else 
      _OCTAVE=3
   End If 
   If Btst(6,FLAGS) : Rem 5-8 channel
      If DEFTEMPO#>10
         DEFTEMPO#=10
      End If 
      If DEFTEMPO#=10 and TEMP02=4
         DEFTEMPO#=147
      Else If DEFTEMPO#=9 and TEMP02=4
         DEFTEMPO#=160
      Else If DEFTEMPO#=7 and TEMP02=4
         DEFTEMPO#=172
      Else If DEFTEMPO#=6 and TEMP02=4
         DEFTEMPO#=182
      Else If DEFTEMPO#=9 and TEMP02=5
         DEFTEMPO#=124
      Else If DEFTEMPO#=8 and TEMP02=5
         DEFTEMPO#=128
      Else If DEFTEMPO#=7 and TEMP02=5
         DEFTEMPO#=142
      Else If DEFTEMPO#=5 and TEMP02=5
         DEFTEMPO#=160
      Else If DEFTEMPO#=2 and TEMP02=5
         DEFTEMPO#=192
      Else If DEFTEMPO#=10 and TEMP02=6
         DEFTEMPO#=100
      Else If DEFTEMPO#=9 and TEMP02=6
         DEFTEMPO#=112
      Else If DEFTEMPO#=8 and TEMP02=6
         DEFTEMPO#=117
      Else If DEFTEMPO#=9 and TEMP02=8
         DEFTEMPO#=78
      Else 
         DEFTEMPO#=(DEFTEMPO#+27)*(TEMP02-2)
      End If 
   Else 
      If Btst(5,FLAGS2) : Rem bpm
         DEFTEMPO#=(DEFTEMPO#/TEMP02)*12
      Else : Rem spd  
         DEFTEMPO#=(DEFTEMPO#-2)*(TEMP02-2)
      End If 
   End If 
   _REMAP=False
   Pof(1)=16
   S$=Input$(1,4) : DP=Leek(Varptr(S$)) : Rem pointer to blockarr pointer      
   If NUMBLOCKS>1 and Not MACRO
      S$="Choose Block"
      Gosub _OPENFXTEXTWIN
      TXT1$="1.."+Str$(NUMBLOCKS)-_SPACE$+_COLON$
      Gosub _RUNFXTEXTWIN
      If Not REQ
         F$=PF$
         Close 1
         Goto Q
      End If 
      If T$=_$
         AC=1
      Else 
         AC=Val(T$)
         If AC<1
            AC=1
         Else If AC>NUMBLOCKS
            AC=NUMBLOCKS
         End If 
      End If 
   Else 
      AC=1
   End If 
   For I=1 To NUMBLOCKS
      Pof(1)=DP : S$=Input$(1,4) : DP=Pof(1)
      If I=AC : Rem find block 
         P=Leek(Varptr(S$))
         If P>0
            Pof(1)=P
            S$=Input$(1,2) : TRACKS=Deek(Varptr(S$))
            S$=Input$(1,2) : LINES=Deek(Varptr(S$)) : Inc LINES
            S$=Input$(1,4) : Rem blockinfo pointer
            SZ=TRACKS*4*LINES
            S_LENGTH=Int(FREQ/((DEFTEMPO#/4/60)/(Max(16,LINES)/16)))
            DISPATCH$="D="+Str$(LINES)-_SPACE$+",M=4,B=1,"
            _TOAST$=Str$(TRACKS)-_SPACE$+" Tracks "
            If B=1
               Repeat 
                  Reserve As Work B+7,S_LENGTH
                  F$="Track"+Str$(B) : Gosub SETFILENAME : Gosub CLRMETA
                  Inc B
               Until B>TRACKS
               _APPEND=_APPEND+TRACKS
               B=1+_APPEND
            End If 
            If SZ>0
               Trap S$=Input$(1,SZ)
               If Errtrap
                  Goto NOSPACEERROR
               End If 
               Gosub MEDTOSEQUENCE
            End If 
         End If 
      End If 
   Next I
End If 
SEQ$=SEQ$+"B=1,_SHOWALL,"+_NEWLINE$
NN=0 : N=B
Pof(1)=32 : Rem expdata
S$=Input$(1,4) : P=Leek(Varptr(S$)) : Rem exp pointer
Pof(1)=P+20
S$=Input$(1,4) : P=Leek(Varptr(S$)) : Rem iinfo pointer  
S$=Input$(1,2) : ENTRIES=Deek(Varptr(S$)) : Rem entries
S$=Input$(1,2) : ENTSIZE=Deek(Varptr(S$)) : Rem entrsz   
Pof(1)=P
For I=1 To ENTRIES
   S$=Input$(1,ENTSIZE)
   P=Peek(Varptr(S$))
   If P>0
      For I2=1 To Text Length(S$)
         CN=Peek(Varptr(S$)+I2)
         Exit If CN=0
      Next I2
      NAME$(I)=Mid$(S$,0,I2)
   Else 
      NAME$(I)=_UNNAMED$
   End If 
Next I
Pof(1)=24
S$=Input$(1,4) : DP=Leek(Varptr(S$)) : Rem pointer to smplarr pointer 
FX_START=0 : FX=0
FX_LENGTH=Lof(1)
For I=1 To ENTRIES
   Pof(1)=DP : S$=Input$(1,4) : DP=Pof(1) : P=Leek(Varptr(S$))
   If P>0
      Pof(1)=P
      S$=Input$(1,4) : SZ=Leek(Varptr(S$)) : Rem sample length        
      If SZ>0
         S$=Input$(1,2) : _BITS=Deek(Varptr(S$)) : Rem sample type            
         If _BITS=16 : Rem 16bit mono   
         Else If _BITS=32 : Rem 8bit stereo  
            Add SZ,SZ
            _BITS=8
         Else If _BITS=48 : Rem 16bit stereo 
            Add SZ,SZ
            _BITS=16
         Else : Rem 8bit 
            _BITS=8
         End If 
         Trap Reserve As Work 7+N,SZ
         If Errtrap
            Close 1
            F$=_$
            Goto NOMEMORY
         End If 
         Gosub HEADER
         AC=Start(7+N)
         Sload 1 To AC,SZ
         FX=FX+SZ
         F$=NAME$(I)
         B=N : Gosub SETFILENAME
         _NAME$=F$ : Gosub SETMETA
         If _BITS=16
            PBANK=B+7
            Gosub _16BITTO8BIT
         End If 
         If _REMAP
            Inc N
         End If 
         Inc NN
      End If 
   End If 
   If Not _REMAP
      Inc N
   End If 
Next I
FX=FXE
Close 1
If Fn MONOORSTEREOORQUAD
   Bank Swap PB,8+_APPEND
End If 
PBANK=PB : B=1+_APPEND : PB=B : F$=FB$(B) : _CHANNEL=1
Gosub DISPATCH
If Not MACRO
   TXT1$="Octamed module loaded" : TXT2$="with"+Str$(NN)+" samples" : Rem _NOTICE  
End If 
_TEXT=True
Return 
'
MEDTOSEQUENCE:
NN=0
_CHANNEL=0
_I=0
For I=0 To Len(S$)-1 Step 4
   Inc _CHANNEL
   CN=Varptr(S$) : Add CN,I
   'xnnnnnnn xxiiiiii cccccccc dddddddd 
   _NOTE=Peek(CN) : Inc CN : Rem 0 - $7F
   _INST=Peek(CN) : Inc CN : Rem 0 - $3F
   _CMND=Peek(CN) : Inc CN : Rem 0 - $FF
   _DATA=Peek(CN) : Rem 0 - $FF
   If _INST=0 and _NOTE>0
      _INST=INST(_CHANNEL)
   End If 
   If _I<>_INST and _INST>0
      SL$=SL$+"B="+Str$(_INST+_APPEND)-_SPACE$+",_COPY,"
      INST(_CHANNEL)=_INST
      _I=_INST
   End If 
   SL$=SL$+"B="+Str$(_CHANNEL)-_SPACE$
   If _NOTE>0
      _NOTE=_NOTE+MM(_INST) : Rem transpose          
      If RANDRSL(_INST)<>0
         Trap SL$=SL$+",FINE="+Str$(RANDRSL(_INST))-_SPACE$ : Rem finetune 
         If Errtrap
            Goto NOSPACEERROR
         End If 
         Trap SL$=SL$+",NOTE="+Str$(_NOTE)-_SPACE$+",_RENDER,"
      Else 
         CN=_NOTE/12
         CN2=_NOTE-(CN*12)
         If CN2=0
            Dec CN
         End If 
         Trap SL$=SL$+",NOTE="+CHROM$(CN2)+Str$(CN+_OCTAVE)-_SPACE$+",_RENDER," : Rem octave 
      End If 
      If Errtrap
         Goto NOSPACEERROR
      End If 
   Else 
      SL$=SL$+",_NOP,"
   End If 
   Inc NN
   If NN=TRACKS
      Trap SEQ$=SEQ$+"_NDPQ,"+SL$+_NEWLINE$ : Rem no dispatch queue
      If Errtrap
         Goto NOSPACEERROR
      End If 
      SL$=_$
      _CHANNEL=0
      NN=0
   End If 
Next I
Return 
'
'***************************************************************************** 
'    ¦  ¦ ¦  ¦   ¦¦    ¦¦   ¦  ¦¦¦ ¦ ¦ 
'   ¦ ¦ ¦¦¦ ¦ ¦ ¦      ¦ ¦ ¦ ¦ ¦ ¦ ¦ ¦ 
'   ¦¦¦ ¦¦¦ ¦ ¦  ¦     ¦¦  ¦¦¦ ¦ ¦ ¦¦
'   ¦ ¦ ¦ ¦ ¦ ¦   ¦    ¦ ¦ ¦ ¦ ¦ ¦ ¦ ¦ 
'   ¦ ¦ ¦ ¦  ¦  ¦¦     ¦¦  ¦ ¦ ¦ ¦ ¦ ¦ 
'
OPENABK:
BANKNAME$=F$
If LF<22
   Close 1
   F$=PF$
   TXT1$="Amos bank invalid" : TXT2$=_$ : Goto _ERROR
End If 
S$=Input$(1,4) : Rem (1,2) 5 (1,2) 0
S$=Input$(1,4)
Gosub MEMORY
If MEMORY<(Leek(Varptr(S$)) xor $80000000)
   Close 1
   F$=PF$
   Goto NOMEMORY
End If 
S$=Input$(1,8)
If S$<>"Samples "
   Close 1
   F$=PF$
   TXT1$="Not a sample bank" : TXT2$=_$ : Goto _ERROR
End If 
S$=Input$(1,2) : NN=Deek(Varptr(S$))
If Eof(1)
   Close 1
   F$=PF$
   TXT1$="Empty sample bank" : TXT2$=_$ : Goto _NOTICE
End If 
SF$=Input$(1,4) : SL=Leek(Varptr(SF$)) : If SL>6 : SF$=SF$+Input$(1,SL-6) : End If 
FX=0 : FX_START=0 : FX_LENGTH=Lof(1) : FXE=FX_LENGTH
For N=1 To NN
   If Leek(Varptr(SF$)+(N-1)*4)
      If Eof(1)
         TXT1$="Error loading"+Str$(N)+Str$(NN) : TXT2$="bank, continuing..." : Gosub _ERROR
         _TEXT=True
         Exit 
      End If 
      S$=Input$(1,14)
      For CHR=1 To 7
         If Peek(Varptr(S$)+CHR)=0
            Exit 
         End If 
      Next CHR
      F$=Left$(S$,CHR)
      B=N+_APPEND : Gosub SETFILENAME
      _NAME$=F$ : Gosub SETMETA
      _RATE=Deek(Varptr(S$)+8)
      SZ=Leek(Varptr(S$)+10)
      If SZ mod 2=1
         SZ=SZ+1
      End If 
      If SZ>0
         Trap Reserve As Work 7+N+_APPEND,SZ
         If Errtrap
            Close 1
            F$=_$
            Goto NOMEMORY
         End If 
         Gosub HEADER
         AC=Start(7+N+_APPEND)
         P=0
         Sload 1 To AC,SZ
         FX=FX+SZ
      End If 
   End If 
Next 
FX=FXE
Close 1
If Fn MONOORSTEREOORQUAD
   Bank Swap PBANK,8+_APPEND
End If 
B=1+_APPEND : PB=B : F$=FB$(B)
If Not MACRO
   TXT1$="Amos Bank loaded" : TXT2$="with"+Str$(NN)+" samples" : Rem _NOTICE  
End If 
_TEXT=True
Return 
'
'***************************************************************************** 
'   ¦¦¦ ¦¦¦ ¦¦¦     ¦¦  ¦  ¦¦¦ 
'    ¦  ¦   ¦      ¦   ¦ ¦  ¦
'    ¦  ¦¦  ¦¦     ¦   ¦¦¦  ¦
'    ¦  ¦   ¦      ¦   ¦ ¦  ¦
'   ¦¦¦ ¦   ¦       ¦¦ ¦ ¦  ¦
'
OPENCAT:
BANKNAME$=F$
N=B : PB=PBANK : NN=0
S$=Input$(1,4)
SL=Leek(Varptr(S$))
SZ=12
Repeat 
   PBANK=7+N
   Trap Reserve As Work PBANK,_KILOBYTE
   If Errtrap
      Close 1
      F$=_$
      Goto NOMEMORY
   End If 
   Pof(1)=SZ
   Sload 1 To PBANK,_KILOBYTE
   _IFF=True
   Gosub PARSEHEADER
   If _IFF
      S_START=S_START-Start(PBANK)
      Trap Reserve As Work PBANK,S_LENGTH
      If Errtrap
         Close 1
         F$=_$
         Goto NOMEMORY
      End If 
      Gosub HEADER
      Gosub T0AST
      Pof(1)=S_START+SZ
      Sload 1 To PBANK,S_LENGTH
      B=N : F$=_NAME$ : Gosub SETFILENAME
      Gosub SETMETA
      If _TAG>0
         If _CHANNELS>1
            _MODE=2
         End If 
         Gosub SETPBANK
         RST=0 : RL=P_LENGTH
         On _TAG Gosub _DECODEFIBONACCIDELTA,_DECODEEXPONENTIALDELTA
         RL=0
         _TAG=0
      End If 
      _IFF=False
      Inc N : Inc NN
   Else 
      Erase PBANK
   End If 
   SZ=SZ+F_LENGTH
Until SZ>=SL or F_LENGTH=0
Close 1
If Fn MONOORSTEREOORQUAD
   Bank Swap PB,8+_APPEND
End If 
PBANK=PB : B=1+_APPEND : PB=1+_APPEND : F$=FB$(1+_APPEND)
If Not MACRO
   TXT1$="Iff Cat loaded" : TXT2$="with"+Str$(NN)+" samples" : Rem _NOTICE  
End If 
_TEXT=True
Return 
'
'***************************************************************************** 
'
_OPENASRAW:
WTXT$="Open As: raw"
PF$=F$ : F$=LF$
Gosub FREQUEST
If Not FRQ
   F$=PF$
   Return 
Else If Not Exist(F$)
   Gosub CANTFIND
   F$=PF$
   Return 
End If 
Gosub SETFILENAME
Gosub CLRMETA
If Fn MONOORSTEREOORQUAD or Fn MULTIINVIEW
   Gosub _STOP
End If 
If B=UB Then Gosub _CLEARUNDO
R:
Trap Open In 1,F$
If Errtrap Then Goto FILEERROR
LF=Lof(1)
If LF=0
   Close 1
   Return 
End If 
XD=0 : XD2=SCR_W : XR=0 : XR2=0 : ST=0 : FIN=0 : RST=0 : RFIN=0 : RL=0 : STA=0 : FI=0
FH$=Input$(1,4)
_BITS=0
If FH$="PP20"
   Gosub POWERPACKER
   Goto R
Else If FH$="FORM"
   _IFF=True : _WAV=False
Else If FH$="RIFF"
   _WAV=True : _IFF=False
End If 
Trap Reserve As Work PBANK,_KILOBYTE
If Errtrap
   Close 1
   F$=_$
   Goto NOMEMORY
End If 
_TEXT=True
Pof(1)=0
Sload 1 To PBANK,_KILOBYTE
Gosub PARSEHEADER
If _IFF
   H_POS=S_START
   S_START=Hunt(H_POS To H_LENGTH,"BODY")
   If S_START>0
      Add S_START,4 : S_LENGTH=Leek(S_START) : Add S_START,4
   Else 
      S_START=H_POS
   End If 
   Gosub SETMETA
Else 
   COMP(B)=0
End If 
S_START=S_START-Start(PBANK)
If S_LENGTH=0
   S_LENGTH=LF-S_START
End If 
Trap Reserve As Work PBANK,S_LENGTH
If Errtrap
   Close 1
   F$=_$
   Goto NOMEMORY
End If 
Gosub HEADER
Pof(1)=S_START
Sload 1 To PBANK,S_LENGTH
Close 1
TXT1$=_TOAST$
If _CHANNELS=1
   TXT2$="Mono"
Else If _CHANNELS=2
   TXT2$="Stereo"
Else If _CHANNELS=4
   TXT2$="Quad"
End If 
_CHANNELS=1
If _BITS>0
   _TOAST$="Header Removed "
   Gosub _NOTICE
   If -_MODE-1 and Fn MONOORSTEREOORQUAD
      _M3SEL=1
      Gosub M0DEMENU
   End If 
Else 
   _BITS=8
End If 
Gosub _SHOWALL
_TEXT=False
Return 
'  
_REVERT:
If F$=_$ and BANKNAME$=_$ Then Goto FLSHSCR
BTXT1$=_OK$ : TXT1$="Are you sure?" : TXT2$="You will loose edits" : Gosub _REQUEST
If Not REQ Then Return 
If FB$(B)=_UNNAMED$ or FPATH$(B)=_$ Then Goto FLSHSCR
If Fn A500 Then Gosub _STOP
If BANKNAME$<>_$ Then F$=BANKNAME$
PPROGDIR$=Dir$
Dir$=FPATH$(B)
_APPEND=B-1
Gosub _OPENF
Dir$=PPROGDIR$
Goto SETPBANK
'
_SAVEASIFF:
_ASIFF=True
WTXT$="iff"
Goto _SAVE
_SAVEAS:
_ASIFF=False
WTXT$="raw"
_SAVE:
If Length(PBANK)=0 Then Goto FLSHSCR
_TEXT=True
PF$=F$
WTXT$="Save As: "+WTXT$
Gosub FREQUEST
If Not FRQ
   F$=PF$
   Return 
End If 
Gosub CLEANFILENAME
If Exist(F$)
   Gosub OVERWRITE
   If Not REQ
      F$=PF$
      Return 
   End If 
End If 
Trap Open Out 1,F$
If Errtrap
   F$=PF$
   Goto FILEERROR
End If 
S_START=Start(PBANK) : S_LENGTH=Length(PBANK)
If _ASIFF
   Gosub _IFFHEADER
   Ssave 1,Varptr(T$) To Varptr(T$)+Len(T$)
End If 
Ssave 1,S_START To S_START+S_LENGTH
If _PAD : Rem odd sizes have a pad byte
   Ssave 1,Varptr(_NULL$) To Varptr(_NULL$)+1
   Inc S_LENGTH
End If 
Close 1
Gosub SETFILEPOS
Gosub SETFILENAME
Gosub HEADER
_TEXT=False
Return 
'
_SAVEASCAT:
_TEXT=True
PF$=F$
If BANKNAME$<>_$ Then F$=BANKNAME$ Else F$=_DEFAULT$+Lower$(_CAT$)
WTXT$="Save As: cat"
If Right$(Upper$(F$),4)=_ABK$ Then Right$(F$,4)=Lower$(_CAT$)
Gosub FREQUEST
If Not FRQ
   F$=PF$
   Return 
End If 
Gosub CLEANFILENAME
If Right$(Upper$(F$),4)<>_CAT$ Then F$=F$+Lower$(_CAT$)
If Exist(F$)
   Gosub OVERWRITE
   If Not REQ
      F$=PF$
      Return 
   End If 
End If 
BANKNAME$=F$
If Fn MONOORSTEREOORQUAD
   Bank Swap PBANK,B+7
End If 
PB=B : B=1 : NN=0
Trap Open Out 1,F$
If Errtrap Then Goto FILEERROR
T$="CAT     8SVX"
Ssave 1,Varptr(T$) To Varptr(T$)+12
F_LENGTH=0
S_LENGTH=Length(B+7)
Repeat 
   Gosub _IFFHEADER
   Ssave 1,Varptr(T$) To Varptr(T$)+Len(T$)
   Ssave 1,Start(B+7) To Start(B+7)+S_LENGTH
   If _PAD : Rem odd sizes have a pad byte
      Ssave 1,Varptr(_NULL$) To Varptr(_NULL$)+1
   End If 
   F_LENGTH=F_LENGTH+S_LENGTH+Len(T$)
   Inc B : Inc NN
   S_LENGTH=Length(B+7)
Until S_LENGTH=0
Add F_LENGTH,4
Pof(1)=4
Ssave 1,Varptr(F_LENGTH) To Varptr(F_LENGTH)+4
Close 1
If Fn MONOORSTEREOORQUAD and Length(PBANK)=0 Then Bank Swap PBANK,PB+7
S_LENGTH=F_LENGTH
Gosub SETFILEPOS
F$=PF$ : B=PB
TXT1$="Iff Cat saved" : TXT2$="with"+Str$(NN)+" samples" : Goto _NOTICE
'
_SAVEASBANK:
_TEXT=True
PF$=F$
If BANKNAME$<>_$ Then F$=BANKNAME$ Else F$=_DEFAULT$+Lower$(_ABK$)
WTXT$="Save As: abk"
If Right$(Upper$(F$),4)=_CAT$ Then Right$(F$,4)=Lower$(_ABK$)
Gosub FREQUEST
If Not FRQ
   F$=PF$
   Return 
End If 
Gosub CLEANFILENAME
If Exist(F$)
   Gosub OVERWRITE
   If Not REQ
      F$=PF$
      Return 
   End If 
End If 
If Fn MONOORSTEREOORQUAD
   Bank Swap PBANK,B+7
End If 
PB=B : B=1
'***************************************************************************** 
'   Sample Bank Maker by François Lionet, AMOS version by P.J.Hickman    
'   © Copyright 1990 Mandarin Software 
'
ODD=False
For FIN=1 To 248
   S_LENGTH=Length(FIN+7)
   If(S_LENGTH/2)*2<S_LENGTH
      ODD=True
   End If 
   Exit If S_LENGTH=0
Next FIN
If ODD
   BTXT1$=_OK$ : TXT1$="Ignore the detected" : TXT2$="odd size?" : Gosub _REQUEST
   If Not REQ
      F$=PF$
      Return 
   End If 
End If 
TL=0 : TN=0
For N=1 To FIN
   If Length(7+N)>0
      TL=TL+Length(7+N)+4+14
      Inc TN
   End If 
Next 
S_LENGTH=TL+22
Trap Reserve As Work WBANK,S_LENGTH
If Errtrap Then Goto NOMEMORY
AD=Start(WBANK)
T$="AmBk"
For I=1 To Len(T$)
   Poke AD+I-1,Asc(Mid$(T$,I,1))
Next I
AD=AD+4
Doke AD,5
AD=AD+2
Doke AD,0
AD=AD+2
Loke AD,(TL+8) or $80000000
AD=AD+4
T$="Samples "
For I=1 To Len(T$)
   Poke AD+I-1,Asc(Mid$(T$,I,1))
Next I
AD=AD+8
ACALC=AD
Doke AD,TN
AD=AD+2
AOFF=AD
APOKE=AOFF+TN*4
NN=0
For N=1 To 248
   WEIGHTING=0
   If Length(7+N)>0
      Inc NN
      Loke AOFF,APOKE-ACALC
      AOFF=AOFF+4
      If FB$(N)=_$
         T$=Left$(_UNNAMED$,8)
      Else 
         T$=Left$(FB$(N),8)
      End If 
      AD=APOKE
      For I=1 To Len(T$)
         Poke AD+I-1,Asc(Mid$(T$,I,1))
      Next I
      Doke APOKE+8,FREQ
      Loke APOKE+10,Length(7+N)
      APOKE=APOKE+14
      A_START=Start(7+N)
      PP=Varptr(P)
      For I=0 To Length(7+N)
         P=Peek(A_START+I)+WEIGHTING
         Poke APOKE+I,Peek(PP+3)
      Next I
      APOKE=APOKE+Length(7+N)
      If Btst(0,APOKE)
         Inc APOKE
      End If 
   End If 
Next N
'
'***************************************************************************** 
If Right$(Upper$(F$),4)<>_ABK$ Then F$=F$+Lower$(_ABK$)
BANKNAME$=F$
Trap Open Out 1,F$
If Errtrap
   F$=PF$
   Goto FILEERROR
End If 
Ssave 1,Start(WBANK) To Start(WBANK)+S_LENGTH
Close 1
If Fn MONOORSTEREOORQUAD and Length(PBANK)=0 Then Bank Swap PBANK,PB+7
Gosub SETFILEPOS
F$=PF$ : B=PB
Gosub _CLEARWORK
Gosub SETBANK
TXT1$="Amos Bank saved" : TXT2$="with"+Str$(NN)+" samples" : Goto _NOTICE
'
_PROPERTIES:
_TEXT=True
WTXT$=S$ : WX=149 : WY=28 : WX2=490 : WY2=135 : _COL=_WHITE : Gosub WIN
Ink _BLACK,_WHITE
Text 272,56,"Name: "+NAME$(B)
Text 288,64,"(c) "+CPYR$(B)
Text 256,72,"Author: "+AUTH$(B)
Text 248,80,"Comment: "+TXT$(B)
Text 224,88,"Annotation: "+ANNO$(B)
Text 240,96,"Channels:"+Str$(_CHANNELS)
Text 216,104,"Compression:"
If COMP(B)=0
   T$="none"
Else If COMP(B)=1
   T$="fibonacci delta"
Else If COMP(B)=2
   T$="exponential delta"
End If 
Text 320,104,T$
Gosub WINWAITC
_TEXT=False
Return 
'
_QUIT:
If _STOP
   _STOP=False
   Return 
End If 
If _REPEAT$<>"_QUIT"
   If OSCILLO
      Goto _TGLOSCILLOSCOPE
   Else If CALC
      Goto _TGLCALCULATOR
   End If 
End If 
BTXT1$="Quit" : TXT1$="Are you sure" : TXT2$="you want to quit?" : Gosub _REQUEST
If Not REQ Then Return 
ŻQUIT:
Gosub _FULLSTOP
Every Off 
Erase Temp 
I=1
Repeat 
   Trap Close I
   Inc I
Until I>7
Rainbow Del 0
If REXX Then Arexx Close 
If MATH Then Lib Close 1
If BSD
   Gosub SOCK_CLOSESYNC
   Lib Close 2
End If 
If PP20 Then Lib Close 3
Trap Dir$=PROGDIR$
End 
'
_IFFHEADER:
T$="FORM"+_CHUNK$+"8SVXVHDR"+String$(_NULL$,24)
CN=Varptr(T$)+16
Loke CN,20 : Add CN,4
If COMP(B)>0
   If _CHANNELS=1
      FF_LENGTH=(S_LENGTH-2)*2
   Else If _CHANNELS=2
      FF_LENGTH=S_LENGTH-4
   Else If _CHANNELS=4
      FF_LENGTH=(S_LENGTH-8)/2
   End If 
Else 
   If _CHANNELS=2
      FF_LENGTH=S_LENGTH/2
   Else If _CHANNELS=4
      FF_LENGTH=S_LENGTH/4
   Else 
      FF_LENGTH=S_LENGTH
   End If 
End If 
Loke CN,FF_LENGTH : Add CN,4 : Rem oneShotHiSamples   
Loke CN,0 : Add CN,4 : Rem repeatHiSamples
Loke CN,32 : Add CN,4 : Rem samplesPerHiCycle
Doke CN,FREQ : Add CN,2 : Rem samplesPerSec
Poke CN,1 : Inc CN : Rem octave 
Poke CN,COMP(B) : Inc CN : Rem compression
Loke CN,VOL*1024 : Rem unity $00010000 $0000FFFF  
If NAME$(B)=_$
   If FB$(B)=_UNNAMED$
      S$=F$
   Else 
      S$=FB$(B)
   End If 
Else 
   S$=NAME$(B)
End If 
Gosub PROPLEN
_NAME$="NAME"+_CHUNK$+S$+_CHUNK$
Loke Varptr(_NAME$)+4,Len(_NAME$)-8
If CPYR$(B)<>_$
   S$=CPYR$(B)
   Gosub PROPLEN
   _CPYR$="(c) "+_CHUNK$+S$+_CHUNK$
   Loke Varptr(_CPYR$)+4,Len(_CPYR$)-8
Else 
   _CPYR$=_$
End If 
If AUTH$(B)<>_$
   S$=AUTH$(B)
   Gosub PROPLEN
   _AUTH$="AUTH"+_CHUNK$+S$+_CHUNK$
   Loke Varptr(_AUTH$)+4,Len(_AUTH$)-8
Else 
   _AUTH$=_$
End If 
If TXT$(B)<>_$
   S$=TXT$(B)
   Gosub PROPLEN
   _TXT$="TEXT"+_CHUNK$+S$+_CHUNK$
   Loke Varptr(_TXT$)+4,Len(_TXT$)-8
Else 
   _TXT$=_$
End If 
If ANNO$(B)<>_$
   S$=ANNO$(B)
Else 
   S$="FxBox"
End If 
Gosub PROPLEN
_ANNO$="ANNO"+_CHUNK$+S$+_CHUNK$
Loke Varptr(_ANNO$)+4,Len(_ANNO$)-8
If Fn STEREOORQUAD
   _CHAN$="CHAN"+_CHUNK$+_CHUNK$
   Loke Varptr(_CHAN$)+4,4
   If Fn STEREO
      Loke Varptr(_CHAN$)+8,6 : Rem STEREO 6L  
   Else If Fn QUAD
      Loke Varptr(_CHAN$)+8,30 : Rem QUAD 30L ea-iff-85.CHAN does not define quad     
   End If 
Else 
   _CHAN$=_$
End If 
_BODY$="BODY"+_CHUNK$
If(S_LENGTH/2)*2<S_LENGTH Then _PAD=1 Else _PAD=0 : Rem odd sizes have a pad byte  
Loke Varptr(_BODY$)+4,S_LENGTH+_PAD
T$=T$+_NAME$+_CPYR$+_AUTH$+_TXT$+_ANNO$+_CHAN$+_BODY$
Loke Varptr(T$)+4,S_LENGTH+_PAD+Len(T$)
Return 
'
PROPLEN:
H_LENGTH=Len(S$)
If(H_LENGTH/2)*2<H_LENGTH
   S$=S$+Chr$(0)
End If 
Return 
'
PARSEHEADER:
_CHANNELS=1
S_START=Start(PBANK) : S_LENGTH=0 : H_LENGTH=Start(PBANK)+Length(PBANK)
H_START=S_START
If _IFF
   H_POS=S_START
   S_START=Hunt(S_START To H_LENGTH,"FORM")
   If S_START=0
      S_START=H_POS
      _IFF=False
      Return 
   End If 
   Add S_START,4 : F_LENGTH=Leek(S_START) : Add S_START,4
   If F_LENGTH<Length(PBANK)
      H_LENGTH=S_START+F_LENGTH
   End If 
   H_POS=S_START
   S_START=Hunt(S_START To H_LENGTH,"8SVX")
   If S_START=0
      S_START=H_POS
      S_START=Hunt(S_START To H_LENGTH,"16SV")
      If S_START=0
         S_START=H_POS
         S_START=Hunt(S_START To H_LENGTH,"24SV")
         If S_START=0
            S_START=H_POS
            S_START=Hunt(S_START To H_LENGTH,"IESV")
            If S_START>0
               _BITS=32
               _FLOAT=True
            End If 
         Else 
            _BITS=24
         End If 
      Else 
         _BITS=16
      End If 
   Else 
      _BITS=8
   End If 
   If S_START>0
      T$="VHDR" : _FULLCHUNK=True : Gosub PARSECHUNK
      CN=Varptr(T$)
      If _BITS=8
         HI_LENGTH=Leek(CN) : Rem oneShotHiSamples 
      End If 
      Add CN,4
      HI_REPEAT=Leek(CN) : Add CN,8 : Rem repeatHiSamples
      _RATE=Deek(CN) : Add CN,2
      If _RATE=30464 or _RATE=22664 : Rem 96000 88200
         Add _RATE,65536
         Ink _PANE : Gosub AMIHZDIAL : _HIGHDIAL=False
         _AMIHZ=False
      End If 
      _OCTAVE=Peek(CN) : Inc CN
      _TAG=Peek(CN) : Inc CN
      _UNTY=Leek(CN)
      T$="NAME" : Gosub PARSECHUNK : _NAME$=T$
      T$="(c) " : Gosub PARSECHUNK : _CPYR$=T$
      T$="AUTH" : Gosub PARSECHUNK : _AUTH$=T$
      T$="TEXT" : Gosub PARSECHUNK : _TXT$=T$
      T$="ANNO" : Gosub PARSECHUNK : _ANNO$=T$
      T$="CHAN" : _FULLCHUNK=True : Gosub PARSECHUNK
      If T$<>_$
         _CHANNELS=Leek(Varptr(T$))
         If _CHANNELS=4 or _CHANNELS=2 : Rem RIGHT 4L LEFT 2L 
            _CHANNELS=1
         Else If _CHANNELS=6 : Rem STEREO 6L  
            _CHANNELS=2
            _INTERLEAVED=False
         Else If _CHANNELS=30 : Rem QUAD 30L 
            _CHANNELS=4
            _INTERLEAVED=False
         End If 
      Else 
         S_START=H_POS
      End If 
      H_POS=S_START
      S_START=Hunt(S_START To H_LENGTH,"BODY") : Add S_START,4
      If _OCTAVE>3
         S_START=S_START+((HI_LENGTH+HI_REPEAT)*3)
         _RST=HI_LENGTH*4
         HI_LENGTH=(HI_LENGTH+HI_REPEAT)*4
         _RL=HI_LENGTH-_RST
      Else If _OCTAVE>1
         S_START=S_START+HI_LENGTH+HI_REPEAT
         _RST=HI_LENGTH*2
         HI_LENGTH=(HI_LENGTH+HI_REPEAT)*2
         _RL=HI_LENGTH-_RST
      Else 
         _RST=HI_LENGTH
         HI_LENGTH=HI_LENGTH+HI_REPEAT
         _RL=HI_LENGTH-_RST
      End If 
      If _TAG>0
         If _CHANNELS=1
            HI_LENGTH=(HI_LENGTH/2)+2
         Else If _CHANNELS=2
            HI_LENGTH=HI_LENGTH+4
         Else If _CHANNELS=4
            HI_LENGTH=(HI_LENGTH*2)+8
         End If 
      Else If _CHANNELS=2
         HI_LENGTH=HI_LENGTH*2
      Else If _CHANNELS=4
         HI_LENGTH=HI_LENGTH*4
      End If 
      If HI_LENGTH>0
         S_LENGTH=HI_LENGTH
      Else 
         S_LENGTH=Leek(S_START)
      End If 
      Add S_START,4
      _TOAST$=_TOAST$+"Iff"
   Else 
      S_START=H_POS
      S_START=Hunt(S_START To H_LENGTH,"AIFF")
      If S_START=0
         S_START=H_POS
         S_START=Hunt(S_START To H_LENGTH,"AIFC")
         If S_START=0
            Add H_START,4
            S_START=H_START
            H_LENGTH=Leek(S_START)
            Add H_LENGTH,8
            S_LENGTH=H_LENGTH
            _IFF=False
            Return 
         End If 
      End If 
      T$="COMM" : _FULLCHUNK=True : Gosub PARSECHUNK
      _CHANNELS=Deek(Varptr(T$))
      _BITS=Deek(Varptr(T$)+6)
      _RATE=Deek(Varptr(T$)+10)
      H_POS=S_START
      S_START=Hunt(H_POS To H_LENGTH,"FL32")
      If S_START=0
         S_START=Hunt(H_POS To H_LENGTH,"fl32")
         If S_START=0
            S_START=H_POS
         End If 
      End If 
      If H_POS<>S_START
         _FLOAT=True
      End If 
      S_START=Hunt(S_START To H_LENGTH,"SSND")
      Add S_START,4 : S_LENGTH=Leek(S_START) : Add S_START,4
      _TOAST$=_TOAST$+"Aif"
   End If 
Else If _WAV
   S_START=Hunt(S_START To H_LENGTH,"fmt ")
   Add S_START,8 : _TAG=Peek(S_START)
   If _TAG=3 or _TAG=254
      _FLOAT=True
   Else If _TAG-1
      _TOAST$="("+Str$(_TAG)-_SPACE$+") "
      _TAG=0
   End If 
   Add S_START,2 : _CHANNELS=Peek(S_START) : Add S_START,2
   Poke Varptr(_RATE)+3,Peek(S_START) : Inc S_START
   Poke Varptr(_RATE)+2,Peek(S_START) : Inc S_START
   Poke Varptr(_RATE)+1,Peek(S_START) : Inc S_START
   Poke Varptr(_RATE),Peek(S_START) : Inc S_START
   Add S_START,6 : _BITS=Peek(S_START)
   S_START=Hunt(S_START To H_LENGTH,"data") : Add S_START,4
   Poke Varptr(S_LENGTH)+3,Peek(S_START) : Inc S_START
   Poke Varptr(S_LENGTH)+2,Peek(S_START) : Inc S_START
   Poke Varptr(S_LENGTH)+1,Peek(S_START) : Inc S_START
   Poke Varptr(S_LENGTH),Peek(S_START) : Inc S_START
   _TOAST$=_TOAST$+"Wav"
Else 
   _TOAST$=_TOAST$+"Raw PCM "
End If 
If _FLOAT
   _TOAST$=_TOAST$+" Float"
End If 
If _BITS>0
   _TOAST$=_TOAST$+Str$(_BITS)+"bit"
End If 
If _RATE>0
   _TOAST$=_TOAST$+Str$(_RATE)+_HZ$+_SPACE$
End If 
Return 
'
PARSECHUNK:
H_POS=S_START
S_START=Hunt(S_START To H_LENGTH,T$)
If S_START>0
   Add S_START,4 : C_LENGTH=Leek(S_START) : Add S_START,4
   T$=String$(_NULL$,C_LENGTH)
   Copy S_START,S_START+C_LENGTH To Varptr(T$)
   If Not _FULLCHUNK
      Repeat 
         Exit If Mid$(T$,C_LENGTH,1)<>Chr$(0)
         Dec C_LENGTH
      Until C_LENGTH<0
      If C_LENGTH>0
         T$=Left$(T$,C_LENGTH)
      Else 
         T$=_$
      End If 
   End If 
Else 
   T$=_$
   S_START=H_POS
End If 
_FULLCHUNK=False
Return 
'
CLRMETA:
_NAME$=_$ : _CPYR$=_$ : _AUTH$=_$ : _TXT$=_$ : _ANNO$=_$
_TAG=0 : _UNTY=0
'
SETMETA:
If B>_FL Then Return 
NAME$(B)=_NAME$
CPYR$(B)=_CPYR$
AUTH$(B)=_AUTH$
TXT$(B)=_TXT$
ANNO$(B)=_ANNO$
COMP(B)=_TAG
Return 
'
SETFILENAMELENGTH:
Set Dir 105,_$
Return 
'
SETFILENAME:
If B>_FL Then Return 
FB$(B)=F$
If F$<>_UNNAMED$ Then FPATH$(B)=Dir$ Else FPATH$(B)=_$
If B<11
   Mid$(MENB$(B),7)=Space$(16)
   If F$<>_$
      Mid$(MENB$(B),7)=Left$(FB$(B),8)
   End If 
End If 
Return 
'
SETUNNAMED:
If F$=_$
   F$=_UNNAMED$ : Gosub SETFILENAME
End If 
Return 
'
CLEANFILENAME:
I=Len(F$)
Repeat 
   Exit If Mid$(F$,I,1)<>_SPACE$
   Dec I
Until I<0
If I<1
   F$=_$
End If 
If I>0 and I<Len(F$)
   F$=Left$(F$,I)
End If 
Return 
'
SETFILEPOS:
TCOUNT=0
TPOS=FTOTAL-1
Repeat 
   TXT1$=FILES$(TCOUNT)
   CCOUNT=0
   If Peek(Varptr(TXT1$))<>CHR_STAR
      CN=Peek(Varptr(F$)+CCOUNT)
      If Fn KEY_UPPER(CN)
         CN=CN+32
      End If 
      CN2=Peek(Varptr(TXT1$)+1+CCOUNT)
      If Fn KEY_UPPER(CN2)
         CN2=CN2+32
      End If 
      If CN=CN2
         CCOUNT=1 : CSAME=1
         Repeat 
            CN=Peek(Varptr(F$)+CCOUNT)
            If Fn KEY_UPPER(CN)
               CN=CN+32
            End If 
            CN2=Peek(Varptr(TXT1$)+1+CCOUNT)
            If Fn KEY_UPPER(CN2)
               CN2=CN2+32
            End If 
            If CN=CN2
               Inc CSAME
            Else If CN>CN2 : Rem try next position  
               Dec CSAME
               Exit 
            Else If CN<CN2 : Rem this position
               Dec CSAME
               TPOS=TCOUNT
               TCOUNT=-1
               Exit 
            End If 
            Inc CCOUNT
         Until CCOUNT=>Len(TXT1$) or CCOUNT=>Len(F$)
         If CCOUNT=CSAME : Rem update size only 
            FILEL(TCOUNT)=S_LENGTH
            Return 
         End If 
      Else If CN<CN2 : Rem this position
         TPOS=TCOUNT
         TCOUNT=-1
         Exit 
      End If 
   End If 
   Inc TCOUNT
Until TCOUNT>FTOTAL or TCOUNT=0
TCOUNT=FTOTAL-1
While TPOS<TCOUNT
   Swap FILES$(TCOUNT),FILES$(TCOUNT-1)
   Swap FILEL(TCOUNT),FILEL(TCOUNT-1)
   Dec TCOUNT
Wend 
FILES$(TPOS)=_SPACE$+F$
FILEL(TPOS)=S_LENGTH
Inc FTOTAL
Return 
'
'
'
'***************************************************************************** 
'*edit************************************************************************ 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'   .,::::::::::::-.   :::  :::::::::: 
'   ;;;;'''';;,   `';, ;;;  ;;;;;;;''' 
'    [[cccc `[[     [[ [[[      [[     
'    $$""""  $$,    $$ $$$,     $$     
'    888oo,_ 888_,o8P'o88888    88,    
'    """"YUM"MMMMP"`  MMM"MM    MMM  
'
'
'  
_CUT:
If RL=0 or P_LENGTH=0 Then Goto FLSHSCR
Gosub _UNDOSET
Gosub _COPYSET
If RL=1 or RL=P_LENGTH
   Gosub _CLEARCOPY
   Bank Swap CBANK,PBANK
   If Fn MULTI
      Gosub CLRPLY
   Else 
      Gosub _STOP
   End If 
   Gosub SETPBANK
   If Fn INVIEW
      ADVPOS#(B)=0
   End If 
   F$=_$ : Gosub SETFILENAME
Else 
   S_LENGTH=Length(PBANK)-CLENGTHN
   Trap Reserve As Work WBANK,S_LENGTH
   If Errtrap
      Goto NOMEMORY
   End If 
   Gosub _CLEARCOPY
   Trap Reserve As Work CBANK,CLENGTHN
   If Errtrap
      Goto NOMEMORY
   End If 
   S_START=Start(CBANK)
   CCOUNT=0 : CLENGTH=0
   Repeat 
      Copy P_START+CLENGTH+RST,P_START+CLENGTH+RST+RL To S_START+(RL*CCOUNT)
      CLENGTH=CLENGTH+P_LENGTH
      Inc CCOUNT
   Until CCOUNT>CCOUNTN
   S_START=Start(WBANK)
   CCOUNT=0 : CLENGTH=0
   Repeat 
      If RST+CLENGTH>CLENGTH
         Copy P_START+CLENGTH,P_START+CLENGTH+RST To S_START+CLENGTH-(RL*CCOUNT)
      End If 
      If P_LENGTH>RST+RL
         Copy P_START+CLENGTH+RST+RL,P_START+CLENGTH+P_LENGTH To S_START+CLENGTH+RST-(RL*CCOUNT)
      End If 
      CLENGTH=CLENGTH+P_LENGTH
      Inc CCOUNT
   Until CCOUNT>CCOUNTN
   Gosub _WORKSWAP
   Gosub _RESIZED
End If 
Gosub _RANGENONE
Goto _SHOWALL
'
_CROP:
If RL<2 or RL=P_LENGTH Then Goto FLSHSCR
Gosub _UNDOSET
Gosub _COPYSET
Trap Reserve As Work WBANK,CLENGTHN
If Errtrap Then Goto NOMEMORY
S_START=Start(WBANK)
CCOUNT=0 : CLENGTH=0
Repeat 
   Copy P_START+CLENGTH+RST,P_START+CLENGTH+RST+RL To S_START+(RL*CCOUNT)
   CLENGTH=CLENGTH+P_LENGTH
   Inc CCOUNT
Until CCOUNT>CCOUNTN
Gosub _WORKSWAP
Gosub _RANGENONE
Goto _SHOWALL
'
_COPY:
If P_LENGTH=0 Then Goto FLSHSCR
If RL<2
   If Fn MULTIINVIEW
      Gosub NUDGE4POS
   End If 
   Gosub _RANGEALL
   If MACRO
      _CHOICE=3 : Rem after the macro clear the range  
   End If 
End If 
Gosub _COPYSET
Gosub _CLEARCOPY
Trap Reserve As Work CBANK,CLENGTHN
If Errtrap Then Goto NOMEMORY
S_START=Start(CBANK)
CCOUNT=0 : CLENGTH=0
Repeat 
   Copy P_START+CLENGTH+RST,P_START+CLENGTH+RST+RL To S_START+(RL*CCOUNT)
   CLENGTH=CLENGTH+P_LENGTH
   Inc CCOUNT
Until CCOUNT>CCOUNTN
Return 
'
_PASTE:
If Length(CBANK)=0 Then Goto NOCOPY
If Length(PBANK)=0
   S_START=Start(CBANK)
   S_LENGTH=Length(CBANK)
   Trap Reserve As Work PBANK,S_LENGTH
   If Errtrap
      Goto NOMEMORY
   End If 
   Copy S_START,S_START+S_LENGTH To Start(PBANK)
   RL=S_LENGTH
   Gosub SETUNNAMED
   Gosub SETPBANK
   Gosub SETCORDS
   If Fn MONOORSTEREOORQUAD or Fn MULTIINVIEW
      Goto _SHOWALL
   End If 
   Goto HEADER
End If 
Gosub _COPYSET
Gosub _UNDOSET
If Fn STEREO
   RL=Length(CBANK)/2
Else If Fn QUAD
   RL=Length(CBANK)/4
Else 
   RL=Length(CBANK)
End If 
S_LENGTH=Length(PBANK)+Length(CBANK)
Trap Reserve As Work WBANK,S_LENGTH
If Errtrap
   Goto NOMEMORY
End If 
CCOUNT=0
Repeat 
   If RST>0
      Copy Start(PBANK)+(P_LENGTH*CCOUNT),Start(PBANK)+(P_LENGTH*CCOUNT)+RST To Start(WBANK)+(P_LENGTH*CCOUNT)+(RL*CCOUNT)
   End If 
   Copy Start(CBANK)+(RL*CCOUNT),Start(CBANK)+(RL*CCOUNT)+RL To Start(WBANK)+(P_LENGTH*CCOUNT)+RST+(RL*CCOUNT)
   If RST<P_LENGTH
      Copy Start(PBANK)+(P_LENGTH*CCOUNT)+RST,Start(PBANK)+(P_LENGTH*CCOUNT)+P_LENGTH To Start(WBANK)+RST+(P_LENGTH*CCOUNT)+(RL*CCOUNT)+RL
   End If 
   Inc CCOUNT
Until CCOUNT>CCOUNTN
Gosub _WORKSWAP
Gosub _RESIZED
Gosub MAGICWAND
If Not Fn WANDZOOM
   XR=RST/CON#
   XR2=XR+(RL/CON#)
End If 
Gosub SETSELCORDS
If Fn MONOORSTEREOORQUAD or Fn MULTIINVIEW Then Goto _SHOWALL
Goto HEADER
'
_SIZE:
Gosub _OPENFXTEXTWIN
TXT1$="From"+Str$(P_LENGTH)+_COLON$
Gosub _RUNFXTEXTWIN
If T$=_$ Then REQ=False
If REQ
   Gosub _UNDOSET
   MACRO=True
   Gosub ŻSIZE
   MACRO=False
   Gosub _DRAWALL
End If 
_TEXT=False
Return 
'
_TIME:
Gosub _OPENFXTEXTWIN
DIV#=FREQ
TXT1$="From"+Str$(P_LENGTH/DIV#)+"s"+_COLON$
Gosub _RUNFXTEXTWIN
If T$=_$ Then REQ=False
If REQ
   CN=Int(Val(T$)*DIV#)
   T$=Str$(CN)
   Gosub _UNDOSET
   MACRO=True
   Gosub ŻSIZE
   MACRO=False
   Gosub _DRAWALL
End If 
_TEXT=False
Return 
'
_SWAP:
Gosub _OPENFXTEXTWIN
TXT1$="Swap"+Str$(B)+" with:"
Gosub _RUNFXTEXTWIN
If T$=_$ Then REQ=False
If REQ
   Gosub _RANGENONE
   If Not MACRO
      MACRO=True : Gosub ŻSWAP : MACRO=False
   Else 
      Gosub ŻSWAP
   End If 
End If 
_TEXT=False
Return 
'
SWPMENU:
If B=_M3SEL-2 Then Goto FLSHSCR
T$=Str$(_M3SEL-2)
MACRO=True : Gosub ŻSWAP : MACRO=False
Return 
'
_COPYSWAP:
Bank Swap PBANK,CBANK
XR=0 : XR2=0 : XD=0 : XD2=SCR_W : L=0 : ST=0 : FIN=0 : RST=0 : RFIN=0 : RL=0
REQ=True
Gosub PBANKLEN
Gosub POSCAL
Goto _SHOWALL
'
_COPYCOPY:
Bank Swap CBANK,CCBANK
Return 
'  
_CLEARCOPY:
If Length(CBANK)>0 Then Erase CBANK
REQ=True
Return 
'
_COPYSET:
Gosub SETPBANK
Gosub SETCORDS
If Fn STEREO
   CLENGTHN=RL*2
   CCOUNTN=1
Else If Fn QUAD
   CLENGTHN=RL*4
   CCOUNTN=3
Else 
   CLENGTHN=RL
   CCOUNTN=0
End If 
Return 
'
_UNDO:
If Length(UBANK)=0 Then Goto NOUNDO
If UB-B Then Goto WRONGUNDO
Bank Swap PBANK,UBANK
Gosub SETPBANK
If Length(PBANK)-Length(UBANK)
   Gosub _RANGENONE
   Gosub _RESIZED
End If 
Gosub _DRAWALL
If Instr(_UNDID$,"_ENCODE")
   COMP(B)=0
Else If Instr(_UNDID$,"_DECODEFIB")
   COMP(B)=1
Else If Instr(_UNDID$,"_DECODEEXP")
   COMP(B)=2
Else 
End If 
_TOAST$=G$ : Gosub T0AST
Goto CAL_BCK
'
_UNDOSET:
If REALTIME or MACRO or PASS>0 Then Return 
REQ=True
If P_LENGTH=0 Then Return 
_UNDID$=G$
S_LENGTH=Length(PBANK)
Trap Reserve As Work UBANK,S_LENGTH
If Errtrap Then Return 
Copy Start(PBANK),Start(PBANK)+S_LENGTH To Start(UBANK)
UB=B
Return 
'
_CLEARUNDO:
If Length(UBANK)>0 Then Erase UBANK
Return 
'
_WORKSWAP:
Bank Swap PBANK,WBANK
Return 
'
_CLEARWORK:
If Length(WBANK)>0 Then Erase WBANK
Return 
'
_RESIZED:
Gosub _CLEARWORK
Gosub PBANKLEN
If Fn MULTI
   If Fn INVIEW
      D_LENGTH(B)=Length(B+7)
      If D_LENGTH(B)>0
         ADV#(B)=(D_LENGTH(B)-ST-FIN)/SCR_W#
         D_START(B)=Start(B+7)+ST
      Else 
         ADV#(B)=0
      End If 
   End If 
End If 
Gosub SETSELV
RFIN=P_LENGTH-RST-RL
Gosub SETCORDS
Gosub HEADER
Gosub DRWTIME
Return 
'
'
'
'***************************************************************************** 
'*mix************************************************************************* 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    .        :   :::  :.,::      .:.
'    ;;,.    ;;;  ;;;   `;;;,  .,;;
'    [[[[, ,[[[[, [[[      '[[,,[['
'    $$$$$$$$"$$$ $$$,      Y$$$P
'   888 Y88" 888oo88888   oP"``"Yo,
'   MM  M'  "MMMMMMM"MM,m"       "Mm,
'
'
'
_MIX:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub MIXSET
If FX_LENGTH2=0 Then Goto NOCOPY
Gosub _UNDOSET
FX2=0
FX_START2=Start(CBANK)+(FX_LENGTH2*PASS)
Repeat 
   CN=Peek(FX)
   CN2=Peek(FX_START2+FX2)
   Gosub SIGN2
   If CN<0 and CN2<0
      CN=(CN+CN2)-((CN*CN2)/-128)
   Else If CN>0 and CN2>0
      CN=(CN+CN2)-((CN*CN2)/127)
   Else 
      Add CN,CN2
   End If 
   Inc FX2
   If FX2>FX_LENGTH2
      If _LPMIX
         FX2=0
      Else 
         FX=FXE
      End If 
   End If 
   Gosub UNSIGN
   Poke FX,CN
   Inc FX
Until FX>FXE
Return 
'
_ADD:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub MIXSET
If FX_LENGTH2=0 Then Goto NOCOPY
Gosub _UNDOSET
FX_START2=Start(CBANK)+(FX_LENGTH2*PASS)
FX2=0
Repeat 
   CN=Peek(FX)
   CN2=Peek(FX_START2+FX2)
   Gosub SIGN2
   CN=CN+CN2
   Inc FX2
   If FX2>FX_LENGTH2
      If _LPMIX
         FX2=0
      Else 
         FX=FXE
      End If 
   End If 
   Gosub UNSIGN
   Poke FX,CN
   Inc FX
Until FX>FXE
Return 
'
_SUBTRACT:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub MIXSET
If FX_LENGTH2=0 Then Goto NOCOPY
Gosub _UNDOSET
FX_START2=Start(CBANK)+(FX_LENGTH2*PASS)
FX2=0
Repeat 
   CN=Peek(FX)
   CN2=Peek(FX_START2+FX2)
   Gosub SIGN2
   CN=CN-CN2
   Inc FX2
   If FX2>FX_LENGTH2
      If _LPMIX
         FX2=0
      Else 
         FX=FXE
      End If 
   End If 
   Gosub UNSIGN
   Poke FX,CN
   Inc FX
Until FX>FXE
Return 
'
_AMPLITUDE:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub MIXSET
If FX_LENGTH2=0 Then Goto NOCOPY
Gosub _UNDOSET
FX_START2=Start(CBANK)+(FX_LENGTH2*PASS)
FX2=0
_RMS=BSIZE : SUMA#=0 : _READY=False
Repeat 
   CN=Peek(FX2+FX_START2)
   If FX2>_RMS
      _READY=True
      CN2=Peek(FX2+FX_START2-_RMS)
   Else 
      CN2=Peek(FX_START2+FX_LENGTH2-(_RMS-FX2))
   End If 
   Gosub FLOAT2
   SUMA#=SUMA#+(CN#*CN#)
   If _READY Then SUMA#=SUMA#-(CN2#*CN2#)
   If SUMA#<0 Then SUMA#=-SUMA#
   _RMS#=Sqr(SUMA#/_RMS)
   CN=Peek(FX)
   Gosub SIGN
   CN=Int(CN*_RMS#)
   Gosub UNSIGN
   Poke FX,CN
   Inc FX : Inc FX2
   If FX2>FX_LENGTH2 Then FX2=0
Until FX>FXE
Return 
'
_MODULATE:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub MIXSET
If FX_LENGTH2=0 Then Goto NOCOPY
Gosub _UNDOSET
FX_START2=Start(CBANK)+(FX_LENGTH2*PASS)
FX2=0
Repeat 
   CN=Peek(FX)
   CN2=Peek(FX_START2+FX2)
   Gosub SIGN2
   If CN2<0
      CN#=128
   Else 
      CN#=127
   End If 
   CN=Int(CN*(CN2/CN#))
   Inc FX2
   If FX2>FX_LENGTH2
      If _LPMIX
         FX2=0
      Else 
         FX=FXE
      End If 
   End If 
   Gosub UNSIGN
   Poke FX,CN
   Inc FX
Until FX>FXE
Return 
'
_XOR:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub MIXSET
If FX_LENGTH2=0 Then Goto NOCOPY
Gosub _UNDOSET
FX_START2=Start(CBANK)+(FX_LENGTH2*PASS)
FX2=0
Repeat 
   CN=Peek(FX)
   CN2=Peek(FX_START2+FX2)
   Gosub SIGN2
   CN=CN xor CN2
   Inc FX2
   If FX2>FX_LENGTH2
      If _LPMIX
         FX2=0
      Else 
         FX=FXE
      End If 
   End If 
   Gosub UNSIGN
   Poke FX,CN
   Inc FX
Until FX>FXE
Return 
'
_RENDER:
N#=FREQ
N2#=KEYF
N#=N2#/N#
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub MIXSET
If FX_LENGTH2=0 Then Goto NOCOPY
If Fn STEREOORQUAD and Length(CBANK)>Length(PBANK)
   _TOAST$="multi buffer overload" : Gosub T0AST
   Goto FLSHSCR
End If 
Gosub _UNDOSET
FX_START2=Start(PBANK)+(P_LENGTH*PASS)+OFFSET
FXE2=Start(PBANK)+(P_LENGTH*PASS)+P_LENGTH-1
FX_START=Start(CBANK)+(FX_LENGTH2*PASS)
FX_LENGTH=FX_LENGTH2
FXE=FX_START+FX_LENGTH2-1
FX2=0
FX3=FX_START2
CN#=N#
Repeat 
   CN=Int(CN#)
   CN#=FX2*N#
   FX=FX_START+CN
   If _INTERPOLATE
      Gosub WINSINC
   Else 
      CN=Peek(FX)
   End If 
   CN2=Peek(FX3)
   If _POLY
      Gosub SIGN2
      If CN<0 and CN2<0
         CN=(CN+CN2)-((CN*CN2)/-128)
      Else If CN>0 and CN2>0
         CN=(CN+CN2)-((CN*CN2)/127)
      Else 
         Add CN,CN2
      End If 
      Gosub UNSIGN
   End If 
   Poke FX3,CN
   Inc FX2 : Inc FX3
   If FX3>=FXE2
      If PIANO
         FX3=Start(PBANK)+(P_LENGTH*PASS)
      Else 
         FX=FXE
      End If 
   End If 
Until FX>=FXE
Return 
'
MIXSET:
If Fn STEREO
   FX_LENGTH2=Length(CBANK)/2
Else If Fn QUAD
   FX_LENGTH2=Length(CBANK)/4
Else 
   FX_LENGTH2=Length(CBANK)
End If 
Return 
'
'
'
'***************************************************************************** 
'*frame*********************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    .-:::::':::::::..    :::.      .        :  .,:::::: 
'    ;;;'''',;;;;``;;;;   ;;`;;     ;;,.    ;;; ;;;;'''' 
'    [[[,,==[\[[[,/[[['  ,[[ '[[,   [[[[, ,[[[[, [[cccc
'    `$$$"``""$$$$$$c   c$$$cc$$$c  $$$$$$$$"$$$ $$""""
'   _ 888    ,888b "88bo 888   888,888 Y88" 888o 888oo,_ 
'   MM"MM,   "MMMM   "W" YMM   ""` MM  M'  "MMMM """"YUM 
'
'
'
_SAMPLELEFT:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
FX_LENGTH2=1
LEFT:
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
Copy FX,FX+FX_LENGTH2 To Start(WBANK)
Copy FX+FX_LENGTH2,FXE To FX
Copy Start(WBANK),Start(WBANK)+FX_LENGTH2 To FXE-FX_LENGTH2
Gosub _CLEARWORK
Return 
'
_SAMPLERIGHT:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
FX_LENGTH2=1
RIGHT:
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
Copy FXE-FX_LENGTH2,FXE To Start(WBANK)
Copy FX,FXE-FX_LENGTH2 To FX+FX_LENGTH2
Copy Start(WBANK),Start(WBANK)+FX_LENGTH2 To FX
Gosub _CLEARWORK
Return 
'
_BEATLEFT:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
FX_LENGTH2=P_LENGTH/_TIMEDIV#
Goto LEFT
'
_BEATRIGHT:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
FX_LENGTH2=P_LENGTH/_TIMEDIV#
Goto RIGHT
'
_TIMEDIVISION:
_MENUDO=True : Rem hack 
Gosub HIGHDIV
Gosub _OPENFXTEXTWIN
TXT1$="From"+Str$(_TIMEDIV#)+_COLON$
Gosub _RUNFXTEXTWIN
_TEXT=True
If T$=_$ Then REQ=False
If REQ
   TIMEDIV:
   CN#=Val(T$)
   If CN#<2 or CN#>SCR_W
      Goto FLSHSCR
   End If 
   _TIMEDIV#=CN#
   _TIMEBEAT#=SCR_W/_TIMEDIV#
   If Not MACRO
      Gosub _DRAWALL
   End If 
Else 
   RENDERING=True
   Gosub DRWDIV
   RENDERING=False
End If 
_TEXT=False
_MENUDO=False : Rem hack 
Return 
'
HIGHDIV:
Ink _BRIGHT
Goto DIV
DRWDIV:
Ink _SHADOW
DIV:
DI#=_TIMEBEAT#
If(DI#<=40) Then DI#=DI#-1
INF_H=1
DE#=SCR_W-_TIMEBEAT#+1
Repeat 
   DI=Int(DI#)
   Draw DI,DIV_T To DI,DIV_T+INF_H
   Draw DI,DIV_B-INF_H To DI,DIV_B
   DI#=DI#+_TIMEBEAT#
   If INF_H=1 Then INF_H=2 Else INF_H=1
Until DI#>=DE#
If Fn MONOORSTEREOORQUAD Then Return 
DI#=_TIMEBEAT#
If(DI#<=40) Then DI#=DI#-1
INF_H=1
Repeat 
   DI=Int(DI#)
   Draw DI,DIV_U To DI,DIV_U+INF_H
   Draw DI,DIV_L-INF_H To DI,DIV_L
   DI#=DI#+_TIMEBEAT#
   If INF_H=1 Then INF_H=2 Else INF_H=1
Until DI#>=DE#
Return 
'
'
'
'***************************************************************************** 
'*volume********************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'   :::      .::.    ...       :::     ...    ::: .        :  .,:::::: 
'   ';;,   ,;;;'  .;;;;;;;.    ;;;    ';;     ;;; ;;,.    ;;; ;;;;'''' 
'    \[[  .[[/   ,[[     \[[,  [[[    [['     [[[ [[[[, ,[[[[, [[cccc  
'     Y$c.$$"    $$$,     $$$  $$'    $$      $$$ $$$$$$$$"$$$ $$""""  
'      Y88P      "888,_ _,88Po88oo,.__88    .d888888 Y88" 888o 888oo,_ 
'       MP         "YMMMMMP" """YUMMMM "YmmMMMM""MM  M'  "MMMM """"YUM 
'  
'
'
_VOLUME:
Gosub SETREALTIME
If FXSHOW
   If PASS=0
      Gosub SETPBANK
      If FX_LENGTH<2
         Goto FLSHSCR
      End If 
      CHAIN$(1)="_VOLUMEP"
      Gosub _OPENFXWIN
      FXN=VN : FXSN=VN : FXS$=_PERCENT$ : Gosub FXDRW
      Gosub VODRW
      FXRUN$="VODRW"
      Gosub _RUNFXWIN
   End If 
   If Not REQ
      Return 
   End If 
End If 
_VOLUMEP:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
Repeat 
   CN=Peek(FX)
   Gosub SIGN
   CN=Int(CN*VA#)
   Gosub UNSIGN
   Poke FX,CN
   Inc FX
Until FX>FXE
Return 
'
VODRW:
VN=FXN
VA#=VN*0.01
FXSN=VN
Return 
'
_FADEIN:
CN2=0
Goto _FADE
_FADEOUT:
CN2=1
_FADE:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
DIV#=FX_LENGTH/100.0
If DIV#=0 Then Goto FLSHSCR
Gosub _UNDOSET
FX2=FX_LENGTH*CN2
Repeat 
   CN=Peek(FX)
   Gosub SIGN
   CN#=(FX2/DIV#)/100.0
   CN=Int(CN*CN#)
   Gosub UNSIGN
   Poke FX,CN
   Inc FX
   If CN2=0 Then Inc FX2 Else Dec FX2
Until FX>FXE
Return 
'
_HALF:
VA#=0.5
Goto _VOLUMEP
'
_DOUBLE:
VA#=2.0
Goto _VOLUMEP
'
_SILENCE:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
Repeat 
   FX_LENGTH2=Min(FX_LENGTH-(FX-FX_START),_MEGABYTE)
   Fill FX To FX+FX_LENGTH2,0
   FX=FX+FX_LENGTH2
Until FX>FXE
Return 
'
_MAXIMIZE:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
CN2=0
If PASS=0
   Repeat 
      CN=Peek(FX)
      Gosub SIGN
      If CN>CN2
         CN2=CN
      Else If CN<0 and CN<-CN2
         CN2=-CN
      End If 
      Inc FX
   Until FX>FXE
   If CN2=0 or CN2=127
      Return 
   End If 
   VA#=127.0/CN2
End If 
Goto _VOLUMEP
'
_DCOFFSET:
Gosub SETREALTIME
If FXSHOW
   If PASS=0
      Gosub SETPBANK
      If FX_LENGTH<2
         Goto FLSHSCR
      End If 
      _REPEAT$="_DCOFFSETP"
      Gosub _OPENFXTEXTWIN
      BTXT1$="Auto" : BX=267 : BY=71 : BZN=ZN_AUTO : Gosub BTN
      T$=_$ : _EXIT=False : _TEXT=True : KDOWN=False
      TXT1$="-127 to 127:"
      TXT_X=340 : TXT_Y=Y+68 : N=0 : _MAX=9
      Repeat 
         Gosub _TEXTINPUT
         Repeat 
            Gosub GVAL
            If Z=ZN_AUTO and Fn MOUSEDOWN
               PZN=Z : BX=267 : BY=71 : Gosub PRESS
               If _ON
                  Gosub WINC
                  Reset Zone ZN_AUTO
                  REQ=True
                  Goto _DCSCAN
               End If 
            Else If Z=ZN_OK and Fn MOUSEDOWN or Fn KEY_RETURN
               PZN=Z : BX=RX : BY=87 : Gosub PRESS
               If _ON
                  REQ=True
                  _EXIT=True
               End If 
            Else If Z=ZN_CANCEL and Fn MOUSEDOWN or Fn KEY_ESC
               PZN=Z : BX=RX+107 : BY=87 : Gosub PRESS
               If _ON
                  REQ=False
                  _EXIT=True
               End If 
            End If 
         Until _EXIT or C
      Until _EXIT
      _TEXT=False
      Gosub WINC
      Reset Zone ZN_AUTO
      CN=Val(T$)
      If(T$=_$ or CN=0) and REQ
         REQ=False
         Gosub FLSHSCR
      End If 
      If Not REQ
         Return 
      End If 
      Gosub CHECKCLIP
      _DCOFFSETN=CN
   End If 
   If Not REQ
      Return 
   End If 
End If 
_DCOFFSETP:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
Repeat 
   CN=Peek(FX)
   Gosub SIGN
   CN=CN+_DCOFFSETN
   Gosub UNSIGN
   Poke FX,CN
   Inc FX
Until FX>FXE
Return 
'
_DCSCAN:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
CN2=0 : CN3=0
Repeat 
   CN=Peek(FX)
   Gosub SIGN
   If CN>0
      If CN>CN2
         CN2=CN
      End If 
   Else If CN<0
      If CN<CN3
         CN3=CN
      End If 
   End If 
   Inc FX
Until FX>FXE
_DCOFFSETN=(-CN3-CN2)/2
Goto _DCOFFSETP
'
_DCHALVE:
Gosub _UNDOSET
MACRO=True
_DCOFFSETN=127
Gosub _DCOFFSETP
_DCOFFSETN=-127
Gosub _DCOFFSETP
MACRO=False
Return 
'
'
'
'***************************************************************************** 
'*resample******************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'   :::::::..  .,:::::: .::::::.   :::.      .        :  ::::::::.   :::    .,:::: 
'   ;;;;``;;;; ;;;;'''';;;`    `;  ;;`;;     ;;,.    ;;; `;;```.;;;  ;;;    ;;;;'' 
'   \[[[,/[[['  [[cccc '[==/[[[[, ,[[ '[[,   [[[[, ,[[[[,`]]nnn]]'   [[[     [[ccc 
'   "$$$$$$c    $$""""   '''    $c$$$cc$$$c  $$$$$$$$"$$$ $$$""      $$'     $$""" 
'   ,888b "88bo 888oo,_,88b    dP 888   888,888 Y88" 888o 888o     o88oo,.__ 888oo 
'   "MMMM   "W" """"YUM  "YMmMY"  YMM   ""` MM  M'  "MMMM YMMMb    """YUMMMM """"Y 
'  
'
'
_RERESAMPLE:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Goto S
_RESAMPLE:
If _SWAP
   Swap N#,N2#
   _SWAP=False
End If 
N#=N2#/N#
S:
FX_LENGTH2=Int(FX_LENGTH/N#)
If FX_LENGTH2<2 Then Goto FLSHSCR
If RL<2 Then _SCALEMIX=False Else _SCALEMIX=True
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
Gosub _UNDOSET
FX_START2=Start(WBANK)
FX2=0
FX3=FX_START2
FXE2=FX_START2+FX_LENGTH2-1
CN#=N#
Repeat 
   CN=Int(CN#)
   CN#=FX2*N#
   FX=FX_START+CN
   If _INTERPOLATE
      Gosub WINSINC
   Else 
      CN=Peek(FX)
   End If 
   Poke FX3,CN
   Inc FX2 : Inc FX3
Until FX3>=FXE2 or FX=FXE
FX=FXE
If _SCALEMIX
   If FX_LENGTH2>=FX_LENGTH
      FX_LENGTH3=FX_LENGTH
   Else 
      FX_LENGTH3=FX_LENGTH2
   End If 
   If Not MACRO
      MACRO=True : Gosub _SILENCE : MACRO=False
   Else 
      Gosub _SILENCE
   End If 
   Copy FX_START2,FX_START2+FX_LENGTH3 To FX_START
Else 
   Gosub _WORKSWAP
   Gosub _RESIZED
End If 
If Instr(_REPEAT$,_MACRO$)=0
   _REPEAT$="_RERESAMPLE"
End If 
Return 
'
WINSINC:
If FREQ>N2#
   FMAX#=(N2#/2.0)-1
Else 
   FMAX#=(FREQ/2.0)-1
End If 
WNWDTH=14
X=FX-FX_START
'***************************************************************************** 
'   Windowed-Sinc Resampling by Ronald H. Nicholson Jr.  
'
R_G#=2*FMAX#/FREQ : Rem Calc gain correction factor
R_Y#=0
For I=-WNWDTH/2 To(WNWDTH/2)-1 : Rem For 1 window width 
   J=Int(X+I) : Rem Calc input sample index
   Rem calculate von Hann Window. Scale and calculate Sinc
   R_W#=0.5-0.5*Cos(_2PI#*(0.5+(J-X)/WNWDTH))
   R_A#=_2PI#*(J-X)*FMAX#/FREQ
   R_SNC#=1
   If(R_A#<>0) Then R_SNC#=Sin(R_A#)/R_A#
   If(J>=0) and(J<FX_LENGTH)
      CN=Peek(FX_START+J)
      Gosub SIGN
      CN=CN*255
      R_Y#=R_Y#+R_G#*R_W#*R_SNC#*CN
   End If 
Next I
CN=Int(R_Y#) : Rem Return new filtered sample 
CN=CN/255
Gosub UNSIGN
Return 
'
'***************************************************************************** 
'
_BYRATE:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
If PASS=0
   Gosub _OPENFXTEXTWIN
   BTXT1$=_$ : BX=267 : BY=71 : BZN=ZN_PIANO : Gosub BTN
   Gosub BYRATEPIANO
   T$=_$ : _EXIT=False : _TEXT=True : KDOWN=False
   TXT1$="From "+Str$(FREQ)-_SPACE$+_COLON$
   TXT_X=340 : TXT_Y=Y+68 : N=0 : _MAX=9
   Repeat 
      Gosub _TEXTINPUT
      Repeat 
         Gosub GVAL
         If Z=ZN_PIANO and M
            Repeat 
               Gosub GVAL
               If Z=ZN_PIANO and KDOWN=False
                  PZN=Z : BX=267 : BY=71
                  Ink _COL
                  Draw BX+9,BY+2 To BX+93,BY+2
                  Gosub HIGHBTN
                  Inc BY : Gosub BYRATEPIANO : Dec BY
                  N=0
                  T$=_$
                  KDOWN=True
               End If 
               If Fn KEY_PRESS and KDOWN
                  Gosub PIANO
                  If KEYC<>-1
                     _TOAST$=KEYS$
                     T$=Str$(KEYF)-_SPACE$
                     N=Len(T$)
                     C=0
                     Gosub _TEXTINPUT
                  Else 
                     Gosub FLSHSCR
                  End If 
               End If 
               If KDOWN and( Fn MOUSEUP or PZN<>Z)
                  PZN=Z : BX=267 : BY=71 : Gosub BTN
                  Gosub BYRATEPIANO
                  KDOWN=False
               End If 
            Until Fn MOUSEUP
         Else If Z=ZN_OK and Fn MOUSEDOWN or Fn KEY_RETURN
            PZN=Z : BX=RX : BY=RY+28 : Gosub PRESS
            If _ON
               REQ=True
               _EXIT=True
            End If 
         Else If Z=ZN_CANCEL and Fn MOUSEDOWN or Fn KEY_ESC
            PZN=Z : BX=RX+107 : BY=RY+28 : Gosub PRESS
            If _ON
               REQ=False
               _EXIT=True
            End If 
         End If 
      Until _EXIT or C
   Until _EXIT
   Gosub WINC
   Reset Zone ZN_PIANO
   If Not REQ
      Return 
   End If 
   _SWAP=True
   _BYRATEP:
   _TEXT=True
   Gosub SETPBANK
   If FX_LENGTH<2
      Goto FLSHSCR
   End If 
   _TEXT=False
End If 
N2#=Val(T$)
If N2#<600 Then Goto FLSHSCR
N#=FREQ
Goto _RESAMPLE
'
BYRATEPIANO:
Ink _BLACK
Bar BX+9,BY+2 To BX+93,BY+11
Paste Bob BX+9,BY+2,3
Return 
'
_BYTIME:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
DIV#=FREQ
N2#=P_LENGTH/DIV#
TXT1$="From"+Str$(N2#)+"s"+_COLON$
Goto BYWIN
'
_BYSIZE:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
N2#=FX_LENGTH
TXT1$="From "+Str$(N2#)-_SPACE$+_COLON$
Goto BYWIN
'  
_BYBPM:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
DIV#=FREQ
DIV#=((DIV#/Length(PBANK))*60)*4
If Fn STEREO
   DIV#=DIV#*2
Else If Fn QUAD
   DIV#=DIV#*4
End If 
N2#=DIV#
_SWAP=True
TXT1$="From "+Str$(DIV#)-_SPACE$+_COLON$
'
BYWIN:
If PASS=0
   Gosub _OPENFXTEXTWIN
   Gosub _RUNFXTEXTWIN
   If Not REQ
      Return 
   End If 
   _TEXT=True
   Gosub SETPBANK
   If FX_LENGTH<2
      Goto FLSHSCR
   End If 
   _TEXT=False
End If 
N#=Val(T$)
If N#<2 Then Goto FLSHSCR
Goto _RESAMPLE
'
_OCTAVEUP:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
If RL<2 Then _SCALEMIX=False Else _SCALEMIX=True
FX_LENGTH2=FX_LENGTH/2
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
FX_START2=Start(WBANK)
FX2=0
Repeat 
   If FX>FX_START Then CNL=Peek(FX-1)
   CN=Peek(FX)
   If FX<FXE Then CN2=Peek(FX+1)
   If FX<FXE-1 Then CNR=Peek(FX+2)
   A0=CNR-CN2-CNL+CN
   A1=CNL-CN-A0
   A2=CN2-CNL
   A3=CN
   Gosub SIGN
   CN=A0+A1+A2+A3
   If FX_START2+FX_LENGTH2>FX_START2+FX2
      Poke FX_START2+FX2,CN : Inc FX2
   End If 
   Inc FX : Inc FX
Until FX>FXE
If _SCALEMIX
   If Not MACRO
      MACRO=True : Gosub _SILENCE : MACRO=False
   Else 
      Gosub _SILENCE
   End If 
   Copy FX_START2,FX_START2+FX_LENGTH2/2 To FX_START
Else 
   Gosub _WORKSWAP
   Gosub _RESIZED
   RST=RST/2
   Gosub HEADERCORDS
   If BGPLYING
      If Fn MULTIINVIEW and OFFSET(B)>P_LENGTH
         OFFSET(B)=OFFSET(B)-P_LENGTH
      Else If Fn MONOORSTEREOORQUAD and OFFSET(1)>P_LENGTH
         OFFSET(1)=OFFSET(1)-P_LENGTH
      End If 
   End If 
End If 
Return 
'
_OCTAVEDOWN:
Gosub SETPBANK
If FX_LENGTH<2 Then Goto FLSHSCR
Gosub _UNDOSET
If RL<2 Then _SCALEMIX=False Else _SCALEMIX=True
FX_LENGTH2=FX_LENGTH*2
Trap Reserve As Work WBANK,FX_LENGTH2
If Errtrap Then Goto NOMEMORY
FX_START2=Start(WBANK)
FX2=0
Repeat 
   If FX>FX_START Then CNL=Peek(FX-1)
   CN=Peek(FX)
   If FX<FXE Then CN2=Peek(FX+1)
   If FX<FXE-1 Then CNR=Peek(FX+2)
   A0=CNR-CN2-CNL+CN
   A1=CNL-CN-A0
   A2=CN2-CNL
   A3=CN
   Gosub SIGN
   CN2=A0+A1+A2+A3
   Poke FX_START2+FX2,CN : Inc FX2
   Poke FX_START2+FX2,CN2 : Inc FX2
   Inc FX
Until FX>FXE
If _SCALEMIX
   If Not MACRO
      MACRO=True : Gosub _SILENCE : MACRO=False
   Else 
      Gosub _SILENCE
   End If 
   Copy FX_START2,FX_START2+FX_LENGTH2 To FX_START
Else 
   Gosub _WORKSWAP
   Gosub _RESIZED
End If 
Return 
'
_NOTEUP:
PFREQ=FREQ
FREQ=16730
T$="17734"
Gosub _BYRATEP
FREQ=PFREQ
Goto SETHZ
'
_NOTEDOWN:
PFREQ=FREQ
FREQ=17734
T$="16730"
Gosub _BYRATEP
FREQ=PFREQ
Goto SETHZ
'
_FINEUP:
T$=Str$(FREQ+50)
Goto _BYRATEP
'  
_FINEDOWN:
T$=Str$(FREQ-50)
Goto _BYRATEP
'
