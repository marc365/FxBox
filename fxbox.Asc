'***************************************************************************** 
'*memory********************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'    .        :  .,:::::: .        :      ...     :::::::..  -:.     ::-.: 
'    ;;,.    ;;; ;;;;'''' ;;,.    ;;;  .;;;;;;;.  ;;;;``;;;; ';;.   ;;;;'' 
'    [[[[, ,[[[[, [[cccc  [[[[, ,[[[[,,[[     \[[,\[[[,/[[['    '[[,[[[' 
'    $$$$$$$$"$$$ $$""""  $$$$$$$$"$$$$$$,     $$$"$$$$$$c        c$$" 
'   888 Y88" 888o 888oo,_888 Y88" 888o"888,_ _,88P,888b "88bo   ,8P"`
'   MM  M'  "MMMM """"YUMMM  M'  "MMMM  "YMMMMMP" "MMMM   "W"  mM" 
'
'
'
'  
FKEY:
N=C-79
If Fn KEY_SHIFT Then T$="S=" Else T$="B="
T$=T$+Str$(N)-_SPACE$
If PLYING and CON#>0 and SETTING$(26)<>_FALSE$ : Rem quantizer
   _TOAST$=_$
   T$=T$+_COMMA$+_NEWLINE$
   Goto ACTION
Else 
   If MACRO
      Gosub CMD
   Else 
      MACRO=True
      Gosub CMD
      If Not SEQUENCER
         MACRO=False
      End If 
   End If 
End If 
Return 
'
BANKMENU:
B=_M2SEL
If PB=B Then Return 
Goto SETBANK
'
_PREVIOUS:
If B=1 Then Return 
Dec B
REQ=True
Goto SETBANK
'
_NEXT:
If B=_FL Then Return 
Inc B
REQ=True
Goto SETBANK
'  
SETBANK:
Gosub CLRRNG
Gosub BANKSET
If PB=B
   If Fn MULTI
      PBANK=PB+7
   End If 
   Return 
End If 
LB=PB
XR=0 : XR2=0 : LXR=0 : LXR2=0
RST=0 : RL=0 : RFIN=0
Gosub SETZN
If Fn MONOORSTEREOORQUAD
   PBANK=5
   Bank Swap PB+7,PBANK
   Bank Swap PBANK,B+7
Else 
   PBANK=B+7
End If 
PB=B
F$=FB$(B)
P_LENGTH=Length(PBANK)
If P_LENGTH>0
   P_START=Start(PBANK)
Else If Fn MONOORSTEREOORQUAD or Fn INVIEW
   If Fn MULTI
      Gosub CLREMPTY
   Else 
      Gosub CLRPLY
   End If 
End If 
Gosub PBANKLEN
Gosub SETPBANK
If SETTING$(27)<>_FALSE$ or STPPED : Rem always draw
   If RENDERING=False and _MENUDO=False
      If Fn MULTI
         RENDERING=True
         Gosub R4INSET
      Else 
         Gosub CLRPOS
         RENDERING=True
         Gosub _DRAW
      End If 
      RENDERING=False
   End If 
End If 
Gosub HEADER
Gosub DRWTIME
Goto MAGICWAND
'
_FLUSHBUFFERS:
BTXT1$="Clear" : TXT1$="This will clear" : TXT2$="the variable buffers?" : Gosub _REQUEST
If Not REQ Then Return 
Goto E
'
_ERASEALL:
BTXT1$="Clear" : TXT1$="This will clear all" : TXT2$="samples and buffers?" : Gosub _REQUEST
If Not REQ Then Return 
Gosub _STOP
BANKNAME$=_$ : F$=_$ : PF$=_$
B=1
Repeat 
   CHAIN$(B)=_$
   Inc B
Until B>_XC
While _FXCUR>32767
   Dec _FXCUR
   Erase _FXCUR
Wend 
Erase PBANK
B=1
Repeat 
   FB$(B)=_$ : FPATH$(B)=_$
   Gosub CLRMETA
   Erase B+7
   Inc B
Until B>_FL
B=1
Repeat 
   Mid$(MENB$(B),7)=Space$(7)
   Inc B
Until B>10
B=1
_M3SEL=1 : Gosub M0DEMENU
Gosub _NORMALPIANO
E:
Gosub _CLEARUNDO
Gosub _CLEARCOPY
Gosub _CLEARWORK
Gosub CLRFILES
SEQ$=_$ : SEQF$=_$ : SEQP$=_$ : DISPATCH$=_$
T$=_$ : S$=_$ : D$=_$
XD=0 : XD2=SCR_W : XR=0 : XR2=0 : LXR=0 : LXR2=0
RST=0 : RL=0 : RFIN=0
Gosub SETBANK
Gosub MAGICWAND
Gosub SETPBANK
If Not BGPLYING
   P_LENGTH=0 : PLYTIME=0 : STPTIME=0
End If 
RENDERING=True
Gosub _DRAW
RENDERING=False
Gosub HEADER
Gosub DRWTIME
Goto _TOASTFREE
'
CLRPLY:
Fill P_STARTB1 To P_STARTB1+(BSIZE*_CH),0
Fill P_STARTB2 To P_STARTB2+(BSIZE*_CH),0
Return 
'
CLREMPTY:
If Fn INVIEW
   N=0
   Repeat 
      If Length(N+8)=0
         If PBSIZE>BSIZE and N>1
            Fill P_STARTB1+(BSIZE*(N-1)) To P_STARTB1+(BSIZE*N)+PBSIZE,0
            Fill P_STARTB2+(BSIZE*(N-1)) To P_STARTB2+(BSIZE*N)+PBSIZE,0
         End If 
      End If 
      Inc N
   Until N>3
End If 
Return 
'  
SETPBANK:
If Length(PBANK)=0
   FX_LENGTH=0
   P_LENGTH=0
   Return 
End If 
If REALTIME
   FX=P_SWP
   FX_START=FX
   FX_LENGTH=BSIZE
   FXE=FX+BSIZE-1
Else 
   FX_START=Start(PBANK)+RST
   If RL>Length(PBANK)-RST or RST+RL=0
      FX_LENGTH=Length(PBANK)-RST
   Else If RL<2
      FX_START=Start(PBANK)
      FX_LENGTH=Length(PBANK)
   Else 
      FX_LENGTH=RL
   End If 
   FX=FX_START
   FXE=FX_START+FX_LENGTH-1
End If 
P_START=Start(PBANK)
P_LENGTH=Length(PBANK)
If Fn STEREO
   P_LENGTH=P_LENGTH/2
Else If Fn QUAD
   P_LENGTH=P_LENGTH/4
End If 
Return 
'
PBANKLEN:
FI=Length(PBANK)
If Fn STEREO
   FI=FI/2
Else If Fn QUAD
   FI=FI/4
End If 
Return 
'
STEREOQUAD:
If Fn STEREO
   RN=0
Else If Fn QUAD
   RN=2
Else 
   Return 
End If 
Gosub _RANGESET
RI=0
Repeat 
   Inc PASS
   RST=RST+P_LENGTH : RFIN=RFIN+P_LENGTH
   Gosub G$
   Inc RI
Until RI>RN
Gosub _RANGERESTORE
PASS=0
Return 
'
STEREOQUADX2:
If _CHANNELS=2
   RN=1
   Inc _FXCUR
   Reserve As Work _FXCUR,Length(WBANK)*2
Else If _CHANNELS=4
   RN=3
   Inc _FXCUR
   Reserve As Work _FXCUR,Length(WBANK)*4
Else 
   Return 
End If 
Copy Start(WBANK),Start(WBANK)+Length(WBANK) To Start(_FXCUR)
Gosub _RANGESET
RI=1
Repeat 
   Inc PASS
   RST=RST+P_LENGTH : RFIN=RFIN+P_LENGTH
   Gosub G$
   Copy Start(WBANK),Start(WBANK)+Length(WBANK) To Start(_FXCUR)+(Length(WBANK)*RI)
   Erase WBANK
   Inc RI
Until RI>RN
Gosub _RANGERESTORE
Bank Swap _FXCUR,PBANK
Erase _FXCUR
Dec _FXCUR
PASS=0
Return 
'
FXBUFFER:
FXBC=1
Repeat 
   Trap Reserve As Work _FXCUR,_FXBUF
   If Errtrap
      _FXCUR=-1
      Goto NOMEMORY
   End If 
   Inc _FXCUR
   Inc FXBC
Until FXBC>_CH
FXBC=1
Return 
'
FXBUFFERC:
FXBC=_CH
Repeat 
   Dec _FXCUR
   Erase(_FXCUR)
   Dec FXBC
Until FXBC<1
Return 
'
_TOASTFREE:
_TOAST$="Buffer:"+Str$( Fn BUFFER/1000)+_KILO$
Goto T0AST
'
