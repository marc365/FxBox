'***************************************************************************** 
'*help************************************************************************ 
'***************************************************************************** 
'***************************************************************************** 
'***************************************************************************** 
'
'     ::   .: .,::::::  :::    ::::::::. 
'    ,;;   ;;,;;;;''''  ;;;    `;;```.;;;
'   ,[[[,,,[[[ [[cccc   [[[    `]]nnn]]' 
'   "$$$"""$$$ $$""""   $$'     $$$""
'    888   "88 888oo,_o88oo,.__ 888o 
'    MMM    YM """"YUM"""YUMMMM YMMMb
'
'
'
_OPTIONS:
_TEXT=True
RX=105 : RY=20
WTXT$=S$ : WX=98 : WY=RY : WX2=542 : WY2=146 : _COL=_PANE : Gosub WIN
Gosub OPTBTN
Repeat 
   Gosub GVAL
   E$=_$
   If Fn MOUSEDOWN and Z>=ZN_OPTIONS and Z<ZN_OPTIONSOK
      Restore OPB
      BZN=ZN_OPTIONS
      Repeat 
         Read BTXT1$,BTXT2$,BX,BY,E$
         If Z=BZN
            PZN=Z : Add BX,RX : Add BY,RY : Gosub PRESS
            If _ON
               If BZN<ZN_OPTIONSOK-3
                  N=BZN-ZN_OPTIONS+10
                  Gosub SETSET
               End If 
               Gosub E$
               Gosub OPTBTN
               Exit 
            Else 
               Exit 
            End If 
         End If 
         Inc BZN
      Until BZN=ZN_OPTIONSOK
      If E$=_$
         Exit 
      End If 
   End If 
Until Fn KEY_RETURN or Fn KEY_ESC
Goto OPTC
'
OPTOK:
REQ=True
Pop 
OPTC:
I=ZN_OPTIONS : N=ZN_OPTIONSOK : Gosub RESETZN
Gosub MAGICWAND
Gosub WINC
Gosub NUDGEPOS
Return 
'  
OPTBTN:
Restore OPB
BZN=ZN_OPTIONS
Repeat 
   Read BTXT1$,BTXT2$,BX,BY,E$
   If BZN<ZN_OPTIONSOK-3
      If SETTING$(BZN-ZN_OPTIONS+10)<>_FALSE$
         If BTXT2$<>_$
            Swap BTXT1$,BTXT2$
         End If 
         _COL=_WHITE
      Else 
         _COL=_PANE
      End If 
   Else 
      If BZN=23 and _DITHER=0
         _COL=_PANE
      Else If BZN=24 and _INTERPOLATE=0
         _COL=_PANE
      Else 
         _COL=_WHITE
      End If 
   End If 
   Add BX,RX : Add BY,RY : Gosub BTN
   Inc BZN
Until BZN=ZN_OPTIONSOK
If _DITHER=1
   T$="Dither"
Else If _DITHER=2
   T$="HP-Tri"
Else If _DITHER=3
   T$="LP"
Else 
   T$="None"
End If 
Ink _SHADOW,_PANE
Text RX+112,RY+119,Space$(6)
Text RX+112,RY+119,T$
If _INTERPOLATE=1
   T$="W-Sinc"
Else 
   T$="  None"
End If 
Ink _SHADOW,_PANE
Text RX+270,RY+119,Space$(6)
Text RX+270,RY+119,T$
Return 
'
SETSET:
If SETTING$(N)<>_FALSE$
   SETTING$(N)=_FALSE$
Else 
   SETTING$(N)=_TRUE$
End If 
Return 
'  
SETFILTER:
If SETTING$(10)=_FALSE$ Then Led Off Else Led On 
Return 
'
SETMON:
If SETTING$(11)<>_FALSE$
   MONHZ#=50.0 : CLOCK=3546895 : Rem pal
Else 
   MONHZ#=60.0 : CLOCK=3579545 : Rem ntsc 
End If 
Reserve As Chip Work 3,MFREQ/MONHZ#*_CH
Reserve As Chip Work 4,MFREQ/MONHZ#*_CH
P_STARTB1=Start(3) : P_STARTB2=Start(4)
If _INIT
   SETTING$(29)=_FALSE$ : Rem -0.2hz 
   _AMIHZ=False
   Gosub SETHZ
   Gosub DRWTIMENOW
End If 
Return 
'
SETLIGHTMODE:
If SETTING$(12)=_FALSE$
   Palette $0,$222,$777,$222,$111,$444,$999,$AAA,,,,,,,,,,$DDD,$999,$111
Else 
   Palette $0,$599,$DDD,$566,$111,$377,$FFF,$E70
   Gosub MCOL
End If 
If _INIT Then Gosub R4INRESTORE
Return 
'
SETDEBUG:
If SETTING$(13)=_FALSE$ Then _DEBUG=False Else _DEBUG=True
If _INIT Then Gosub _TOASTFREE
Return 
'  
SETNETSYNC:
If BSD=False and SETTING$(14)<>_FALSE$
   NN=14 : Gosub BSD
Else If BSD and SETTING$(14)=_FALSE$
   NETSYNC=False
   If _INIT
      Gosub _STOP
   End If 
   Goto SOCK_CLOSESYNC
End If 
If BSD
   If _INIT
      Gosub _STOP
   End If 
   Gosub SOCK_OPENSYNC
   If CONNECT=-1
      TXT1$="Failed sync socket" : TXT2$=_$ : Gosub _NOTICE
      Gosub SOCK_CLOSESYNC
      SOCKSYNC=-1
      NETSYNC=False
   Else 
      NETSYNC=True
   End If 
Else 
   NETSYNC=False
End If 
Return 
'
SETHIRES:
SB=Screen Base
If SETTING$(15)=_FALSE$
   If _INIT
      Doke SB+72,Deek(SB+72) xor Hires
   End If 
   SCR_R=Lowres
Else 
   If _INIT
      Doke SB+72,Deek(SB+72) or Hires
      Screen Offset 0,0,0
   End If 
   SCR_R=Hires
End If 
Return 
'  
SETPOSITION:
If SETTING$(16)=_FALSE$ Then _POSITIONOFF=True Else _POSITIONOFF=False
Return 
'
SETLEVELMETER:
If SETTING$(17)=_FALSE$ Then _LEVEL=False Else _LEVEL=True
Return 
'  
SETMETRONOME:
If SETTING$(18)=_FALSE$
   _METRO=False
   If _INIT
      Goto METROC
   End If 
Else 
   _METRO=True
End If 
Return 
'
SETPREVIEW:
If SETTING$(19)=_FALSE$ Then _PREVIEW=False Else _PREVIEW=True
Return 
'
'ZOOMDRAW  
'
SETGRAPH:
If SETTING$(21)<>_FALSE$ Then _STEP=2 Else _STEP=1
Return 
'
'WHEELZOOM 
'
SETAREXXSYNC:
If REXX=False and SETTING$(23)<>_FALSE$
   SETTING$(23)=_FALSE$
   TXT1$="Arexx server" : TXT2$=_NOTAVAILABLE$ : Gosub _ERROR
   If _INIT
      Pop : Goto _OPTIONS
   End If 
Else If REXX and Arexx Exist(OCTAMED_REXX$)
   OCTAMED=True
Else If SETTING$(23)<>_FALSE$
   OCTAMED=False
   SETTING$(23)=_FALSE$
   TXT1$="Octamed arexx port" : TXT2$=_NOTAVAILABLE$ : Gosub _ERROR
   If _INIT
      Pop : Goto _OPTIONS
   End If 
Else 
   OCTAMED=False
End If 
Return 
'
'SCROLLER  
'
SETVST:
If BSD=False and SETTING$(25)<>_FALSE$
   NN=25 : Gosub BSD
Else If BSD and SETTING$(25)=_FALSE$
   _VST=False
   If _INIT
      Gosub _STOP
   End If 
   Goto SOCK_CLOSEVST
End If 
If BSD
   If _INIT
      Gosub _STOP
   End If 
   Gosub SOCK_OPENVST
   If CONNECT=-1
      TXT1$="Failed vst socket" : TXT2$=_$ : Gosub _NOTICE
      Gosub SOCK_CLOSEVST
      SOCKVST=-1
      _VST=False
   Else 
      _VST=True
   End If 
Else 
   _VST=False
End If 
Return 
'
'QUANTIZER 
'
SETALWAYSDRAW:
If SETTING$(27)=_FALSE$ Then SETTING$(20)=_FALSE$ : Rem zoom draw
Return 
'
'MAGIC 
'
SETPOINT2:
If SETTING$(29)=_FALSE$
   If _INIT
      MONHZ#=0.2+MONHZ#
      _TOAST$=Str$(MONHZ#)+_HZ$
   End If 
Else 
   MONHZ#=-0.2+MONHZ#
   _TOAST$=Str$(MONHZ#)+_HZ$
End If 
If _INIT
   _AMIHZ=False
   Gosub SETHZ
   Gosub DRWTIMENOW
End If 
Return 
'
_TGLDITHER:
Inc _DITHER
If _DITHER>3
   _DITHER=0
End If 
Return 
'
_TGLINTERPOLATE:
Inc _INTERPOLATE
If _INTERPOLATE>1
   _INTERPOLATE=0
End If 
Return 

'
_ABOUT:
_TEXT=True : ABOUT=True
WTXT$="FxBox" : WX=149 : WY=28 : WX2=490 : WY2=127 : _COL=_WHITE : Gosub WIN
Set Text 4 : Text WX+4+48,WY+10,"powered by" : Set Text 0 : Paste Bob WX+141,WY,2
T$="Chip:"+Str$((Chip Free/1000))-_SPACE$+_KILO$
Ink _WHITE,_SHADOW
Text WX2-Text Length(T$)-3,WY+10,T$
Gosub HEADER
Ink _BLACK,_WHITE
Text 168,56,Mid$("$VER: Version 1.21 © 1991-2026 Marc Williams",7)
Text 232,64,"Benchmark:"
If REXX
   T$=FXBOX_REXX$
Else 
   T$=_NOTAVAILABLE$
End If 
Text 224,72,"Arexx Port: "+T$
If OCTAMED
   If SETTING$(23)<>_FALSE$ : Rem arexx sync 
      T$=OCTAMED_REXX$
   Else 
      T$=_NOTACTIVE$
   End If 
Else 
   T$=_NOTAVAILABLE$
End If 
Text 208,80,"Octamed Sync: "+T$
If Not BSD Then Gosub BSD
If NETSYNC
   T$=_ADDRSYNC$+_COLON$+Str$(_PORTSYNC)-_SPACE$
Else If BSD
   T$=_NOTACTIVE$
Else 
   T$=_NOTAVAILABLE$
End If 
Text 240,88,"Net Sync: "+T$
If _VST
   T$=_ADDRVST$+_COLON$+Str$(_PORTVST)-_SPACE$
Else If BSD
   T$=_NOTACTIVE$
Else 
   T$=_NOTAVAILABLE$
End If 
Text 248,96,"VST Out: "+T$
If P_LENGTH=0 Then TIME$="not playing" Else TIME$=_$
Text 232,104,"Play Time: "+TIME$
Paste Bob WX2-178,WY2-BUT_H,4
BX=0 : BY=Int(Timer+MONHZ#)
Repeat 
   Inc BX
Until Timer>BY
Text 312,64,Str$(BX/1E+06)+" DSP MIPS"
Gosub WINWAITC
ABOUT=False
Return 
'
